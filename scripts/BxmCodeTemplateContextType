public class BuilderActivator extends AbstractUIPlugin {
	protected final static Logger logger = LoggerFactory.getLogger(BuilderActivator.class);

	// The plug-in ID
	public static final String PLUGIN_ID = "bxm.builder";

	private static final String CODE_TEMPLATES_KEY= "org.eclipse.jdt.ui.text.custom_code_templates";

	private static final String CODE_TEMPLATES_MIGRATION_KEY= "org.eclipse.jdt.ui.text.code_templates_migrated";

	// The shared instance
	private static BuilderActivator plugin;

	private static ContextTypeRegistry codeTemplateContextTypeRegistry;

	private TemplateStore fCodeTemplateStore;

	private BuilderConfiguration configuration;

	private ServiceListInfo fServiceListInfo;

	/**
	 * The constructor
	 */
	public BuilderActivator() {
	}

	public void start(BundleContext context) throws Exception {
		super.start(context);
		plugin = this;
		
		org.eclipse.jdt.internal.core.util.Messages.build_compiling="자바 컴파일 {0}";


		/* 2012.11.05 - 설정항목 선수행 */
		loadConfigurationExtensionRegistry();

		getCodeTemplateContextRegistry();
//		getConfigureLogger();

		loadNewProjectProviderExtensionRegistry();
		loadTestCaseValueProviderExtensionRegistry();


		DeployExecutorManager.instance();

		processTemplate();
	}

	public void stop(BundleContext context) throws Exception {
		plugin = null;
		super.stop(context);
	}

	/**
	 * Returns an image descriptor for the image file at the given
	 * plug-in relative path
	 *
	 * @param path the path
	 * @return the image descriptor
	 */
	public static ImageDescriptor getImageDescriptor(String path) {
		return imageDescriptorFromPlugin(PLUGIN_ID, path);
	}

	/**
	 * Returns the shared instance
	 *
	 * @return the shared instance
	 */
	public static BuilderActivator getDefault() {
		return plugin;
	}

	public BuilderConfiguration getConfiguration() {
		if (configuration == null) {
			configuration= configurationLoad();
		}

		return configuration;
	}

	public ServiceListInfo getServiceListInfo() {
		if (this.fServiceListInfo == null) {
			this.fServiceListInfo= new ServiceListInfo();
		}

		return this.fServiceListInfo;
	}

	public static IWorkspace getWorkspace() {
		return ResourcesPlugin.getWorkspace();
	}

	public static IWorkbenchPage getActivePage() {
		return getDefault().internalGetActivePage();
	}

	public static IWorkbenchWindow getActiveWorkbenchWindow() {
		return getDefault().getWorkbench().getActiveWorkbenchWindow();
	}

	public static Shell getActiveWorkbenchShell() {
		 IWorkbenchWindow window= getActiveWorkbenchWindow();
		 if (window != null) {
		 	return window.getShell();
		 }
		 return null;
	}

	public static String getPluginId() {
		return BuilderActivator.PLUGIN_ID;
	}

	/**
	 * Preferences > Java > Code Style > Code Templates
	 * Code Templates에 ContextType을 등록한다.
	 * @return ContextTypeRegistry
	 */
	public ContextTypeRegistry getCodeTemplateContextRegistry() {
		logger.debug("BuilderActivator.getCodeTemplateContextRegistry : " + codeTemplateContextTypeRegistry);
		if (codeTemplateContextTypeRegistry == null) {
			codeTemplateContextTypeRegistry = JavaPlugin.getDefault().getCodeTemplateContextRegistry();

			BxmCodeTemplateContextType.registerContextTypes(codeTemplateContextTypeRegistry);
		}

		return codeTemplateContextTypeRegistry;
	}

	public TemplateStore getCodeTemplateStore() {
		logger.debug("BuilderActivator.getCodeTemplateStore : " + fCodeTemplateStore);
		if (fCodeTemplateStore == null) {
			IPreferenceStore store= getPreferenceStore();
			boolean alreadyMigrated= store.getBoolean(CODE_TEMPLATES_MIGRATION_KEY);
			if (alreadyMigrated)
				fCodeTemplateStore= new ContributionTemplateStore(getCodeTemplateContextRegistry(), store, CODE_TEMPLATES_KEY);
			else {
				fCodeTemplateStore= new TemplateStore(getCodeTemplateContextRegistry(), store, CODE_TEMPLATES_KEY);
				store.setValue(CODE_TEMPLATES_MIGRATION_KEY, true);
			}

			try {
				fCodeTemplateStore.load();
			} catch (IOException e) {
				logger.error("", e);
			}

			fCodeTemplateStore.startListeningForPreferenceChanges();

			// compatibility / bug fixing code for duplicated templates
			// TODO remove for 3.0
//			CompatibilityTemplateStore.prunwldnjewleDuplicates(fCodeTemplateStore, true);//21 확인
			
		}

		return fCodeTemplateStore;
	}

	/**
	 * Private deprecated method to avoid deprecation warnings
	 *
	 * @return the deprecated code template store
	 * @deprecated to avoid deprecation warnings
	 */
//	private org.eclipse.jdt.internal.corext.template.java.CodeTemplates getOldCodeTemplateStoreInstance() {
//		return org.eclipse.jdt.internal.corext.template.java.CodeTemplates.getInstance();
//	}

	private IWorkbenchPage internalGetActivePage() {
		IWorkbenchWindow window= getWorkbench().getActiveWorkbenchWindow();
		if (window == null)
			return null;
		return window.getActivePage();
	}

	private BuilderConfiguration configurationLoad() {
		BuilderConfiguration config= null;
		try {
			config= PreferenceConfiguration.load();
		}
		catch (Exception e) {
			config= PreferenceConfiguration.loadDefault();
			BuilderLog.logInfo("Builder - Load default configuration");
		}
		return config;
	}

	private void getConfigureLogger()
	{
//		final URL url = getClass().getClassLoader().getResource("log4j.properties");
		final URL url = getClass().getClassLoader().getResource("log4j2.xml");
		if (null == url) {
			return;
		}

//		PropertyConfigurator.configure(url);
	}

	/*
	 * 2012.11.05 PARK.Jeongyeob
	 *
	 * 빌더 플러긴에 대한 extension 항목 호출 - Configuration 항목
	 */
	private void loadConfigurationExtensionRegistry() throws Exception
	{
		CodeTemplateContextManager.instance();		// 초기화를 위한 호출
		logger.debug("Builder - loadConfigurationExtensionRegistry()");
		try {
			IConfigurationElement[] configs = Platform.getExtensionRegistry().getConfigurationElementsFor("bxm.builder.configuration");

			for (IConfigurationElement e : configs) {

				final Object o = e.createExecutableExtension("class");

				if (o instanceof IBuilderConfiguration ) {
					try {
						IBuilderConfiguration bc = (IBuilderConfiguration)o;
						if ( bc != null )
						{
							logger.debug("Do config : {}", bc.getId());
							bc.doConfig();
						}
					} catch (Exception e2) {
						BuilderLog.logError("Error : IBuilderConfiguration ", e2);
						e2.printStackTrace();
					}
				}
			}
		} catch (Exception e) {
			BuilderLog.logError("Error - load extension-point: bxm.builder.configuration ", e);
			e.printStackTrace();
		}
	}

	private void loadNewProjectProviderExtensionRegistry() throws Exception
	{
		BuilderCustomizationManager.instance();
	}

	private void loadTestCaseValueProviderExtensionRegistry() throws Exception
	{
		TestCaseValueManager.instance();
	}

	public void processTemplate(){

		// 기본 제공 템플릿 사용여부 설정
		if ( !ConfigurationUtils.getConfiguration().isUseDefaultTemplate() ){
			TemplatePersistenceData[] datas= JavaPlugin.getDefault().getTemplateStore().getTemplateData(false);

			for (TemplatePersistenceData data : datas) {
				Template template= data.getTemplate();
				if ( template.getName().startsWith("fw_")){
					JavaPlugin.getDefault().getTemplateStore().delete(data);
				}
			}

			try {
				JavaPlugin.getDefault().getTemplateStore().save();
			} catch (Exception e) {
				e.printStackTrace();
			}
		}
	}
}