JDK 7 + EGit 4.1.1 기준으로 바꿔야 할 것들부터 정리할게요.

---

## 변경 목록

| 항목 | JDK 8 | JDK 7 |
|---|---|---|
| 람다 | `r -> {}` | 익명 클래스 |
| 스트림 | `.stream().forEach()` | for문 |
| 메서드 참조 | `this::register` | 익명 클래스 |
| 다중 catch | `catch (A \| B e)` | catch 분리 |
| RepositoryUtil | `RepositoryUtil.INSTANCE` | `Activator.getDefault().getRepositoryUtil()` |

---

## 변환된 전체 코드

### `BxmGitRepositoryInitializer.java`

```java
package bxm.team.scm.git;

import java.io.File;
import java.nio.file.ClosedWatchServiceException;
import java.nio.file.FileSystems;
import java.nio.file.Path;
import java.nio.file.StandardWatchEventKinds;
import java.nio.file.WatchEvent;
import java.nio.file.WatchKey;
import java.nio.file.WatchService;
import java.util.ArrayList;
import java.util.Collections;
import java.util.Comparator;
import java.util.List;
import java.util.Map;
import java.util.concurrent.ConcurrentHashMap;
import java.util.concurrent.ExecutorService;
import java.util.concurrent.Executors;
import java.util.concurrent.ScheduledExecutorService;
import java.util.concurrent.ScheduledFuture;
import java.util.concurrent.ThreadFactory;
import java.util.concurrent.TimeUnit;
import java.util.concurrent.atomic.AtomicBoolean;

import org.eclipse.core.runtime.CoreException;
import org.eclipse.core.runtime.IConfigurationElement;
import org.eclipse.core.runtime.IExtension;
import org.eclipse.core.runtime.IExtensionPoint;
import org.eclipse.core.runtime.IExtensionRegistry;
import org.eclipse.core.runtime.Platform;
import org.eclipse.jgit.api.Git;
import org.eclipse.jgit.diff.DiffEntry;
import org.eclipse.jgit.lib.ObjectReader;
import org.eclipse.jgit.lib.Repository;
import org.eclipse.jgit.revwalk.RevCommit;
import org.eclipse.jgit.revwalk.RevWalk;
import org.eclipse.jgit.treewalk.AbstractTreeIterator;
import org.eclipse.jgit.treewalk.CanonicalTreeParser;

public class BxmGitRepositoryInitializer {

    private WatchService watchService;
    private final Map<WatchKey, Repository> keyToRepo = new ConcurrentHashMap<WatchKey, Repository>();
    private final AtomicBoolean running = new AtomicBoolean(false);

    // ✅ JDK 7 — 람다 → ThreadFactory 익명 클래스
    private final ScheduledExecutorService debouncer =
            Executors.newSingleThreadScheduledExecutor(new ThreadFactory() {
                @Override
                public Thread newThread(Runnable r) {
                    Thread t = new Thread(r, "BXM-Git-Debouncer");
                    t.setDaemon(true);
                    return t;
                }
            });

    private final ExecutorService commitExecutor =
            Executors.newFixedThreadPool(2, new ThreadFactory() {
                @Override
                public Thread newThread(Runnable r) {
                    Thread t = new Thread(r, "BXM-Git-CommitWorker");
                    t.setDaemon(true);
                    return t;
                }
            });

    private final Map<Repository, ScheduledFuture<?>> pendingCommits =
            new ConcurrentHashMap<Repository, ScheduledFuture<?>>();

    public void start() {
        if (running.getAndSet(true)) return;

        try {
            watchService = FileSystems.getDefault().newWatchService();

            Thread watchThread = new Thread(new Runnable() {
                @Override
                public void run() {
                    watchLoop();
                }
            }, "BXM-Git-Watcher");
            watchThread.setDaemon(true);
            watchThread.start();

            // ✅ JVM 강제종료 대비 ShutdownHook
            Runtime.getRuntime().addShutdownHook(new Thread(new Runnable() {
                @Override
                public void run() {
                    dispose();
                }
            }, "BXM-Git-Shutdown"));

        } catch (Exception e) {
            e.printStackTrace();
        }
    }

    public void init(Repository repo) {
        if (watchService == null) return;
        File gitDir = repo.getDirectory();
        if (gitDir == null || !gitDir.exists()) return;

        // ✅ JDK 7 — 스트림 → for문
        boolean alreadyRegistered = false;
        for (Repository r : keyToRepo.values()) {
            if (r.getDirectory().equals(gitDir)) {
                alreadyRegistered = true;
                break;
            }
        }
        if (alreadyRegistered) return;

        try {
            WatchKey key = gitDir.toPath().register(
                    watchService,
                    StandardWatchEventKinds.ENTRY_MODIFY
            );
            keyToRepo.put(key, repo);
        } catch (Exception e) {
            e.printStackTrace();
        }
    }

    private void watchLoop() {
        while (running.get()) {
            try {
                WatchKey key = watchService.poll(1, TimeUnit.SECONDS);
                if (key == null) continue;

                Repository repo = keyToRepo.get(key);
                if (repo != null) {
                    for (WatchEvent<?> event : key.pollEvents()) {
                        Path changed = (Path) event.context();
                        if ("COMMIT_EDITMSG".equals(changed.getFileName().toString())) {
                            scheduleCommit(repo);
                        }
                    }
                }

                if (!key.reset()) {
                    keyToRepo.remove(key);
                }

            } catch (ClosedWatchServiceException e) {
                break;
            } catch (InterruptedException e) {
                Thread.currentThread().interrupt();
                break;
            } catch (Exception e) {
                e.printStackTrace();
            }
        }
    }

    // ✅ JDK 7 — 람다 → 익명 Runnable
    private void scheduleCommit(final Repository repo) {
        ScheduledFuture<?> existing = pendingCommits.get(repo);
        if (existing != null) {
            existing.cancel(false);
        }

        ScheduledFuture<?> future = debouncer.schedule(new Runnable() {
            @Override
            public void run() {
                pendingCommits.remove(repo);
                commitExecutor.submit(new Runnable() {
                    @Override
                    public void run() {
                        onCommit(repo);
                    }
                });
            }
        }, 500, TimeUnit.MILLISECONDS);

        pendingCommits.put(repo, future);
    }

    private void onCommit(Repository repo) {
        Git git = new Git(repo);
        try {
            RevCommit latest = git.log().setMaxCount(1).call().iterator().next();
            List<String> files = getChangedFiles(git, repo, latest);
            fireParticipants(files, repo.getWorkTree());
        } catch (Exception e) {
            e.printStackTrace();
        } finally {
            // ✅ JDK 7 — try-with-resources 대신 finally
            git.close();
        }
    }

    public void dispose() {
        if (!running.getAndSet(false)) return;

        // 대기 중인 커밋 취소
        for (ScheduledFuture<?> f : pendingCommits.values()) {
            f.cancel(false);
        }
        pendingCommits.clear();

        try {
            if (watchService != null) watchService.close();
        } catch (Exception ignored) {}

        shutdownExecutor(debouncer, "debouncer");
        shutdownExecutor(commitExecutor, "commitExecutor");

        keyToRepo.clear();
    }

    private void shutdownExecutor(ExecutorService executor, String name) {
        executor.shutdown();
        try {
            if (!executor.awaitTermination(5, TimeUnit.SECONDS)) {
                executor.shutdownNow();
            }
        } catch (InterruptedException e) {
            executor.shutdownNow();
            Thread.currentThread().interrupt();
        }
    }

    private List<String> getChangedFiles(Git git, Repository repo, RevCommit commit) throws Exception {
        List<String> result = new ArrayList<String>();
        if (commit.getParentCount() == 0) return result;

        RevCommit parent = commit.getParent(0);
        List<DiffEntry> diffs = git.diff()
                .setOldTree(prepareTreeParser(repo, parent))
                .setNewTree(prepareTreeParser(repo, commit))
                .call();

        for (DiffEntry diff : diffs) {
            switch (diff.getChangeType()) {
                case ADD:    result.add("A:" + diff.getNewPath()); break;
                case MODIFY: result.add("M:" + diff.getNewPath()); break;
                case DELETE: result.add("D:" + diff.getOldPath()); break;
                default: break;
            }
        }
        return result;
    }

    private void fireParticipants(List<String> files, File repoRoot) {
        IExtensionRegistry registry = Platform.getExtensionRegistry();
        IExtensionPoint ep = registry.getExtensionPoint("bxm.team.scm.git.commit");
        if (ep == null) {
            System.err.println("[BXM] Extension point 'bxm.team.scm.git.commit' not found");
            return;
        }

        List<IBxmGitCommitParticipant> participants = new ArrayList<IBxmGitCommitParticipant>();
        for (IExtension ext : ep.getExtensions()) {
            for (IConfigurationElement el : ext.getConfigurationElements()) {
                try {
                    IBxmGitCommitParticipant p =
                        (IBxmGitCommitParticipant) el.createExecutableExtension("class");
                    participants.add(p);
                } catch (CoreException e) {
                    e.printStackTrace();
                }
            }
        }

        // ✅ JDK 7 — Comparator 익명 클래스
        Collections.sort(participants, new Comparator<IBxmGitCommitParticipant>() {
            @Override
            public int compare(IBxmGitCommitParticipant a, IBxmGitCommitParticipant b) {
                return Integer.compare(a.getPriority(), b.getPriority());
            }
        });

        for (IBxmGitCommitParticipant p : participants) {
            Object pre = p.performPreProcess();
            p.performAfterCommitTasks(pre, files, repoRoot);
            p.performPostProcess();
        }
    }

    private AbstractTreeIterator prepareTreeParser(Repository repo, RevCommit commit) throws Exception {
        RevWalk walk = new RevWalk(repo);
        ObjectReader reader = repo.newObjectReader();
        try {
            CanonicalTreeParser parser = new CanonicalTreeParser();
            parser.reset(reader, walk.parseTree(commit.getTree()));
            return parser;
        } finally {
            // ✅ JDK 7 — 다중 try-with-resources 대신 finally
            reader.close();
            walk.close();
        }
    }
}
```

### `BxmGitRepositoryManager.java`

```java
public void start() {
    initializer.start();

    // ✅ EGit 4.1.1 — INSTANCE 없음, Activator에서 꺼내야 함
    org.eclipse.egit.core.RepositoryUtil repoUtil =
            org.eclipse.egit.core.Activator.getDefault().getRepositoryUtil();

    // ✅ JDK 7 — forEach 대신 for문
    for (String repoDir : repoUtil.getConfiguredRepositories()) {
        register(repoDir);
    }
}

public void stop() {
    initializer.dispose();
    for (Repository repo : registeredRepos) {
        repo.close();
    }
    registeredRepos.clear();
}
```

---

## EGit 4.1.1 주요 API 변경점

| EGit 7.x | EGit 4.1.1 |
|---|---|
| `RepositoryUtil.INSTANCE` | `Activator.getDefault().getRepositoryUtil()` |
| `repoUtil.getRepositories()` | `repoUtil.getConfiguredRepositories()` |

`getConfiguredRepositories()`가 없으면 에러 메시지 알려주세요, EGit 4.1.1 소스에서 정확한 메서드명 확인해드릴게요.
