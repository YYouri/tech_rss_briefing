        <properties/>
        
        <example><![CDATA[
/* 잘못된 예 */  
public class Foo {
  private int x; // could be final
  public Foo() {
      x = 7;
  }
  public void foo() {
     int a = x + 2;
  }
}
  
      ]]></example>
       
    </rule>

  
   <rule name="DuplicateImports" 
         language="java" 
         message="''{0}'' import문이 중복 선언 되었음" 
         class="net.sourceforge.pmd.lang.java.rule.imports.DuplicateImportsRule"
      	 externalInfoUrl="http://developer.cis.co.kr/support/pmd/DuplicateImports.html">
      	 
        <description>
impot 문이 중복 선언 되었는지 확인합니다.
        </description>
        
        <priority>1</priority>
        <properties/>
        
        <example><![CDATA[

import java.lang.String;
import java.lang.*;
public class Foo {}

    ]]></example>
       
       
       
    </rule>
    
        <rule name="ImportFromSamePackage" 
          language="java" 
          message="동일 패키지에 있을 때는 import문을 사용할 필요가 없음" 
          class="net.sourceforge.pmd.lang.java.rule.imports.ImportFromSamePackageRule"
      	  externalInfoUrl="http://developer.cis.co.kr/support/pmd/ImportFromSamePackage.html">

        <description>
동일 패키지에 있을때는 impot 해줄 필요가 없습니다.
     </description>
     
        <priority>1</priority>
        <properties/>
        
        <example><![CDATA[
 
 package foo;
 import foo.Buz; // no need for this
 import foo.*; // or this
 public class Bar{}
 
     ]]></example>

    </rule>
        
   
     <rule name="InefficientEmptyStringCheck" 
           language="java" 
           message="Empty String 을 체크하기 위해 String.trim().length() 을 사용하는 것은 피하도록 함" 
           class="net.sourceforge.pmd.lang.java.rule.strings.InefficientEmptyStringCheckRule"
      	   externalInfoUrl="http://developer.cis.co.kr/support/pmd/InefficientEmptyStringCheck.html">
     
        <description>

비효율적인 Empty String 체크를 하는지 확인합니다.
Empty String 체크시 String.trim().length() 를 사용하는것은 피해야 합니다.
    
    </description>
    
            <priority>1</priority>
        <properties/>
        
        <example><![CDATA[
/* 잘못된 예 */
public class Foo {
    void bar(String string) {
        if (string != null && string.trim().size() > 0) { 
		    doSomething();
        } 
    }
}

    ]]></example>

    </rule>
    
    
      <rule name="InefficientStringBuffering" 
            language="java" 
            message="StringBuffer 함수에서 nonliteral 을 직접 concatenate 하지 말 것" 
            class="net.sourceforge.pmd.lang.java.rule.strings.InefficientStringBufferingRule"
      		externalInfoUrl="http://developer.cis.co.kr/support/pmd/InefficientStringBuffering.html">
            
        <description>
StringBuffer 함수에서 nonliteral간의 연결을 직접적으로 하지 말아야 합니다.
    </description>
    
            <priority>2</priority>
        <properties/>
        
        <example><![CDATA[

public class Foo {
 void bar() {
 
  /* 잘못된 예 */
  StringBuffer sb=new StringBuffer("tmp = "+System.getProperty("java.io.tmpdir"));
 
  /* 올바른 예 */
  StringBuffer sb = new StringBuffer("tmp = ");
  sb.append(System.getProperty("java.io.tmpdir"));
 }
}

    ]]></example>

    </rule>
    
      <rule name="StringInstantiation" 
          language="java" 
          message="필요없는 Instance가 생성되어 있음" 
          class="net.sourceforge.pmd.lang.java.rule.strings.StringInstantiationRule"
      	  externalInfoUrl="http://developer.cis.co.kr/support/pmd/StringInstantiation.html">
          
        <description>
불필요한 인스턴스가생성되었는지 확인합니다.
        </description>
    
        <priority>1</priority>
        <properties/>
        
        <example><![CDATA[
        
 /* 잘못된 예 */
public class Foo {
 private String bar = new String("bar"); // just do a String bar = "bar";
}

    ]]></example>

    </rule>
    
    
     <rule name="StringToString" 
           language="java" 
           message="String 객체에서 toString()함수를 사용하는 것은 불필요함" 
           class="net.sourceforge.pmd.lang.java.rule.strings.StringToStringRule"
      	   externalInfoUrl="http://developer.cis.co.kr/support/pmd/StringToString.html">
       
        <description>
String 객체에서 toString()함수를 사용하는 것은 불필요함
        </description>
        
        <priority>1</priority>
        <properties/>
                
        <example><![CDATA[
        
 /* 잘못된 예 */
public class Foo {
 private String baz() {
  String bar = "howdy";
  return   bar.toString();
 }
}

    ]]></example>

    </rule>
        
        
</ruleset> 

