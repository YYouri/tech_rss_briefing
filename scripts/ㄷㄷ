package bxm.das.ui.svn;

import java.lang.reflect.InvocationTargetException;
import java.sql.Connection;
import java.text.MessageFormat;
import java.util.ArrayList;
import java.util.HashMap;
import java.util.List;
import java.util.Map;
import java.util.Map.Entry;

import org.eclipse.core.resources.IResource;
import org.eclipse.core.runtime.IProgressMonitor;
import org.eclipse.core.runtime.SubProgressMonitor;
import org.eclipse.jface.dialogs.ProgressMonitorDialog;
import org.eclipse.jface.operation.IRunnableWithProgress;
import org.eclipse.team.svn.core.IStateFilter;
import org.eclipse.team.svn.core.operation.CompositeOperation;
import org.eclipse.team.svn.core.operation.IActionOperation;
import org.eclipse.team.svn.core.operation.IRevisionProvider;
import org.eclipse.team.svn.core.utility.FileUtility;
import org.eclipse.ui.IWorkbenchPart;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;

import bxm.das.ui.PluginLog;
import bxm.das.ui.approval.ApprovalDao;
import bxm.das.ui.approval.ApprovalInterface;
import bxm.das.ui.approval.ApprovalMapper;
import bxm.das.ui.config.DASConfigUtils;
import bxm.das.ui.db.DBUtils;
import bxm.das.ui.dependency.DependencyDao;
import bxm.das.ui.dependency.DependenyAnalyzer;
import bxm.das.ui.text.UIText;
import bxm.das.ui.util.common.StringUtils;
import bxm.das.ui.util.view.MessageUtils;
import bxm.datatools.enablement.exception.DASException;
import bxm.team.scm.svn.IBxmCommitParticipant;
import bxm.team.scm.svn.SvnUtils;
import bxm.ui.db.ConnectionManager;
import bxm.ui.db.config.ConfigurationUtils;
import bxm.ui.util.BXMUtils;

public class SVNCommitHooker
implements IBxmCommitParticipant
{
	private Connection conn;
	private DependenyAnalyzer dependenyAnalyzer;

	private ApprovalMapper approvalMapper;
	private ApprovalInterface approvalInterface;

	private Map<IResource, Throwable> errorList;

	public SVNCommitHooker()
	{
	}

	private Logger log() {
		return LoggerFactory.getLogger(getClass());
	}

	public void internalPerformAfterCommitTasks(Object preProcessResult, CompositeOperation operation,
			IRevisionProvider revisionProvider, IActionOperation[] dependsOn, IWorkbenchPart part, IProgressMonitor monitor)
	{
		if ( isSkipCommitOperation() ) {
			log().info("DBIO Commit Operation 처리를 Skip 합니다.");
			return;
		}

		final SVNResourceOperation resourceOper = new SVNResourceOperation();
		final IResource[] resources = resourceOper.getResources(operation);
		if ( resources == null ) {
			log().debug("처리할 resources 가 없습니다.");
			return;
		}

		final IResource[] resourcesToAdd = FileUtility.getResourcesRecursive(resources, IStateFilter.SF_ADDED, 0);
		final IResource[] resourcesToModify = FileUtility.getResourcesRecursive(resources, IStateFilter.SF_MODIFIED, 0);
		final IResource[] _resourcesToDelete = FileUtility.getResourcesRecursive(resources, IStateFilter.SF_DELETED, 0);

		/*
		 * SVN 에 replaced 는  delete / add 에 목록이 추가되므로 delete 가 가장 먼저 처리되어야 함.
		 * 처리 순서는 dbio -> interface -> dependency 순서로 처리해야 함.
		 */
		final IResource[] resourcesToDelete = removeResource(resourcesToAdd, _resourcesToDelete);

		String svnUserId= SvnUtils.getUserId(resources[0]);
		if ( DASConfigUtils.applyApproval() ) {
			procApprovalMapper( resourcesToDelete, true, svnUserId );
			procApprovalMapper( resourcesToAdd, false, svnUserId );
			procApprovalMapper( resourcesToModify, false, svnUserId );

			procApprovalInterface( resourcesToDelete, true );
			procApprovalInterface( resourcesToAdd, false );
			procApprovalInterface( resourcesToModify, false );
		}

		/**
		 * FW Connection Name 이
		 * 업무 Connection Name 에 없어도 관계 없으므로
		 * 아래 소스 주석처리 함
		 * 2012.09.06 신창영
		 */
//		List<DASDataSource> list = DASConfigUtils.cloneDataSources();
//		for ( DASDataSource ds : list )
//		{
//			if ( temp.equals(ds.getConnection()) )
//			{
//				connectionName = ds.getName();
//				break;
//			}
//		}

//		if ( DASConfigUtils.applyDependency() ) {
//			procDependencyMapper( resourcesToDelete, true, monitor );
//			procDependencyMapper( resourcesToAdd, false, monitor );
//			procDependencyMapper( resourcesToModify, false , monitor);
//		}

		if ( getErrorList().size() > 0 ) {

			resourceOper.removeAll(operation);

			final StringBuilder msg = new StringBuilder();

			msg.append(">> 아래의 Resource 는 Commit 될 수 없습니다. <<\n\n");
//			msg.append("- 대상 Connection : ");
//			msg.append(connectionName);
//			msg.append("\n\n");
			msg.append( getErrorMessage() );
			msg.append(">> Commit Operation 을 취소합니다. <<\n");

			MessageUtils.openError(msg.toString());

		} else {

			log().debug(">>> {}", DASConfigUtils.applyDependency());

			if ( DASConfigUtils.applyDependency() ) {
				procDependencyMapper( resourcesToDelete, true , monitor);
				procDependencyMapper( resourcesToAdd, false , monitor);
				procDependencyMapper( resourcesToModify, false , monitor);

				if ( getErrorList().size() > 0 )
				{
					resourceOper.removeAll(operation);

					final StringBuilder msg = new StringBuilder();

					msg.append(">> 아래의 Resource 는 Commit 될 수 없습니다. <<\n\n");
//					msg.append("- 대상 Connection : ");
//					msg.append(connectionName);
//					msg.append("\n\n");
					msg.append( getErrorMessage() );
					msg.append(">> Commit Operation 을 취소합니다. <<\n");

					MessageUtils.openError(msg.toString());
				}
			}
			else{
				System.out.println(">> DBIO DEPENDENCY를 사용하지 않습니다.");
			}
		}
	}

	@Override
	public void performAfterCommitTasks(final Object preProcessResult, final CompositeOperation operation,
			final IRevisionProvider revisionProvider, final IActionOperation[] dependsOn, final IWorkbenchPart part)
	{
		IRunnableWithProgress runnable= new IRunnableWithProgress() {

			@Override
			public void run(IProgressMonitor monitor) throws InvocationTargetException,
					InterruptedException {
				monitor.beginTask(UIText.DAS_COMMIT_PROCESS,100);
				internalPerformAfterCommitTasks(preProcessResult, operation, revisionProvider, dependsOn, part, monitor);
				monitor.done();
			}
		};

		try {
			ProgressMonitorDialog dialog= new ProgressMonitorDialog(part.getSite().getShell());
			dialog.run(false, false, runnable);
		} catch (Exception e) {
			e.printStackTrace();
			PluginLog.error("DBIO Commit process", e);
		}
	}

	private boolean isSkipCommitOperation()
	{
		if ( !DASConfigUtils.applyApproval() ) {
			log().info("Approval 처리를 Skip 합니다.");
		}

		if ( !DASConfigUtils.applyDependency() ) {
			log().info("Dependency 처리를 Skip 합니다.");
		}

		return ( !DASConfigUtils.applyApproval() && !DASConfigUtils.applyDependency() );
	}

	private IResource[] removeResource(IResource[] adds, IResource[] deletes)
	{
		List<IResource> results = new ArrayList<IResource>();

		for (IResource resource : deletes) {
			if ( !contain(adds, resource) ) {
				results.add(resource);
			}
		}

		return results.toArray(new IResource[results.size()]);
	}

	private boolean contain(IResource[] adds, IResource resource)
	{
		for (IResource r : adds) {
			if ( r.equals(resource) ) {
				log().debug("Replace Event : {}", r);
				return true;
			}
		}

		return false;
	}

	private void procApprovalMapper(IResource[] resources, boolean delete, String svnUserId)
	{
		for ( IResource resource : resources ) {

			try {
				if ( !getApprovalMapper().needProcess(resource) ) {
					continue;
				}

				if ( (Boolean) DBUtils.txInvoke(getConnection(), "preCommit", getApprovalMapper(), resource, delete, svnUserId) ) {
					throw new DASException(UIText.EMSG_APPROVAL_03);
				}

			} catch (DASException e) {
				getErrorList().put(resource, e);
			}
		}
	}

	private void procApprovalInterface(IResource[] resources, boolean delete)
	{
		for ( IResource resource : resources ) {

			try {
				if ( !getApprovalInterface().needProcess(resource) ) {
					continue;
				}

				getApprovalInterface().preCommit(resource, delete);
			} catch (DASException e) {
				getErrorList().put(resource, e);
			}
		}
	}

	private void procDependencyMapper(IResource[] resources, boolean delete, IProgressMonitor monitor)
	{
		log().debug(">> procDependencyMapper");
		for ( IResource resource : resources ) {
			new SubProgressMonitor(monitor, 1).subTask(UIText.DAS_CREATE_DEPENDENCY_META + ": " + resource.getFullPath().toString());

			try {
				if ( !DependenyAnalyzer.needProcess(resource) ) {
					continue;
				}

				DBUtils.txInvoke(getConnection(), "preCommit", getDependenyAnalyzer(), resource, delete);
			} catch (DASException e) {
				e.printStackTrace();
				PluginLog.error(
						MessageFormat.format(
								UIText.PROCESS_DEPENDENCY_DATA_ERROR
								, resource.toString()), e);

				getErrorList().put(resource, e);
			}
			monitor.worked(1);
		}
	}

	@Override
	public Object getErrorMessage()
	{
		if ( getErrorList().isEmpty() ) {
			return null;
		}

		final StringBuilder msg = new StringBuilder();

		for ( Entry<IResource, Throwable> item : getErrorList().entrySet()) {

			msg.append( item.getKey().getName() );
			msg.append(" : ");
			msg.append( item.getValue().getMessage() );
			msg.append("\n");
		}

		return msg.toString();
	}

	@Override
	public IResource[] getPreResourcesToCommit()
	{
		return null;
	}

	@Override
	public Object performPreProcess()
	{
		return new boolean[]{
			DASConfigUtils.applyApproval(),
			DASConfigUtils.applyDependency()
		};
	}

	@Override
	public Object performPostProcess()
	{
		return null;
	}

	@Override
	public int getPriority()
	{
		return PRIORITY_DAS;
	}

	public Map<IResource, Throwable> getErrorList()
	{
		if (errorList == null) 	this.errorList = new HashMap<IResource, Throwable>();
		return errorList;
	}

	private DependenyAnalyzer getDependenyAnalyzer() throws DASException
	{
		if ( dependenyAnalyzer == null ) {
			final DependencyDao dependencyDao = new DependencyDao( getConnection() );
			final String vendor = BXMUtils.getDbmsVendor(ConfigurationUtils.getFWConfigInfo().getConnectName());
					
			this.dependenyAnalyzer = new DependenyAnalyzer(dependencyDao, vendor);
		}

		return dependenyAnalyzer;
	}

	private ApprovalMapper getApprovalMapper() throws DASException
	{
		if ( approvalMapper == null ) {
			final ApprovalDao approvalDao = new ApprovalDao( getConnection() );
			this.approvalMapper = new ApprovalMapper(approvalDao);
			this.approvalInterface = new ApprovalInterface(approvalDao);
		}

		return approvalMapper;
	}

	private ApprovalInterface getApprovalInterface() throws DASException
	{
		if ( approvalInterface == null ) {
			final ApprovalDao approvalDao = new ApprovalDao( getConnection() );
			this.approvalMapper = new ApprovalMapper(approvalDao);
			this.approvalInterface = new ApprovalInterface(approvalDao);
		}

		return approvalInterface;
	}

	private Connection getConnection() throws DASException
	{
		if ( conn != null ) {
			return conn;
		}

		final String connectionName = ConfigurationUtils.getFWConfigInfo().getConnectName();
		if ( StringUtils.isEmpty(connectionName) ) {
			throw new DASException( UIText.EMSG_DB_02 );
		}

		final Connection connection = ConnectionManager.getConnection(connectionName);
		if ( connection == null ) {
			log().debug("Fail to Connect : name =  {}", connectionName);
//			throw new DASException( EMSG_DB_01 );
			throw new DASException( UIText.EMSG_SQL_03 );
		} else {
			this.conn = connection;
			return connection;
		}
	}
}
