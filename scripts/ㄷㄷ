import org.eclipse.core.resources.IResource;
import org.eclipse.team.svn.core.operation.CompositeOperation;
import org.eclipse.team.svn.core.operation.IActionOperation;
import org.eclipse.team.svn.core.operation.IRevisionProvider;
import org.eclipse.ui.IWorkbenchPart;


public interface IBxmCommitParticipant{
	
	public static final int PRIORITY_DAS = 10;
	public static final int PRIORITY_BUILDER  = 21;
	
	/**
	 * 
	 * @param preProcessResult <code>performPreProcess()</code>에서 수행된 결과를 전달.
	 * @param operation
	 * @param revisionProvider
	 * @param dependsOn
	 * @param part
	 */
	public void performAfterCommitTasks(
			final Object preProcessResult,
			final CompositeOperation operation,
			final IRevisionProvider revisionProvider, 
			final IActionOperation[] dependsOn,
			final IWorkbenchPart part
			);
	
	public Object getErrorMessage();
	
	public IResource[] getPreResourcesToCommit();
	
	/**
	 * 
	 * @return <code>performAfterCommitTasks</code>에 전달 될 결과.
	 */
	public Object performPreProcess();
	
	/**
	 * 
	 * @return
	 */
	public Object performPostProcess();
	
	
	/**
	 * DAS는 IBxmCommitParticipant.PRIORITY_DAS를 반환
	 * BUILDER는 IBxmCommitParticipant.PRIORITY_BUILDER를 반환하여 주시면 됩니다.
	 * @return
	 */
	public int getPriority();	
}
