	public static void main(String[] args) {
		String contents= "OMM bpr.nbp.bco.dbio.dto.DBcoEail000Dto <description=\"BCO_EAI로그\">";
		StringBuilder sb= new StringBuilder();
		boolean in= false;
		for( int i = 0; i < contents.length(); ++i){
			char c= contents.charAt(i);
			if ( c== '"'){
				if ( in ){
					break;
				}
				else{
					in= true;
					continue;
				}
			}

			if ( in ){
				sb.append(c);
			}
		}
		if ( logger.isTraceEnabled() ) logger.trace("[" + sb.toString() +"]");
	}

