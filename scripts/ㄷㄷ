@Creatable
public class ChatView
{

	private volatile boolean pendingRefresh=false;
	private static final int REFRESH_INTERVAL_MS=100;
	private String streamingMessageId=null;
	
    @Inject
    private UISynchronize        uiSync;

    @Inject
    private ILog                 logger;

    @Inject
    private ChatViewPresenter     presenter;

    @Inject
    private DropManager          dropManager;

    @Inject
    private AssistaiSharedImages sharedImages;

    @Inject
    private AssistaiSharedFiles  sharedFiles;

    @Inject
    private AssistaiSharedFonts sharedFonts;

    // Browser 대신 StyledText 사용
    private StyledText           chatArea;

    private Text                 inputArea;

    private ScrolledComposite    scrolledComposite;

    private Composite            imagesContainer;

    private ToolItem             modelDropdownItem;

    private ToolBar              actionToolBar;

    private Menu                 modelMenu;

    private Map<String, String>  autocompleteModel;

    private boolean              autoScrollEnabled = true;

    private int                  notificationIdCounter = 0;

    // 알림 표시용 Label
    private Label                notificationLabel;

    // 채팅 메시지 목록 (Browser.execute 대신 Java로 관리)
    private final List<ChatMessage> messages = new ArrayList<>();

    public enum NotificationType
    {
        INFO, WARNING, ERROR
    }

    /**
     * 채팅 메시지를 Java에서 관리하기 위한 내부 클래스
     */
    private static class ChatMessage
    {
        String  id;
        String  role;
        String  content;
        boolean hidden;

        ChatMessage( String id, String role )
        {
            this.id = id;
            this.role = role;
            this.content = "";
            this.hidden = false;
        }
    }

    public ChatView()
    {
        autocompleteModel = new LinkedHashMap<>();
    }

    public void setAutocompleteModel( Map<String, String> map )
    {
        autocompleteModel.clear();
        autocompleteModel.putAll( map );
    }

    @Focus
    public void setFocus()
    {
        inputArea.setFocus();
        presenter.onViewVisible();
    }

    public void clearChatView()
    {
        uiSync.asyncExec( () -> {
            messages.clear();
            refreshChatArea();
        } );
    }

    public void clearUserInput()
    {
        uiSync.asyncExec( () -> inputArea.setText( "" ) );
    }

    @PostConstruct
    public void createControls( Composite parent )
    {
        SashForm sashForm = new SashForm( parent, SWT.VERTICAL );
        sashForm.setLayoutData( new GridData( SWT.FILL, SWT.FILL, true, true ) );

        Composite chatContainer = new Composite( sashForm, SWT.NONE );
        chatContainer.setLayout( new GridLayout( 1, false ) );

        // 알림 레이블 (상단)
        notificationLabel = new Label( chatContainer, SWT.WRAP );
        notificationLabel.setLayoutData( new GridData( SWT.FILL, SWT.TOP, true, false ) );
        notificationLabel.setVisible( false );

        // StyledText 채팅 영역
        chatArea = createChatView( chatContainer );
        chatArea.setLayoutData( new GridData( SWT.FILL, SWT.FILL, true, true ) );

        // 채팅 영역 컨텍스트 메뉴 (코드복사 등 기존 BrowserFunction 대체)
        initializeChatAreaMenu( chatArea );

        Composite controls = new Composite( sashForm, SWT.NONE );
        GridLayout controlsLayout = new GridLayout( 1, false );
        controlsLayout.marginWidth = 5;
        controlsLayout.marginHeight = 5;
        controls.setLayout( controlsLayout );

        // 첨부파일 패널
        Composite attachmentsPanel = createAttachmentsPanel( controls );
        attachmentsPanel.setLayoutData( new GridData( SWT.FILL, SWT.FILL, true, false ) );

        // 입력 영역
        Composite inputContainer = new Composite( controls, SWT.NONE );
        GridLayout inputLayout = new GridLayout( 2, false );
        inputLayout.marginWidth = 0;
        inputLayout.marginHeight = 0;
        inputLayout.horizontalSpacing = 5;
        inputContainer.setLayout( inputLayout );
        inputContainer.setLayoutData( new GridData( SWT.FILL, SWT.FILL, true, true ) );

        inputArea = createUserInput( inputContainer );
        inputArea.setLayoutData( new GridData( SWT.FILL, SWT.FILL, true, true ) );
        setupAutocomplete( inputArea );

        // 버튼 바
        Composite buttonBar = new Composite( controls, SWT.NONE );
        GridLayout buttonBarLayout = new GridLayout( 2, false );
        buttonBarLayout.marginHeight = 0;
        buttonBarLayout.marginWidth = 0;
        buttonBar.setLayout( buttonBarLayout );
        buttonBar.setLayoutData( new GridData( SWT.FILL, SWT.CENTER, true, false ) );

        actionToolBar = new ToolBar( buttonBar, SWT.FLAT | SWT.RIGHT );
        actionToolBar.setLayoutData( new GridData( SWT.RIGHT, SWT.CENTER, true, false ) );

        modelDropdownItem = createModelSelectorComposite( actionToolBar );
        createAttachmentToolItem( actionToolBar );
        createReplayToolItem( actionToolBar );
        createClearChatToolItem( actionToolBar );
        createStopToolItem( actionToolBar );
        createSendToolItem( actionToolBar );

        sashForm.setWeights( new int[] { 70, 30 } );

        dropManager.registerDropTarget( controls );

        clearAttachments();
    }

    /**
     * StyledText 채팅 영역 생성
     */
    private StyledText createChatView( Composite parent )
    {
        StyledText styledText = new StyledText( parent,
                SWT.READ_ONLY | SWT.WRAP | SWT.V_SCROLL | SWT.BORDER );
        styledText.setEditable( false );
        styledText.setAlwaysShowScrollBars( false );

        Display display = parent.getDisplay();
        styledText.setBackground( display.getSystemColor( SWT.COLOR_WIDGET_BACKGROUND ) );
        styledText.setForeground( display.getSystemColor( SWT.COLOR_WIDGET_FOREGROUND ) );

        // 모노스페이스 폰트 적용
        try
        {
            org.eclipse.swt.graphics.Font monoFont = new org.eclipse.swt.graphics.Font(
                    display, new FontData( "Courier New", 10, SWT.NORMAL ) );
            styledText.setFont( monoFont );
            styledText.addDisposeListener( e -> monoFont.dispose() );
        }
        catch ( Exception e )
        {
            // 폰트 설정 실패 시 기본 폰트 사용
        }

        return styledText;
    }

    /**
     * 기존 BrowserFunction들을 컨텍스트 메뉴로 대체
     */
    private void initializeChatAreaMenu( StyledText styledText )
    {
        Menu menu = new Menu( styledText );
        styledText.setMenu( menu );

        menu.addMenuListener( new MenuAdapter()
        {
            @Override
            public void menuShown( MenuEvent e )
            {
                for ( MenuItem item : menu.getItems() )
                {
                    item.dispose();
                }

                boolean hasSelection = !styledText.getSelectionText().isEmpty();

                // 코드 복사 (기존 CopyCodeFunction)
                MenuItem copyItem = new MenuItem( menu, SWT.NONE );
                copyItem.setText( "코드 복사" );
                copyItem.setEnabled( hasSelection );
                copyItem.addListener( SWT.Selection, ev -> {
                    String selected = styledText.getSelectionText();
                    if ( !selected.isEmpty() )
                    {
                        presenter.onCopyCode( selected );
                    }
                } );

                // 패치 적용 (기존 ApplyPatchFunction)
                MenuItem patchItem = new MenuItem( menu, SWT.NONE );
                patchItem.setText( "패치 적용" );
                patchItem.setEnabled( hasSelection );
                patchItem.addListener( SWT.Selection, ev -> {
                    String selected = styledText.getSelectionText();
                    if ( !selected.isEmpty() )
                    {
                        presenter.onApplyPatch( selected );
                    }
                } );

                // 코드 삽입 (기존 InsertCodeFunction)
                MenuItem insertItem = new MenuItem( menu, SWT.NONE );
                insertItem.setText( "코드 삽입" );
                insertItem.setEnabled( hasSelection );
                insertItem.addListener( SWT.Selection, ev -> {
                    String selected = styledText.getSelectionText();
                    if ( !selected.isEmpty() )
                    {
                        presenter.onInsertCode( selected );
                    }
                } );

                // Diff 보기 (기존 DiffCodeFunction)
                MenuItem diffItem = new MenuItem( menu, SWT.NONE );
                diffItem.setText( "Diff 보기" );
                diffItem.setEnabled( hasSelection );
                diffItem.addListener( SWT.Selection, ev -> {
                    String selected = styledText.getSelectionText();
                    if ( !selected.isEmpty() )
                    {
                        presenter.onDiffCode( selected );
                    }
                } );

                new MenuItem( menu, SWT.SEPARATOR );

                // 전체 복사
                MenuItem copyAllItem = new MenuItem( menu, SWT.NONE );
                copyAllItem.setText( "전체 복사" );
                copyAllItem.addListener( SWT.Selection, ev -> {
                    Clipboard clipboard = new Clipboard( Display.getCurrent() );
                    clipboard.setContents(
                            new Object[] { styledText.getText() },
                            new org.eclipse.swt.dnd.Transfer[] { TextTransfer.getInstance() } );
                    clipboard.dispose();
                } );
            }
        } );
    }

    private void scheduleChatArea() {
    	if(!pendingRefresh) {
    		pendingRefresh = true;
    		Display.getCurrent().timerExec(REFRESH_INTERVAL_MS, () -> {
    			if(chatArea == null ||chatArea.isDisposed()) {
    				pendingRefresh = false;
    				return;
    			}
    			pendingRefresh=false;
    			refreshChatArea();
    		});
    	}
	}
    /**
     * 채팅 영역을 messages 목록 기준으로 다시 그림
     */
    private void refreshChatArea()
    {
        if ( chatArea == null || chatArea.isDisposed() )
        {
            return;
        }

        // 스크롤 위치 저장
        int topIndex = chatArea.getTopIndex();
        boolean wasAtBottom = isScrolledToBottom();

        StringBuilder sb = new StringBuilder();
        List<int[]> boldRanges = new ArrayList<>();

        for ( ChatMessage msg : messages )
        {
            if ( msg.hidden )
            {
                continue;
            }

            String header = "user".equals( msg.role )
                    ? "▶ 나\n"
                    : "▶ AI 어시스턴트\n";

            int headerStart = sb.length();
            sb.append( header );
            boldRanges.add( new int[] { headerStart, header.length() } );

            sb.append( msg.content.isEmpty() ? "(응답 대기 중...)" : msg.content );
            sb.append( "\n" );
            sb.append( "─".repeat( 60 ) );
            sb.append( "\n\n" );
        }

        String newText = sb.toString();

        // 텍스트가 실제로 변경된 경우만 갱신 (불필요한 redraw 방지)
        if ( newText.equals( chatArea.getText() ) )
        {
            return;
        }

        chatArea.setRedraw( false ); // 렌더링 일시 중단
        try
        {
            chatArea.setText( newText );

            // 스타일 적용
            List<StyleRange> styles = new ArrayList<>();
            for ( int[] range : boldRanges )
            {
                StyleRange style = new StyleRange();
                style.start = range[0];
                style.length = range[1];
                style.fontStyle = SWT.BOLD;
                styles.add( style );
            }
            chatArea.setStyleRanges( styles.toArray( new StyleRange[0] ) );
        }
        finally
        {
            chatArea.setRedraw( true ); // 렌더링 재개 (한번에 그림)
        }

        // 스크롤 복원
        if ( autoScrollEnabled || wasAtBottom )
        {
            chatArea.setTopIndex( chatArea.getLineCount() - 1 );
        }
        else
        {
            chatArea.setTopIndex( topIndex );
        }
    }

    /**
     * 스크롤이 맨 아래에 있는지 확인
     */
    private boolean isScrolledToBottom()
    {
        int lineCount = chatArea.getLineCount();
        int visibleLines = chatArea.getClientArea().height / chatArea.getLineHeight();
        int topIndex = chatArea.getTopIndex();
        return ( topIndex + visibleLines ) >= lineCount - 2;
    }

    public void appendMessage( String messageId, String role )
    {
        uiSync.asyncExec( () -> {
            boolean exists = messages.stream().anyMatch( m -> m.id.equals( messageId ) );
            if ( !exists )
            {
                messages.add( new ChatMessage( messageId, role ) );
                streamingMessageId = null; // 초기화
                refreshChatArea();
            }
        } );
    }
    public void setMessageHtml( String messageId, String messageBody )
    {
        uiSync.asyncExec( () -> {
            MarkdownParser parser = new MarkdownParser( messageBody );
            String html = parser.parseToHtml();
            String plainText = stripHtml( html );

            messages.stream()
                    .filter( m -> m.id.equals( messageId ) )
                    .findFirst()
                    .ifPresent( m -> {
                        m.content = plainText;
//                        refreshChatArea();
                        streamingMessageId = messageId;
                        scheduleChatArea();
                    } );
        } );
    }

	public void hideMessage( String messageId )
    {
        uiSync.asyncExec( () -> {
            messages.stream()
                    .filter( m -> m.id.equals( messageId ) )
                    .findFirst()
                    .ifPresent( m -> {
                        m.hidden = true;
                        refreshChatArea();
                    } );
        } );
    }

    public void removeMessage( String messageId )
    {
        uiSync.asyncExec( () -> {
            messages.removeIf( m -> m.id.equals( messageId ) );
            refreshChatArea();
        } );
    }

    /**
     * HTML 태그를 제거하고 일반 텍스트로 변환
     */
    private String stripHtml( String html )
    {
        if ( html == null )
        {
            return "";
        }
        // 코드 블록은 내용 보존
        String result = html
                .replaceAll( "<br\\s*/?>", "\n" )
                .replaceAll( "<p[^>]*>", "" )
                .replaceAll( "</p>", "\n" )
                .replaceAll( "<li[^>]*>", "  • " )
                .replaceAll( "</li>", "\n" )
                .replaceAll( "<h[1-6][^>]*>", "\n" )
                .replaceAll( "</h[1-6]>", "\n" )
                .replaceAll( "<pre[^>]*>", "\n" )
                .replaceAll( "</pre>", "\n" )
                .replaceAll( "<code[^>]*>", "" )
                .replaceAll( "</code>", "" )
                .replaceAll( "<[^>]+>", "" )
                .replace( "<", "<" )
                .replace( ">", ">" )
                .replace( "&", "&" )
                .replace( " ", " " )
                .replace( "'", "'" )
                .replace( """, "\"" )
                .replaceAll( "\n{3,}", "\n\n" ); // 연속 빈줄 정리
        return result.trim();
    }

    /**
     * 알림 표시 (기존 browser.execute("showNotification(...)") 대체)
     */
    public void showNotification( String message, Duration duration, NotificationType type )
    {
        uiSync.asyncExec( () -> {
            if ( notificationLabel == null || notificationLabel.isDisposed() )
            {
                return;
            }

            Display display = Display.getCurrent();
            switch ( type )
            {
                case INFO:
                    notificationLabel.setBackground( display.getSystemColor( SWT.COLOR_INFO_BACKGROUND ) );
                    notificationLabel.setForeground( display.getSystemColor( SWT.COLOR_INFO_FOREGROUND ) );
                    notificationLabel.setText( "[정보] " + message );
                    break;
                case WARNING:
                    notificationLabel.setBackground( new Color( display, 210, 153, 34 ) );
                    notificationLabel.setForeground( display.getSystemColor( SWT.COLOR_BLACK ) );
                    notificationLabel.setText( "[경고] " + message );
                    break;
                case ERROR:
                    notificationLabel.setBackground( display.getSystemColor( SWT.COLOR_RED ) );
                    notificationLabel.setForeground( display.getSystemColor( SWT.COLOR_WHITE ) );
                    notificationLabel.setText( "[오류] " + message );
                    break;
            }

            notificationLabel.setVisible( true );
            updateLayout( notificationLabel.getParent() );

            if ( duration.toMillis() > 0 )
            {
                display.timerExec( (int) duration.toMillis(), () -> {
                    if ( !notificationLabel.isDisposed() )
                    {
                        notificationLabel.setVisible( false );
                        notificationLabel.setText( "" );
                        updateLayout( notificationLabel.getParent() );
                    }
                } );
            }
        } );
    }

    // ─────────────────────────────────────────────────────────────────────────
    // 이하 기존 코드 (변경 없음)
    // ─────────────────────────────────────────────────────────────────────────

    public void setupAutocomplete( Text textField )
    {
        IContentProposalProvider proposalProvider = new IContentProposalProvider()
        {
            @Override
            public IContentProposal[] getProposals( String contents, int position )
            {
                if ( contents.startsWith( "/" ) )
                {
                    String prefix = contents.substring( 1 );
                    List<String> matchingCommands = autocompleteModel.keySet()
                                                                     .stream()
                                                                     .filter( s -> s.startsWith( prefix ) )
                                                                     .collect( Collectors.toList() );
                    return matchingCommands.stream()
                            .map( cmd -> new CommandContentProposal( cmd ) )
                            .toArray( IContentProposal[]::new );
                }
                return new IContentProposal[0];
            }
        };

        ContentProposalAdapter adapter = new ContentProposalAdapter(
                textField,
                new TextContentAdapter(),
                proposalProvider,
                null,
                null );

        adapter.setProposalAcceptanceStyle( ContentProposalAdapter.PROPOSAL_REPLACE );
        adapter.setPopupSize( new Point( 300, 200 ) );

        textField.addKeyListener( new KeyAdapter()
        {
            @Override
            public void keyPressed( KeyEvent e )
            {
                if ( e.keyCode == SWT.TAB && textField.getText().startsWith( "/" ) )
                {
                    adapter.openProposalPopup();
                    e.doit = false;
                }
            }
        } );

        textField.addVerifyListener( new VerifyListener()
        {
            @Override
            public void verifyText( VerifyEvent e )
            {
                if ( e.character == SWT.TAB && textField.getText().startsWith( "/" ) )
                {
                    e.doit = false;
                }
            }
        } );
    }

    class CommandContentProposal implements IContentProposal
    {
        private String command;

        public CommandContentProposal( String command )
        {
            this.command = command;
        }

        @Override
        public String getContent()
        {
            return "/" + command;
        }

        @Override
        public int getCursorPosition()
        {
            return getContent().length();
        }

        @Override
        public String getLabel()
        {
            return "/" + command;
        }

        @Override
        public String getDescription()
        {
            return autocompleteModel.get( command );
        }
    }

    private Composite createAttachmentsPanel( Composite parent )
    {
        Composite attachmentsPanel = new Composite( parent, SWT.NONE );
        attachmentsPanel.setLayout( new GridLayout( 1, false ) );

        scrolledComposite = new ScrolledComposite( attachmentsPanel, SWT.H_SCROLL | SWT.V_SCROLL );
        GridData scrolledData = new GridData( SWT.FILL, SWT.FILL, true, false );
        scrolledData.heightHint = 0;
        scrolledComposite.setLayoutData( scrolledData );
        scrolledComposite.setExpandHorizontal( true );
        scrolledComposite.setExpandVertical( true );

        imagesContainer = new Composite( scrolledComposite, SWT.NONE );
        RowLayout rowLayout = new RowLayout( SWT.HORIZONTAL );
        rowLayout.spacing = 8;
        rowLayout.marginTop = 4;
        rowLayout.marginBottom = 4;
        rowLayout.marginLeft = 4;
        rowLayout.marginRight = 4;
        rowLayout.wrap = true;
        imagesContainer.setLayout( rowLayout );

        scrolledComposite.setContent( imagesContainer );
        scrolledComposite.setMinSize( imagesContainer.computeSize( SWT.DEFAULT, SWT.DEFAULT ) );

        imagesContainer.addKeyListener( new KeyAdapter()
        {
            @Override
            public void keyPressed( KeyEvent e )
            {
                if ( e.keyCode == SWT.DEL || e.keyCode == SWT.BS )
                {
                    java.util.List<Integer> selectedIndices = new java.util.ArrayList<>();
                    for ( var child : imagesContainer.getChildren() )
                    {
                        if ( child instanceof Label )
                        {
                            Boolean selected = (Boolean) child.getData( "selected" );
                            if ( selected != null && selected )
                            {
                                Integer index = (Integer) child.getData( "attachmentIndex" );
                                if ( index != null )
                                {
                                    selectedIndices.add( index );
                                }
                            }
                        }
                    }
                    selectedIndices.sort( java.util.Collections.reverseOrder() );
                    for ( int index : selectedIndices )
                    {
                        presenter.onRemoveAttachment( index );
                    }
                }
            }
        } );

        return attachmentsPanel;
    }

    private ToolItem createAttachmentToolItem( ToolBar toolbar )
    {
        ToolItem item = new ToolItem( toolbar, SWT.PUSH );
        try
        {
            Image attachIcon = PlatformUI.getWorkbench().getSharedImages().getImage( ISharedImages.IMG_OBJ_ADD );
            item.setImage( attachIcon );
        }
        catch ( Exception e )
        {
            logger.error( e.getMessage(), e );
        }
        item.setToolTipText( "Add image attachment" );
        item.addSelectionListener( new SelectionAdapter()
        {
            @Override
            public void widgetSelected( SelectionEvent e )
            {
                presenter.onAddAttachment();
            }
        } );
        return item;
    }

    private ToolItem createSendToolItem( ToolBar toolbar )
    {
        ToolItem item = new ToolItem( toolbar, SWT.PUSH );
        try
        {
            Image sendIcon = PlatformUI.getWorkbench().getSharedImages().getImage( ISharedImages.IMG_TOOL_FORWARD );
            item.setImage( sendIcon );
        }
        catch ( Exception e )
        {
            logger.error( e.getMessage(), e );
        }
        item.setToolTipText( "Send message (Ctrl+Enter)" );
        item.addSelectionListener( new SelectionAdapter()
        {
            @Override
            public void widgetSelected( SelectionEvent e )
            {
                String text = inputArea.getText().trim();
                if ( !text.isEmpty() )
                {
                    presenter.onSendUserMessage( text );
                }
            }
        } );
        return item;
    }

    private ToolItem createReplayToolItem( ToolBar toolbar )
