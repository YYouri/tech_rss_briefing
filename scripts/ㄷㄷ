                        </property> 
                </properties> 
        
                <example>  
                        <![CDATA[
/* 잘못된 예 */
public void bar() {
        try {
                // do something
        }  catch (NullPointerException npe) {
        }
}
 
/* 올바른 예 */
public void bar() {
        // do something
}
 
                        ]]> 
                </example> 
        </rule> 
        
        <rule name="AvoidThrowingNullPointerException"
        		language="java"
                since="1.8"
                message="NullPointerException을 throw 함"
                class="net.sourceforge.pmd.lang.rule.XPathRule"
                externalInfoUrl="http://developer.cis.co.kr/support/pmd/AvoidThrowingNullPointerException.html"> 
        
                <description> 
NullPointerException을 throw 하는지 확인합니다.
NullPointerException은 대부분 VM 상에서 발생하기 때문에 혼동될 수 있습니다.
NullPointerException 대신 IllegalArgumentException 을 사용하는 것을 권장합니다.
                </description> 
        
                <priority>5</priority> 
        
                <properties> 
                        <property name="xpath"> 
                                <value> 
                                        <![CDATA[
                                                //AllocationExpression/ClassOrInterfaceType[@Image='NullPointerException']
                                        ]]> 
                                </value> 
                        </property> 
                </properties> 
                <example> 
                        <![CDATA[
/* 잘못된 예 */
public class Foo {
        void bar() throws Exception {
                try {
                        // do something..
                } catch(NullPointerException e) {
                        throw e;
                }
        }
}
 
/* 올바른 예 */
public class Foo {
        void bar() throws IllegalArgumentException {
                try {
                        // do something..
                } catch(NullPointerException e) {
                        throw new IllegalArgumentException(e.getMessage());
                }
        }
}
                        ]]> 
                </example> 
        </rule> 
        
