	at jef.foundation.logging.helper.E2ELoggerHelper.appendEvent(E2ELoggerHelper.java:41)


	public static void appendEvent(String fqnOfCategoryClass, String loggerName, int intLevel, Object message, Throwable throwable) {
		Log4jLogEvent.Builder builder = Log4jLogEvent.newBuilder().setLoggerName(loggerName).setLoggerFqcn(fqnOfCategoryClass).setLevel(toLevel(intLevel));
		
		LogEvent event = null;
		if( message instanceof TracingVO ) {
			builder = builder.setMessage(new E2ETracingVOMessage(message));
		} else {
			builder = builder.setMessage(new SimpleMessage((String)message));
		}
		event = builder.setThrown(throwable).build();
		
		LoggerContext ctx = (LoggerContext) LogManager.getContext(false);
		Map<String, LoggerConfig> loggers = ctx.getConfiguration().getLoggers();
		LoggerConfig loggerConfig2 = loggers.get(loggerName);
		if( loggerConfig2 == null ) {
			loggerConfig2 = loggers.get(""); // root
		}
		Collection<Appender> values = loggerConfig2.getAppenders().values();
		for (Appender appender : values) {
//			appender.append(event);
			appender.append(Log4jLogEvent.createMemento(event));
		}
	}
	