	protected void updateStatus(){

		INewProjectProvider[] providers= BuilderCustomizationManager.instance().getNewProjectProviders();

		Set<PackageSet> packages= new LinkedHashSet<PackageSet>();

		for (INewProjectProvider provider : providers) {
			PackageSet[] pss= provider.getDefaultPackageSet(getProjectCode());
			for (PackageSet ps : pss) {
				packages.add(ps);
			}
		}

		defaultPackageSet= packages.toArray( new PackageSet[packages.size()]);

		if ( packagePreviewTableViewer != null ){
			packagePreviewTableViewer.setInput(defaultPackageSet);
		}

		boolean isPageComplete= isPageComplete();
		String message= getMessage();
		String errorMessage= getErrorMessage();

		System.out.println(">> message : " + message);
		System.out.println(">> errorMessage : " + errorMessage);
		boolean packageValid= true;

		if ( BuilderActivator.getDefault().getConfiguration().isNewProjectUsePackagePreview() ){
			for (PackageSet pkg : packages) {
				System.out.println(">> pkg : " + pkg.getPackageName());
				IStatus status= JavaConventions.validatePackageName(pkg.getPackageName(), "1.3", "1.3");
				if ( !status.isOK() ){
					setErrorMessage(status.getMessage());
					packageValid= false;
					break;
				}
			}
		}
		if ( !packageValid ){
			setPageComplete(packageValid);
		}
		else{
			setPageComplete(isPageComplete);
			setMessage(message);
			setErrorMessage(errorMessage);
		}
	}