package hi.bxm.assist.ui.presenter;

import hi.bxm.assist.core.gateway.AiRequestGateway;
import hi.bxm.assist.core.llm.CancelToken;
import hi.bxm.assist.core.llm.PromptBuilder;
import hi.bxm.assist.core.model.ChatMessage;
import hi.bxm.assist.core.model.ChatMessage.Role;
import hi.bxm.assist.core.model.EditorContext;
import hi.bxm.assist.editor.context.ContextCollector;
import hi.bxm.assist.ui.view.ChatView;

import org.eclipse.swt.widgets.Display;
import org.eclipse.ui.IEditorPart;
import org.eclipse.ui.IWorkbench;
import org.eclipse.ui.IWorkbenchPage;
import org.eclipse.ui.IWorkbenchWindow;
import org.eclipse.ui.PlatformUI;

import java.util.ArrayList;
import java.util.List;

/**
 * BXM AI Assist Chat Presenter (MVP).
 *
 * [변경사항]
 * - OpenAIClient 직접 취득 제거 → AiRequestGateway.submitChat() 경유
 * - cancelCurrent() 에서 AiRequestGateway.getInstance().reset() 호출
 * - CancelToken 을 AiRequestGateway 에 전달하는 방식으로 변경
 * - AsyncRunner 직접 사용 제거 (Gateway 가 내부적으로 처리)
 *
 * [유지된 로직]
 * - history 관리 (buildHistorySummary, trimHistory)
 * - EditorContext 수집 (UI Thread에서 수집 후 Gateway 에 전달)
 * - friendlyError 메시지 변환은 Gateway 담당으로 이전
 *
 * [상태바]
 * - Eclipse 하단 상태바: AiRequestGateway 가 "● AI 요청 중..." / "✓ AI 완료" 처리
 * - 뷰 내부 statusLabel: ChatView.setInputEnabled() 가 "준비" / "AI 응답 대기 중..." 처리
 *
 * [JDK 7 호환] 람다 미사용, 익명 클래스 사용.
 */
public class ChatPresenter {

    private static final int MAX_HISTORY       = 10;
    private static final int MAX_HISTORY_CHARS = 3000;

    private final ChatView          view;
    private final PromptBuilder     promptBuilder = new PromptBuilder();
    private final List<ChatMessage> history       = new ArrayList<ChatMessage>();

    /** 현재 진행 중인 요청의 취소 토큰 */
    private CancelToken currentToken = null;

    public ChatPresenter(ChatView view) {
        this.view = view;
    }

    /**
     * 사용자 메시지 전송.
     * UI Thread 에서 호출됩니다 (ChatView.onSend()).
     *
     * @param userText  사용자 입력 텍스트
     * @param attachCtx true 이면 활성 에디터 컨텍스트를 프롬프트에 포함
     */
    public void onUserMessage(final String userText, final boolean attachCtx) {
        // 이전 요청이 있으면 취소
        if (currentToken != null) {
            currentToken.cancel();
        }
        currentToken = new CancelToken();
        final CancelToken token = currentToken;

        // 사용자 메시지 히스토리 추가 + 화면 표시
        history.add(new ChatMessage(Role.USER, userText));
        Display.getDefault().asyncExec(new Runnable() {
            @Override public void run() {
            	view.appendMessage(Role.USER, userText);
            	view.setInputEnabled(false);
            }
        });
        
        
        // UI Thread 에서 에디터 컨텍스트 수집
        final EditorContext ctx = attachCtx ? collectActiveEditorContext() : null;

        // 히스토리 스냅샷 (백그라운드 스레드 접근 방지)
        final List<ChatMessage> historySnapshot = new ArrayList<ChatMessage>(history);

        // 프롬프트 조립
        final List<ChatMessage> msgs =
                promptBuilder.forChat(historySnapshot, userText, ctx);

        // Gateway 경유 비동기 요청
        AiRequestGateway.getInstance().submitChat(
                msgs, 0.7, 1024, token,
                new AiRequestGateway.ChatCallback() {
                    @Override
                    public void onSuccess(final String result) {
                        if (token.isCancelled()) return;
                        final String text = (result != null) ? result : "";
                        history.add(new ChatMessage(Role.ASSISTANT, text));
                        trimHistory();

                        Display.getDefault().asyncExec(new Runnable() {
                            @Override public void run() {
                                view.appendMessage(Role.ASSISTANT, text);
                                view.setInputEnabled(true);
                            }
                        });
                    }

                    @Override
                    public void onFailure(final String errorMessage) {
                        if (token.isCancelled()) return;
                        Display.getDefault().asyncExec(new Runnable() {
                            @Override public void run() {
                                view.showError(errorMessage);
                                view.setInputEnabled(true);
                            }
                        });
                    }
                });
    }

    /**
     * 현재 진행 중인 요청 취소.
     * AiRequestGateway.reset() 을 호출해 상태바도 함께 정리합니다.
     */
    public void cancelCurrent() {
        if (currentToken != null) {
            currentToken.cancel();
            currentToken = null;
        }
        AiRequestGateway.getInstance().reset();
        view.setInputEnabled(true);
        view.setStatus("요청이 취소되었습니다.");
    }

    /** 대화 히스토리 전체 삭제 */
    public void clearHistory() {
        history.clear();
    }

    // ═══════════════════════════════════════════════════════════════
    // 내부 구현
    // ═══════════════════════════════════════════════════════════════

    /** 히스토리 크기 제한 (MAX_HISTORY * 2 초과 시 오래된 것부터 제거) */
    private void trimHistory() {
        while (history.size() > MAX_HISTORY * 2) {
            history.remove(0);
        }
    }

    /**
     * 현재 활성 에디터에서 EditorContext 수집.
     * UI Thread 에서만 호출해야 합니다.
     */
    private EditorContext collectActiveEditorContext() {
        try {
            IWorkbench wb = PlatformUI.getWorkbench();
            if (wb == null) return null;
            IWorkbenchWindow win = wb.getActiveWorkbenchWindow();
            if (win == null) return null;
            IWorkbenchPage page = win.getActivePage();
            if (page == null) return null;
            IEditorPart editor = page.getActiveEditor();
            if (editor == null) return null;
            return ContextCollector.fromEditor(editor);
        } catch (Exception e) {
            return null;
        }
    }
}
