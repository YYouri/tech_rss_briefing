<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>

  <!-- 1. 커맨드 -->
  <extension point="org.eclipse.ui.commands">
    <category id="hi.bxm.assist.category" name="BXM Assist"/>
    <command id="hi.bxm.assist.openChat"
             name="AI Assist 열기"
             categoryId="hi.bxm.assist.category"/>
    <command id="hi.bxm.assist.explainCode"
             name="AI: 코드 설명"
             categoryId="hi.bxm.assist.category"/>
    <command id="hi.bxm.assist.fixError"
             name="AI: 에러 수정 제안"
             categoryId="hi.bxm.assist.category"/>
    <command id="hi.bxm.assist.refactor"
             name="AI: 리팩토링 제안"
             categoryId="hi.bxm.assist.category"/>
    <command id="hi.bxm.assist.triggerInline"
             name="AI: 인라인 자동완성 트리거"
             categoryId="hi.bxm.assist.category"/>
    <!-- [신규] TODO 코드 생성 -->
    <command id="hi.bxm.assist.generateTodo"
             name="AI: TODO 코드 생성"
             categoryId="hi.bxm.assist.category"/>
  </extension>

  <!-- 2. 핸들러 -->
  <extension point="org.eclipse.ui.handlers">
    <handler commandId="hi.bxm.assist.openChat"
             class="hi.bxm.assist.ui.handler.SendMessageHandler"/>
    <handler commandId="hi.bxm.assist.explainCode"
             class="hi.bxm.assist.editor.command.ExplainCodeHandler">
      <activeWhen>
        <with variable="activeEditorId">
          <equals value="org.eclipse.jdt.ui.CompilationUnitEditor"/>
        </with>
      </activeWhen>
    </handler>
    <handler commandId="hi.bxm.assist.fixError"
             class="hi.bxm.assist.editor.command.FixErrorHandler">
      <activeWhen>
        <with variable="activeEditorId">
          <equals value="org.eclipse.jdt.ui.CompilationUnitEditor"/>
        </with>
      </activeWhen>
    </handler>
    <handler commandId="hi.bxm.assist.refactor"
             class="hi.bxm.assist.editor.command.RefactorHandler">
      <activeWhen>
        <with variable="activeEditorId">
          <equals value="org.eclipse.jdt.ui.CompilationUnitEditor"/>
        </with>
      </activeWhen>
    </handler>
    <handler commandId="hi.bxm.assist.triggerInline"
             class="hi.bxm.assist.editor.ghost.TriggerInlineHandler">
      <activeWhen>
        <with variable="activeEditorId">
          <equals value="org.eclipse.jdt.ui.CompilationUnitEditor"/>
        </with>
      </activeWhen>
    </handler>
    <!-- [신규] TODO 코드 생성 핸들러 -->
    <handler commandId="hi.bxm.assist.generateTodo"
             class="hi.bxm.assist.editor.command.TodoCommentHandler">
      <activeWhen>
        <with variable="activeEditorId">
          <equals value="org.eclipse.jdt.ui.CompilationUnitEditor"/>
        </with>
      </activeWhen>
    </handler>
  </extension>

  <!-- 3. View -->
  <extension point="org.eclipse.ui.views">
    <view id="hi.bxm.assist.ui.ChatView"
          name="BXM Assist"
          class="hi.bxm.assist.ui.view.ChatView"
 		  icon="icons/assist_ai_16.png"
          allowMultiple="false"/>
  </extension>

  <!-- 4. 메뉴 / 툴바 -->
  <extension point="org.eclipse.ui.menus">
    <menuContribution
        locationURI="popup:org.eclipse.jdt.ui.source.menu?after=additions">
      <menu id="hi.bxm.assist.editorMenu" icon="icons/assist_ai_16.png" label="BXM Assist">
        <command commandId="hi.bxm.assist.explainCode"   label="코드 설명"/>
        <command commandId="hi.bxm.assist.fixError"      label="에러 수정 제안"/>
        <command commandId="hi.bxm.assist.refactor"      label="리팩토링 제안"/>
        <command commandId="hi.bxm.assist.generateTodo"  label="TODO 코드 생성"/>
        <command commandId="hi.bxm.assist.triggerInline" label="인라인 제안 트리거"/>
      </menu>
    </menuContribution>
    <menuContribution
        locationURI="popup:org.eclipse.ui.popup.any?after=additions">
      <menu id="hi.bxm.assist.editorMenu2" icon="icons/assist_ai_16.png" label="BXM Assist">
        <visibleWhen checkEnabled="false">
          <with variable="activeEditorId">
            <equals value="org.eclipse.jdt.ui.CompilationUnitEditor"/>
          </with>
        </visibleWhen>
        <command commandId="hi.bxm.assist.explainCode"   label="코드 설명"/>
        <command commandId="hi.bxm.assist.fixError"      label="에러 수정 제안"/>
        <command commandId="hi.bxm.assist.refactor"      label="리팩토링 제안"/>
        <command commandId="hi.bxm.assist.generateTodo"  label="TODO 코드 생성"/>
        <command commandId="hi.bxm.assist.triggerInline" label="인라인 제안 트리거"/>
      </menu>
    </menuContribution>
    <menuContribution locationURI="menu:org.eclipse.ui.main.menu?after=help">
      <menu id="hi.bxm.assist.mainMenu" icon="icons/assist_ai_16.png" label="BXM Assist">
        <command commandId="hi.bxm.assist.openChat"      label="AI Assist 열기"/>
        <separator name="sep1"/>
        <command commandId="hi.bxm.assist.explainCode"   label="코드 설명"/>
        <command commandId="hi.bxm.assist.fixError"      label="에러 수정 제안"/>
        <command commandId="hi.bxm.assist.refactor"      label="리팩토링 제안"/>
