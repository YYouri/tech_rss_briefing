import org.eclipse.swt.layout.GridLayout;
import org.eclipse.swt.widgets.Composite;
import org.eclipse.swt.widgets.Text;
import org.eclipse.ui.PlatformUI;

import bxm.code.inspection.ui.naming.validator.IResourceNameValidator;
import bxm.code.inspection.ui.naming.validator.manager.ResourceNameValidatorManager;
