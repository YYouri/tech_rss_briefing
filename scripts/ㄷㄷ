package hi.bxm.assist.editor.context;

import hi.bxm.assist.core.model.EditorContext;

import org.eclipse.jdt.core.ICompilationUnit;
import org.eclipse.jdt.core.IImportDeclaration;
import org.eclipse.jdt.core.IJavaElement;
import org.eclipse.jdt.core.IMethod;
import org.eclipse.jdt.core.IPackageDeclaration;
import org.eclipse.jdt.core.IType;
import org.eclipse.jdt.core.JavaModelException;
import org.eclipse.jdt.core.Signature;
import org.eclipse.jdt.ui.JavaUI;
import org.eclipse.jface.text.IDocument;
import org.eclipse.jface.text.ITextSelection;
import org.eclipse.ui.IEditorInput;
import org.eclipse.ui.IEditorPart;
import org.eclipse.ui.texteditor.IDocumentProvider;
import org.eclipse.ui.texteditor.ITextEditor;

import java.util.ArrayList;
import java.util.List;

/**
 * 활성 에디터 / 문서로부터 LLM 컨텍스트를 수집한다.
 *
 * 수집 항목:
 *  - 파일명, 패키지명
 *  - import 선언 (qualified name 만)
 *  - 같은 컴파일 유닛 내 메서드 시그니처 (인접 심볼)
 *  - 캐럿 오프셋, 선택 영역
 *  - 전체 소스 (FIM 용)
 *
 * JDT 가 없거나 (.txt 등) 실패하면 부분 컨텍스트만 채움.
 */
public final class ContextCollector {

    private static final int MAX_IMPORTS = 50;
    private static final int MAX_NEIGHBORS = 30;

    private ContextCollector() {}

    public static EditorContext fromEditor(IEditorPart editor) {
        EditorContext.Builder b = EditorContext.builder();
        if (editor == null) return b.build();

        IEditorInput input = editor.getEditorInput();
        if (input != null) b.fileName(input.getName());

        // 문서 / 캐럿
        if (editor instanceof ITextEditor) {
            ITextEditor te = (ITextEditor) editor;
            IDocumentProvider dp = te.getDocumentProvider();
            if (dp != null) {
                IDocument doc = dp.getDocument(input);
                if (doc != null) {
                    b.fullSource(doc.get());
                    Object sel = te.getSelectionProvider() != null
                            ? te.getSelectionProvider().getSelection() : null;
                    if (sel instanceof ITextSelection) {
                        ITextSelection ts = (ITextSelection) sel;
                        b.cursorOffset(ts.getOffset() + ts.getLength());
                        if (ts.getLength() > 0) b.selection(ts.getText());
                    }
                }
            }
        }

        // JDT 메타정보
        try {
            IJavaElement je = input != null ? JavaUI.getEditorInputJavaElement(input) : null;
            if (je instanceof ICompilationUnit) {
                collectFromCompilationUnit((ICompilationUnit) je, b);
            }
        } catch (Throwable t) {
            // JDT 미존재/오픈 안된 파일이면 무시
        }
        return b.build();
    }

    private static void collectFromCompilationUnit(ICompilationUnit cu, EditorContext.Builder b)
            throws JavaModelException {
        IPackageDeclaration[] pkgs = cu.getPackageDeclarations();
        if (pkgs != null && pkgs.length > 0) {
            b.packageName(pkgs[0].getElementName());
        }
        IImportDeclaration[] imports = cu.getImports();
        if (imports != null && imports.length > 0) {
            List<String> list = new ArrayList<String>();
            int limit = Math.min(imports.length, MAX_IMPORTS);
            for (int i = 0; i < limit; i++) list.add(imports[i].getElementName());
            b.imports(list);
        }
        IType[] types = cu.getTypes();
        if (types != null) {
            List<String> sigs = new ArrayList<String>();
            for (IType t : types) {
                collectMethodSigs(t, sigs);
                if (sigs.size() >= MAX_NEIGHBORS) break;
            }
            b.neighborSignatures(sigs);
        }
    }

    private static void collectMethodSigs(IType type, List<String> out) throws JavaModelException {
        for (IMethod m : type.getMethods()) {
            if (out.size() >= MAX_NEIGHBORS) return;
            StringBuilder sb = new StringBuilder();
            sb.append(Signature.toString(m.getReturnType())).append(' ');
            sb.append(m.getElementName()).append('(');
            String[] paramTypes = m.getParameterTypes();
            String[] paramNames = m.getParameterNames();
            for (int i = 0; i < paramTypes.length; i++) {
                if (i > 0) sb.append(", ");
                sb.append(Signature.toString(paramTypes[i]));
                if (paramNames != null && i < paramNames.length) {
                    sb.append(' ').append(paramNames[i]);
                }
            }
            sb.append(')');
            out.add(sb.toString());
        }
        for (IType inner : type.getTypes()) {
            if (out.size() >= MAX_NEIGHBORS) return;
            collectMethodSigs(inner, out);
        }
    }

    /**
     * 인라인 자동완성용 prefix/suffix 자르기.
     * 큰 파일에서 LLM 컨텍스트 윈도우를 보호하기 위해 캐럿 주변 N 글자만 잘라낸다.
     */
    public static String[] sliceForFim(String fullSource, int cursorOffset,
                                       int maxPrefix, int maxSuffix) {
        if (fullSource == null) return new String[]{"", ""};
        int len = fullSource.length();
        if (cursorOffset < 0) cursorOffset = 0;
        if (cursorOffset > len) cursorOffset = len;
        int pStart = Math.max(0, cursorOffset - maxPrefix);
        int sEnd = Math.min(len, cursorOffset + maxSuffix);
        String prefix = fullSource.substring(pStart, cursorOffset);
        String suffix = fullSource.substring(cursorOffset, sEnd);
        return new String[]{prefix, suffix};
    }

    public static IJavaElement getJavaElement(IEditorInput input) {
        try { return JavaUI.getEditorInputJavaElement(input); }
        catch (Throwable t) { return null; }
    }
}
