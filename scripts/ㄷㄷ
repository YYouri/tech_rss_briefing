/**
 * @file			bxm.builder.wizards.NewServiceClassWizardPage.java
 * @filetype		java source file
 * @brief
 * @author			ShinChangYoung
 * @version			1.0
 * @history
 * 성		명			일		자				근  거  자  료					변  경  내  용
 * ----------------		-------------------		-------------------		--------------------------
 * ShinChangYoung		2012. 1. 30.			product 개발				신규 작성
 *
 */
public class NewMainServiceClassWizardPage extends NewHdsTypeWizardPage {
	final Logger logger = LoggerFactory.getLogger(this.getClass());

	private final static String PAGE_NAME = "NewMainServiceClassWizardPage";
	private final static String SETTINGS_CREATEMAIN= "create_main";
	private final static String SETTINGS_CREATECONSTR= "create_constructor";
	private final static String SETTINGS_CREATEUNIMPLEMENTED= "create_unimplemented";

	class OperationViewerLabelProvider extends BaseLabelProvider
	implements ITableLabelProvider
	{
		@Override
		public Image getColumnImage(Object obj, int i) {
			return null;
		}

		@Override
		public String getColumnText(Object obj, int i) {
			if ( obj instanceof ServiceOperationSet ){
				ServiceOperationSet sos= (ServiceOperationSet)obj;
				switch (i) {
				case 0: return sos.getOperationName();
				case 1: return sos.getMethodName();
				case 2: return sos.getInputOmm();
				case 3: return sos.getOutputOmm();
				default:
					return "";
				}
			}
			else{
				return "";
			}
		}
	}

	class OperationViewer extends AbstractTableViewer{

		public OperationViewer(Composite parent, int style) {
			super(parent, style);

			createColumn(UIText.OPERATION, 80);
			createColumn(UIText.METHOD, 80);
			createColumn(UIText.INPUT, 250);
			createColumn(UIText.OUTPUT, 250);

			setHeaderVisible(true);
			setLineVisible(true);
		}
	}

	private OperationViewer operationViewer= null;

	private ServiceOperationSet[] serviceOperationSetList= null;

	private boolean createInputOmmWhenNoExist= false;
	private boolean createOutputOmmWhenNoExist= false;
	private boolean applyLogicalNameToOperation= true;
	private boolean applyLogicalNameToIO= true;

	private SelectionButtonDialogFieldGroup fMethodStubsButtons;

	public NewMainServiceClassWizardPage() {
		super(true, PAGE_NAME);

		setTitle(BuilderMessages.NEW_SERVICE_WIZARD_PAGE_1_TITLE);
		setDescription(BuilderMessages.NEW_SERVICE_WIZARD_PAGE_1_DESC);

		String[] buttonNames3= new String[] {
			NewWizardMessages.NewClassWizardPage_methods_main, NewWizardMessages.NewClassWizardPage_methods_constructors,
			NewWizardMessages.NewClassWizardPage_methods_inherited
		};
		fMethodStubsButtons= new SelectionButtonDialogFieldGroup(SWT.CHECK, buttonNames3, 1);
		fMethodStubsButtons.setLabelText(NewWizardMessages.NewClassWizardPage_methods_label);
	}

	public void init(IStructuredSelection selection) {

		IJavaElement jelem= getInitialJavaElement(selection);

		if ( jelem== null ){
			Object object= selection.getFirstElement();

			if ( object instanceof IFile ){
				IFile file= (IFile)object;
				jelem= JavaCore.create(file);
			}
		}
		else{
		}
		initContainerPage(jelem);
		initTypePage(jelem);
		doStatus_Update();

		boolean createMain= false;
		boolean createConstructors= false;
		boolean createUnimplemented= true;
		IDialogSettings dialogSettings= getDialogSettings();
		if (dialogSettings != null) {
			IDialogSettings section= dialogSettings.getSection(PAGE_NAME);
			if (section != null) {
				createMain= section.getBoolean(SETTINGS_CREATEMAIN);
				createConstructors= section.getBoolean(SETTINGS_CREATECONSTR);
				createUnimplemented= section.getBoolean(SETTINGS_CREATEUNIMPLEMENTED);
			}
		}

		setMethodStubSelection(createMain, createConstructors, createUnimplemented, true);
	}

	private void doStatus_Update() {
		// status of all used components
		IStatus[] status= null;

		if ( WizardOptions.instance().isBeanNewWizardLogicalNameEnabled())
		{
			status= new IStatus[] {
					fContainerStatus,
					isEnclosingTypeSelected() ? fEnclosingTypeStatus : fPackageStatus,
					fTypeNameStatus,
					fServiceNameStatus,
					fModifierStatus,
					fSuperClassStatus,
					fSuperInterfacesStatus,
					fLogicalNameStatus,
					fDescriptionStatus
				};
		}
		else{
			status= new IStatus[] {
					fContainerStatus,
					isEnclosingTypeSelected() ? fEnclosingTypeStatus : fPackageStatus,
					fTypeNameStatus,
					fServiceNameStatus,
					fModifierStatus,
					fSuperClassStatus,
					fSuperInterfacesStatus
				};
		}

		// the mode severe status will be displayed and the OK button enabled/disabled.
		updateStatus(status);
	}

	@Override
	protected void handleFieldChanged(String fieldName) {
		super.handleFieldChanged(fieldName);

		if ("NewContainerWizardPage.container".equals(fieldName)){
			IJavaProject javaProject= getJavaProject();

			if ( javaProject != null ){
				String packageName= ResourceNamingProviderManager.instance().getPackageName(ResourceType.SERVICE, javaProject.getProject(), "", "");

				if ( !StringUtils.isEmpty(packageName) ){
					IPackageFragment pf=getPackageFragmentRoot().getPackageFragment(packageName);
					setPackageFragment(pf, true);
					setFocus();
				}
			}
		}

		doStatus_Update();
	}

	@Override
	public void createControl(Composite parent) {
		logger.trace("NewServiceClassWizardPage.createControl");
		initializeDialogUnits(parent);

		Composite composite= new Composite(parent, SWT.NONE);
		composite.setFont(parent.getFont());

		int columns= 4;

		composite.setLayout(new GridLayout(columns, false));

		// pick & choose the wanted UI components

		createContainerControls(composite, columns);
		createPackageControls(composite, columns);
//		createEnclosingTypeControls(composite, nColumns);
		createSeparator(composite, columns);

		createTypeNameControls(composite, columns);
		createServiceNameControls(composite, columns);

		// 2012.11.21 PARK.Jeongyeob [[
		if ( WizardOptions.instance().isBeanNewWizardLogicalNameEnabled())
		{
			createSeparator(composite, columns);
			createLogicalNameControls(composite, columns);
			createDescriptionControls(composite, columns);
		}
		// 2012.11.21 PARK.Jeongyeob [[

		createSeparator(composite, columns);

		// 15.07.08
		if ( BuilderActivator.getDefault().getConfiguration().isNewServiceUseOperationPreview() ){
			createDefaultOperationControls(composite, columns);
		}

//		createModifierControls(composite, nColumns);

//		createSuperClassControls(composite, nColumns);
//		createSuperInterfacesControls(composite, nColumns);

//		createMethodStubSelectionControls(composite, nColumns);

//		createCommentControls(composite, columns);
		setAddComments(true,false);
		enableCommentControl(true);

		setControl(composite);

		Dialog.applyDialogFont(composite);
		PlatformUI.getWorkbench().getHelpSystem().setHelp(composite, IJavaHelpContextIds.NEW_CLASS_WIZARD_PAGE);



	}

	protected void createDefaultOperationControls(Composite parent, int columns){

		final int buttonColumns= 1;
		Group group= new Group(parent, SWT.NORMAL);
		{
			group.setLayout(new GridLayout(buttonColumns,false));
			GridData data= new GridData(GridData.FILL_HORIZONTAL);
			data.horizontalSpan= columns;
			group.setLayoutData(data);
		}
		group.setText("Operation Preview");

		Button btnCreateInput= new Button(group, SWT.CHECK);
		btnCreateInput.setText(BuilderMessages.ServiceNewWizard_button_001);
		btnCreateInput.setSelection(createInputOmmWhenNoExist);

		btnCreateInput.addSelectionListener(new SelectionAdapter() {
			@Override
			public void widgetSelected(SelectionEvent e) {
				Button btn= (Button)e.widget;
				createInputOmmWhenNoExist= btn.getSelection();
			}
		});

		Button btnCreateOutput= new Button(group, SWT.CHECK);
		btnCreateOutput.setText(BuilderMessages.ServiceNewWizard_button_002);
		btnCreateOutput.setSelection(createOutputOmmWhenNoExist);
		btnCreateOutput.addSelectionListener(new SelectionAdapter() {
			@Override
			public void widgetSelected(SelectionEvent e) {
				Button btn= (Button)e.widget;
				createOutputOmmWhenNoExist= btn.getSelection();
			}
		});

		// 서비스의 논리명, 설명을 오퍼레이션의 논리명, 설명에 적용할 것인지 여부
		Button btnApplyLogicalNameToOperation= new Button(group, SWT.CHECK);
		btnApplyLogicalNameToOperation.setText(BuilderMessages.ServiceNewWizard_button_003);
		btnApplyLogicalNameToOperation.setSelection(applyLogicalNameToOperation);
		btnApplyLogicalNameToOperation.addSelectionListener(new SelectionAdapter() {
			@Override
			public void widgetSelected(SelectionEvent e) {
				Button btn= (Button)e.widget;
				applyLogicalNameToOperation= btn.getSelection();
			}
		});

		// 서비스의 논리명, 설명을 오퍼레이션 IO 논리명에 적용할 것인지 여부
		Button btnApplyLogicalNameToIO= new Button(group, SWT.CHECK);
		btnApplyLogicalNameToIO.setText(BuilderMessages.ServiceNewWizard_button_004);
		btnApplyLogicalNameToIO.setSelection(applyLogicalNameToIO);
		btnApplyLogicalNameToIO.addSelectionListener(new SelectionAdapter() {
			@Override
			public void widgetSelected(SelectionEvent e) {
				Button btn= (Button)e.widget;
				applyLogicalNameToIO= btn.getSelection();
			}
		});

		operationViewer= new OperationViewer(group, SWT.BORDER);
		operationViewer.setContentProvider( new ArrayContentProvider() );
		operationViewer.setLabelProvider( new OperationViewerLabelProvider());

		{
			GridData data= new GridData(GridData.FILL_HORIZONTAL);
			data.heightHint= 100;
			data.horizontalSpan=buttonColumns;
			operationViewer.getControl().setLayoutData(data);
		}

		bindServiceOperation();
	}

	@Override
	public void setVisible(boolean visible) {
		logger.trace("NewServiceClassWizardPage.setVisible");
		super.setVisible(visible);
		if (visible) {
			setFocus();
		} else {
			IDialogSettings dialogSettings= getDialogSettings();
			if (dialogSettings != null) {
				IDialogSettings section= dialogSettings.getSection(PAGE_NAME);
				if (section == null) {
					section= dialogSettings.addNewSection(PAGE_NAME);
				}
				section.put(SETTINGS_CREATEMAIN, isCreateMain());
				section.put(SETTINGS_CREATECONSTR, isCreateConstructors());
				section.put(SETTINGS_CREATEUNIMPLEMENTED, isCreateInherited());
			}
		}
	}

	private void createMethodStubSelectionControls(Composite composite, int nColumns) {
		logger.trace("NewServiceClassWizardPage.createMethodStubSelectionControls");
		Control labelControl= fMethodStubsButtons.getLabelControl(composite);
		LayoutUtil.setHorizontalSpan(labelControl, nColumns);

		DialogField.createEmptySpace(composite);

		Control buttonGroup= fMethodStubsButtons.getSelectionButtonsGroup(composite);
		LayoutUtil.setHorizontalSpan(buttonGroup, nColumns - 1);
	}

	/**
	 * Returns the current selection state of the 'Create Main' checkbox.
	 *
	 * @return the selection state of the 'Create Main' checkbox
	 */
	public boolean isCreateMain() {
		return fMethodStubsButtons.isSelected(0);
	}

	/**
	 * Returns the current selection state of the 'Create Constructors' checkbox.
	 *
	 * @return the selection state of the 'Create Constructors' checkbox
	 */
	public boolean isCreateConstructors() {
		return fMethodStubsButtons.isSelected(1);
	}

	/**
	 * Returns the current selection state of the 'Create inherited abstract methods'
	 * checkbox.
	 *
	 * @return the selection state of the 'Create inherited abstract methods' checkbox
	 */
	public boolean isCreateInherited() {
		return fMethodStubsButtons.isSelected(2);
	}

	/**
	 * Sets the selection state of the method stub checkboxes.
	 *
	 * @param createMain initial selection state of the 'Create Main' checkbox.
	 * @param createConstructors initial selection state of the 'Create Constructors' checkbox.
	 * @param createInherited initial selection state of the 'Create inherited abstract methods' checkbox.
	 * @param canBeModified if <code>true</code> the method stub checkboxes can be changed by
	 * the user. If <code>false</code> the buttons are "read-only"
	 */
	public void setMethodStubSelection(boolean createMain, boolean createConstructors, boolean createInherited, boolean canBeModified) {
		logger.trace("NewServiceClassWizardPage.setMethodStubSelection");
		fMethodStubsButtons.setSelection(0, createMain);
		fMethodStubsButtons.setSelection(1, createConstructors);
		fMethodStubsButtons.setSelection(2, createInherited);

		fMethodStubsButtons.setEnabled(canBeModified);
	}

	@Override
	protected void createTypeMembers(IType type, ImportsManager imports, IProgressMonitor monitor) throws CoreException {
		logger.trace("NewServiceClassWizardPage.createTypeMembers");
		boolean doMain= isCreateMain();
		boolean doConstr= isCreateConstructors();
		boolean doInherited= isCreateInherited();
		createInheritedMethods(type, doConstr, doInherited, imports, new SubProgressMonitor(monitor, 1));

		if (doMain) {
			StringBuffer buf= new StringBuffer();
			final String lineDelim= "\n"; // OK, since content is formatted afterwards
			String comment= CodeGeneration.getMethodComment(type.getCompilationUnit(), type.getTypeQualifiedName('.'), "main", new String[] {"args"}, new String[0], Signature.createTypeSignature("void", true), null, lineDelim);
			if (comment != null) {
				buf.append(comment);
				buf.append(lineDelim);
			}
			buf.append("public static void main(");
			buf.append(imports.addImport("java.lang.String"));
			buf.append("[] args) {");
			buf.append(lineDelim);
			final String content= CodeGeneration.getMethodBodyContent(type.getCompilationUnit(), type.getTypeQualifiedName('.'), "main", false, "", lineDelim);
			if (content != null && content.length() != 0)
				buf.append(content);
			buf.append(lineDelim);
			buf.append("}");
			type.createMethod(buf.toString(), null, false, null);
		}

		if (monitor != null) {
			monitor.done();
		}
	}

	protected String constructSimpleTypeStub() {
		StringBuffer buf= new StringBuffer("public class ");
		buf.append(getTypeName());
		buf.append("{ }");
		return buf.toString();
	}

	@Override
	protected void createPackageControls(Composite composite, int nColumns) {
		super.createPackageControls(composite, nColumns);

		if ( !ConfigurationUtils.getConfiguration().isCheckPackageNameForServiceWizard()) return;

		try {
			if ( getPackageFragmentRoot() != null ){

				IJavaProject javaProject= getJavaProject();
				if ( javaProject == null ) return;

				String selectedPackageName= getPackageText();

				if ( !selectedPackageName.endsWith( getPreferPackageSuffix() ) ){

					String packageName= ResourceNamingProviderManager.instance().getPackageName(ResourceType.SERVICE, javaProject.getProject(), "", "");

					String message= MessageFormat.format(BuilderMessages.PACKAGE_SELECTION_MESSAGE
							, "Service"
							, selectedPackageName
							, packageName
							);
					MessageDialog.openInfo(message);

					IPackageFragment pf=getPackageFragmentRoot().getPackageFragment(packageName);
					setPackageFragment(pf, true);
				}
			}
		} catch (Exception e) {
			e.printStackTrace();
		}
	}

	protected IPackageFragmentRoot chooseContainer()
    {
		return EclipseUtils.chooseSrcContainer(getShell());
    }

	protected String getPreferPackageSuffix(){
		return ResourceNamingProviderManager.instance().getServicePackageSuffix();
	}

	@Override
	protected void updateStatus(IStatus status) {
		super.updateStatus(status);

		bindServiceOperation();
	}

	private void bindServiceOperation(){
		if ( operationViewer != null ){

			INewProjectProvider[] providers= BuilderCustomizationManager.instance().getNewProjectProviders();

			String packageName= getPackageText();
			String serviceName= getServiceName();

			Set<ServiceOperationSet> serviceOperationSet= new LinkedHashSet<ServiceOperationSet>();

			if ( providers != null )
			{
				for (INewProjectProvider provider : providers) {
					ServiceOperationSet[] sos= provider.getDefaultServiceOperationSet(packageName, serviceName);

					if ( sos != null && sos.length > 0){
						for (ServiceOperationSet so : sos) {
							serviceOperationSet.add(so);
						}
					}
				}
			}

			serviceOperationSetList= serviceOperationSet.toArray( new ServiceOperationSet[serviceOperationSet.size()]);
			operationViewer.setInput(serviceOperationSetList);
		}
	}

	public ServiceOperationSet[] getServiceOperationSetList() {
		// 15.07.08
		if ( BuilderActivator.getDefault().getConfiguration().isNewServiceUseOperationPreview() ){
			return serviceOperationSetList;
		}
		else{
			return new ServiceOperationSet[0];
		}
	}

	private void writeExtendedBodyContents(StringBuffer buf, ImportsManager imports, String lineDelimiter, String logicalName, String description){
		if ( serviceOperationSetList== null || serviceOperationSetList.length == 0 ){
			return;
		}

		boolean first= true;

		for (ServiceOperationSet sos : serviceOperationSetList) {

			if ( first ){
				first= false;
			}
			else{
				buf.append(lineDelimiter);
			}

			String inputQName= sos.getInputOmm();
			String inputSName= JavaUtils.getClassName(inputQName);

			String outputQName= sos.getOutputOmm();
			String outputSName= JavaUtils.getClassName(outputQName);

			imports.addImport(inputQName);
			imports.addImport(outputQName);
			imports.addImport("bxm.container.annotation.BxmServiceOperation");
			imports.addImport("bxm.common.annotaion.BxmCategory");

			String throwsClassName= sos.getThrowsClassName();

			buf
			.append("@BxmServiceOperation")
			.append("(\"")
			.append(sos.getOperationName())
			.append("\")")
			.append(lineDelimiter)

			.append("@BxmCategory")
			.append("(")
			.append("logicalName=\"")
			.append(logicalName)
			.append("\"")
			.append(", ")
			.append("description=\"")
			.append(description)
			.append("\")")
			.append(lineDelimiter)

			.append("public ")
			.append(outputSName)
			.append(" ")
			.append(sos.getMethodName())
			.append("(")
			.append(inputSName)
			.append(" " )
			.append("input")
			.append(")")
			.append(" ")
			.append("throws")
			.append(" ")
			;

			if ( StringUtils.isEmpty(throwsClassName) ){
				imports.addImport("bxm.app.ApplicationException");
				buf
				.append("ApplicationException")
				.append(lineDelimiter)
				;
			}
			else{
				imports.addImport(throwsClassName);
				String throwsClassSimpleName= JavaUtils.getClassName(throwsClassName);
				buf
				.append(throwsClassSimpleName)
				.append(lineDelimiter)
				;
			}

			buf
			.append("{")
			.append(lineDelimiter)
			.append(lineDelimiter)
			.append("logger.debug(\"============== SERVICE START ==============\");").append(lineDelimiter)
			.append("logger.debug(\"input = {}\", input);").append(lineDelimiter).append(lineDelimiter)
			.append(outputSName)
			.append(" output = new ")
			.append(outputSName )
			.append("();")
			.append(lineDelimiter)
			.append(lineDelimiter)
			.append("// TODO write code here")
			.append(lineDelimiter)
			.append(lineDelimiter)
			.append("logger.debug(\"output = {}\", output);").append(lineDelimiter)
			.append("logger.debug(\"============== SERVICE END ==============\");").append(lineDelimiter)
			.append(lineDelimiter)
			.append("return output;").append(lineDelimiter)
			.append("}")

			;
		}
	}

	@Override
	protected void writeExtendedBodyContents(StringBuffer buff, ImportsManager imports, String lineDelimiter) {



		this.writeExtendedBodyContents(
				buff
				, imports
				, lineDelimiter
				, applyLogicalNameToOperation?getLogicalName():""
				, applyLogicalNameToOperation?getDescription():""
				);
	}

