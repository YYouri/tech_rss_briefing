                                                        and 
                                                        count( .//MethodDeclaration[@Abstract='true'] )=0 
                                                ]
                                                [count(ImplementsList)=0]
                                                [count(.//ExtendsList)=0]
                                        ]]> 
                                </value> 
                        </property> 
                </properties> 
 
                <example> 
                        <![CDATA[
/* 잘못된 예 */
