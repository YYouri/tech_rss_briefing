<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>

  <!-- ============================================================ -->
  <!-- 1. Commands                                                   -->
  <!-- ============================================================ -->
  <extension point="org.eclipse.ui.commands">

    <command id="com.aiassist.commands.smartAction"
             name="AI Smart Action"
             description="AI가 선택 코드를 분석하여 최적 액션 자동 수행"/>

    <command id="com.aiassist.commands.explainCode"
             name="AI 코드 설명"
             description="선택한 코드를 AI로 설명"/>

    <command id="com.aiassist.commands.analyzeError"
             name="AI 에러 분석"
             description="에러 메시지와 코드를 AI로 분석"/>

    <command id="com.aiassist.commands.generateJavadoc"
             name="AI JavaDoc 생성"
             description="커서 위치 메서드의 JavaDoc을 AI로 생성"/>

    <command id="com.aiassist.commands.openChat"
             name="AI 채팅 열기"
             description="AI와 자유 형식 채팅"/>

    <command id="com.aiassist.commands.serverSettings"
             name="AI 서버 설정"
             description="내부 중계 서버 URL 설정"/>

  </extension>

  <!-- ============================================================ -->
  <!-- 2. Key Bindings                                               -->
  <!-- ============================================================ -->
  <extension point="org.eclipse.ui.bindings">

    <!-- Ctrl+Shift+A : Smart AI Action (Java 에디터 전용) -->
    <key sequence="M1+M2+A"
         commandId="com.aiassist.commands.smartAction"
         schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
         contextId="org.eclipse.jdt.ui.javaEditorScope"/>

    <!-- Ctrl+Shift+E : 코드 설명 (Java 에디터 전용) -->
    <key sequence="M1+M2+E"
         commandId="com.aiassist.commands.explainCode"
         schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
         contextId="org.eclipse.jdt.ui.javaEditorScope"/>

    <!-- Ctrl+Shift+J : JavaDoc 생성 (Java 에디터 전용) -->
    <key sequence="M1+M2+J"
         commandId="com.aiassist.commands.generateJavadoc"
         schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
         contextId="org.eclipse.jdt.ui.javaEditorScope"/>

    <!-- Ctrl+Shift+C : 채팅 열기 (전역) -->
    <key sequence="M1+M2+C"
         commandId="com.aiassist.commands.openChat"
         schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
         contextId="org.eclipse.ui.contexts.window"/>

  </extension>

  <!-- ============================================================ -->
  <!-- 3. Handlers                                                   -->
  <!-- ============================================================ -->
  <extension point="org.eclipse.ui.handlers">

    <handler commandId="com.aiassist.commands.smartAction"
             class="com.aiassist.handlers.SmartAiActionHandler">
      <activeWhen>
        <with variable="activeEditorId">
          <equals value="org.eclipse.jdt.ui.CompilationUnitEditor"/>
        </with>
      </activeWhen>
    </handler>

    <handler commandId="com.aiassist.commands.explainCode"
             class="com.aiassist.handlers.ExplainCodeHandler">
      <activeWhen>
        <with variable="activeEditorId">
          <equals value="org.eclipse.jdt.ui.CompilationUnitEditor"/>
        </with>
      </activeWhen>
    </handler>

    <handler commandId="com.aiassist.commands.analyzeError"
             class="com.aiassist.handlers.AnalyzeErrorHandler">
      <activeWhen>
        <with variable="activeEditorId">
          <equals value="org.eclipse.jdt.ui.CompilationUnitEditor"/>
        </with>
      </activeWhen>
    </handler>

    <handler commandId="com.aiassist.commands.generateJavadoc"
             class="com.aiassist.handlers.GenerateJavadocHandler">
      <activeWhen>
        <with variable="activeEditorId">
          <equals value="org.eclipse.jdt.ui.CompilationUnitEditor"/>
        </with>
      </activeWhen>
    </handler>

    <handler commandId="com.aiassist.commands.openChat"
             class="com.aiassist.handlers.OpenChatHandler"/>

    <handler commandId="com.aiassist.commands.serverSettings"
             class="com.aiassist.handlers.ServerSettingsHandler"/>

  </extension>

  <!-- ============================================================ -->
  <!-- 4. Menus                                                      -->
  <!-- ============================================================ -->
  <extension point="org.eclipse.ui.menus">

    <!-- 에디터 우클릭 컨텍스트 메뉴 -->
    <menuContribution
        locationURI="popup:org.eclipse.jdt.ui.CompilationUnitEditor.EditorContext?after=additions">
      <menu id="com.aiassist.menu.context"
            label="AI Assistant"
            mnemonic="I">

        <command commandId="com.aiassist.commands.smartAction"
                 label="✨ Smart AI Action  (Ctrl+Shift+A)"
                 style="push"/>
        <separator name="sep1"/>
        <command commandId="com.aiassist.commands.explainCode"
                 label="코드 설명  (Ctrl+Shift+E)"
                 style="push"/>
        <command commandId="com.aiassist.commands.analyzeError"
                 label="에러 분석"
                 style="push"/>
        <command commandId="com.aiassist.commands.generateJavadoc"
                 label="JavaDoc 생성  (Ctrl+Shift+J)"
                 style="push"/>
        <separator name="sep2"/>
        <command commandId="com.aiassist.commands.openChat"
                 label="💬 AI 채팅  (Ctrl+Shift+C)"
                 style="push"/>

      </menu>
    </menuContribution>

    <!-- 메인 메뉴바 -->
    <menuContribution locationURI="menu:org.eclipse.ui.main.menu?after=additions">
      <menu id="com.aiassist.menu.main"
            label="AI Assistant"
            mnemonic="I">

        <command commandId="com.aiassist.commands.smartAction"
                 label="✨ Smart AI Action  (Ctrl+Shift+A)"
                 style="push"/>
        <separator name="sep1"/>
        <command commandId="com.aiassist.commands.explainCode"
                 label="코드 설명"
                 style="push"/>
        <command commandId="com.aiassist.commands.analyzeError"
                 label="에러 분석"
                 style="push"/>
        <command commandId="com.aiassist.commands.generateJavadoc"
                 label="JavaDoc 생성"
                 style="push"/>
        <separator name="sep2"/>
        <command commandId="com.aiassist.commands.openChat"
                 label="💬 AI 채팅  (Ctrl+Shift+C)"
                 style="push"/>
        <separator name="sep3"/>
        <command commandId="org.eclipse.ui.views.showView"
                 label="AI 결과 창"
                 style="push">
          <parameter name="org.eclipse.ui.views.showView.viewId"
                     value="com.aiassist.views.AiResultView"/>
        </command>
        <separator name="sep4"/>
        <command commandId="com.aiassist.commands.serverSettings"
                 label="⚙ 서버 설정"
                 style="push"/>

      </menu>
    </menuContribution>

  </extension>

  <!-- ============================================================ -->
  <!-- 5. Views                                                      -->
  <!-- ============================================================ -->
  <extension point="org.eclipse.ui.views">

    <view id="com.aiassist.views.AiResultView"
          name="AI Assistant"
          class="com.aiassist.views.AiResultView"
          category="org.eclipse.jdt"
          restorable="true"/>

    <view id="com.aiassist.chat.AiChatView"
          name="AI Chat"
          class="com.aiassist.chat.AiChatView"
          category="org.eclipse.jdt"
          restorable="true"/>

  </extension>

  <!-- ============================================================ -->
  <!-- 6. Content Assist (Ctrl+Space → AI 코드 생성)               -->
  <!-- ============================================================ -->
  <extension point="org.eclipse.jdt.ui.javaCompletionProposalComputer"
             id="com.aiassist.proposalComputer"
             name="AI 코드 생성">
    <javaCompletionProposalComputer
        class="com.aiassist.assist.AiProposalComputer"
        categoryId="com.aiassist.proposalCategory">
      <partition type="__dftl_partition_content_type"/>
      <partition type="__java_string"/>
      <partition type="__java_singleline_comment"/>
      <partition type="__java_multiline_comment"/>
    </javaCompletionProposalComputer>
  </extension>

  <extension point="org.eclipse.jdt.ui.javaCompletionProposalCategory"
             id="com.aiassist.proposalCategory">
    <javaCompletionProposalCategory
        id="com.aiassist.proposalCategory"
        name="AI Assistant"
        displayName="AI 코드 생성"/>
  </extension>

  <!-- ============================================================ -->
  <!-- 7. Preference Page (Window → Preferences → AI Assistant)     -->
  <!-- ============================================================ -->
  <extension point="org.eclipse.ui.preferencePages">
    <page id="com.aiassist.prefs.AiPreferencePage"
          name="AI Assistant"
          class="com.aiassist.prefs.AiPreferencePage"/>
  </extension>

</plugin>
