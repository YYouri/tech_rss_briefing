        void int method1() { ... }
        void int method2() { ... }
        // consider using abstract methods or removing
        // the abstract modifier and adding protected constructors
}
 
/* 올바른 예 */
public abstract class Foo {
        // using abstract methods
        void abstract int method1();
        void int method2() {
                // do something...
        }
}
 
// removing he abstract modifier
public class Foo {
        void int method1() {
                // do something...
        }
        void int method2() {
                // do something...
        }
}
                        ]]> 
                </example> 
        </rule> 
 
        <rule name="EqualsNull"
        		language="java"
                since="1.9"
                message="equals()을 이용한 null 비교"
                class="net.sourceforge.pmd.lang.rule.XPathRule"
                externalInfoUrl="http://developer.cis.co.kr/support/pmd/EqualsNull.html"> 
 
                <description> 
