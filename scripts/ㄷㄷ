@SuppressWarnings("restriction")
public class BxmDecorator
extends LabelProvider
implements ILightweightLabelDecorator
{
	private static Logger logger= LoggerFactory.getLogger(BxmDecorator.class);
	
	private static final String CLASSPATH_CONTAINER_ID = "bxm.builder.core.container";
	private static final String OMM_JAVA = "[omm-java]";
	private static final String DTO_JAVA = "[dto-java]";
	private static final String DBIO_INTERFACE = "[dbio-interface]";

	public final static String APPLICATION_ROOT_ELEMENT_NAME = "bxm-application";
	public final static String APPLICATION_NAME_TAG = "name";
	
	private FileBufferListener fListener;

	private UIJob fNotifierJob;

	private Set<Object> fChangedResources;

	public BxmDecorator(){
		fListener= new FileBufferListener();
		FileBuffers.getTextFileBufferManager().addFileBufferListener(fListener);

		fChangedResources= new HashSet<Object>();
	}

	public void dispose() {
		FileBuffers.getTextFileBufferManager().removeFileBufferListener(fListener);
	}

	private class DecorationCache{
		String label;
		long timestamp= 0L;
		@Override
		public String toString() {
			return label==null?"":(label);
		}
	}

	private Map<Object, DecorationCache> cacheSet= new WeakHashMap<Object, BxmDecorator.DecorationCache>();

	private class FileBufferListener implements IFileBufferListener {

		@Override
		public void bufferCreated(IFileBuffer buffer) {
		}

		@Override
		public void bufferDisposed(IFileBuffer buffer) {

		}

		@Override
		public void bufferContentAboutToBeReplaced(IFileBuffer buffer) {
		}

		@Override
		public void bufferContentReplaced(IFileBuffer buffer) {
		}

		@Override
		public void stateChanging(IFileBuffer buffer) {
			if (buffer.getLocation() != null)
				update(buffer.getLocation());
		}

		@Override
		public void dirtyStateChanged(IFileBuffer buffer, boolean isDirty) {
		}

		@Override
		public void stateValidationChanged(IFileBuffer buffer, boolean isStateValidated) {
		}

		@Override
		public void underlyingFileMoved(IFileBuffer buffer, IPath path) {
		}

		@Override
		public void underlyingFileDeleted(IFileBuffer buffer) {
		}

		@Override
		public void stateChangeFailed(IFileBuffer buffer) {
		}
	}

	private void update(IPath location) {
		IFile file= FileBuffers.getWorkspaceFileAtLocation(location);
		if (file != null) {
			boolean hasChanges= false;
			synchronized (this) {
				hasChanges= fChangedResources.add(file);
			}
			if (hasChanges) {
				if (fNotifierJob == null) {
					fNotifierJob= new UIJob(Display.getDefault(), "Update BXM Decorations") {
						public IStatus runInUIThread(IProgressMonitor monitor) {
							runPendingUpdates();
							return Status.OK_STATUS;
						}
					};
					fNotifierJob.setSystem(true);
				}
				fNotifierJob.schedule();
			}
		}
	}

	private void runPendingUpdates() {
		Object[] resourceToUpdate= null;
		synchronized (this) {
			resourceToUpdate= fChangedResources.toArray();
			fChangedResources.clear();
		}
		if ( logger.isTraceEnabled() ) logger.trace(">> resourceToUpdate.length : {}", resourceToUpdate.length);
		if (resourceToUpdate.length > 0) {
			LabelProviderChangedEvent event= new LabelProviderChangedEvent(this, resourceToUpdate);
			fireLabelProviderChanged(event);
		}
	}

	// TODO 패키지 라벨링

	@Override
	public void decorate(Object element, IDecoration decoration) 
	{
		if ( !DecoratorPreferenceManager.useDecorating() )
		{
			return ;
		}

		if(isDecorateTarget(element))
		{
			if ( element instanceof IFile )
			{
				decorateInternal((IFile)element, decoration);
			}
			else if ( element instanceof IJavaElement ){
				decorateInternal((IJavaElement)element, decoration);
			}
			else if ( element instanceof IFolder ){
				decorateInternal((IFolder)element, decoration);
			}
			else if ( element instanceof ClassPathContainer ){
				decorateInternal((ClassPathContainer)element, decoration);
			}
		}
	}
	
	private boolean isDecorateTarget(Object element)
	{
		Set<String> packages= DecorationConfiguration.instance().getNoDecoratePackages();
		
		IResource resource= null;
		
		if(element instanceof IResource) {
			resource= (IResource) element;
		} else if(element instanceof IJavaElement) {
			IJavaElement javaElement= (IJavaElement) element;
			resource= javaElement.getResource();
		}

		List<Path> paths= new ArrayList<Path>();
		for(String pack : packages)
		{
			paths.addAll(getPathsFromPackage(pack));
		}
		
		for(Path path : paths)
		{
			if(EclipseUtils.isResourceInDirectory(path, resource))
			{
				return false;
			}
		}
		
		
		return true;
	}
	
	private List<Path> getPathsFromPackage(final String pack)
	{
		List<Path> paths= new ArrayList<Path>();
		Set<String> pathPrefixes= new HashSet<String>();

		pathPrefixes.add(BxmConstants.SRC_FOLDER_NAME);
		
		if(ConfigurationUtils.getConfiguration().getGenOmmJavaInSrcGen()) {
			pathPrefixes.add(BxmConstants.SRC_GEN_FOLDER_NAME);
		}
		pathPrefixes.add(ConfigurationUtils.getConfiguration().getOmmPfr());

		for(String prefix : pathPrefixes)
		{
			Path path= new Path(prefix + "/" + pack);
			paths.add(path);
		}
		
		return paths;
	}

	private void decorateInternal(final ClassPathContainer element, final IDecoration decoration)
	{
		if ( element== null ){
			return;
		}

		if ( !DecoratorPreferenceManager.useLibContainerDecorating() ) return ;

		try {
			if ( element.getJavaProject()==null
					|| !element.getJavaProject().getProject().hasNature(BxmConstants.BXM_APPLICATION_NATURE_ID) ) return;
		} catch (CoreException e) {
			e.printStackTrace();
			return;
		}

		IPath path= element.getClasspathEntry().getPath();

		if ( CLASSPATH_CONTAINER_ID.equals(path.toString()) ){
			decoration.addSuffix(UIText.LABEL_BXM_LIBRARY);
		}
	}

	private void decorateInternal(final IJavaElement element, final IDecoration decoration){

		if ( element== null
				|| !element.exists()
				){
			return;
		}

		try {
			if ( element.getJavaProject()==null
					|| !element.getJavaProject().getProject().hasNature(BxmConstants.BXM_APPLICATION_NATURE_ID) ) return;
		} catch (CoreException e) {
			e.printStackTrace();
			return;
		}

		switch (element.getElementType()) {
		case IJavaElement.JAVA_PROJECT :
		{
			decorateInternal((IJavaProject)element, decoration);
			break;
		}
		case IJavaElement.COMPILATION_UNIT :
		{
			decorateInternal((ICompilationUnit)element, decoration);
			break;
		}
		case IJavaElement.PACKAGE_FRAGMENT_ROOT :
		{
			decorateInternal((IPackageFragmentRoot)element, decoration);
			break;
		}
		case IJavaElement.PACKAGE_FRAGMENT:
		{
			decorateInternal((IPackageFragment)element, decoration);
			break;
		}
		// 16.01.20 Blocked - 비효율적임
//		case IJavaElement.TYPE :
//		{
//			IType type= (IType)element;
//			if ( !type.isBinary() ){
//				if ( type instanceof SourceType ){
////					decorateInternal((SourceType)element, decoration);
//				}
//			}
//			break;
//		}
//		case IJavaElement.METHOD :
//		{
//			IMethod method= (IMethod)element;
//			if ( method != null || !method.isBinary() ){
//				if ( method instanceof SourceMethod )
//				{
////					decorateInternal((SourceMethod)element, decoration);
//				}
//			}
//			break;
//		}
		default:
			break;
		}
	}

	private String getLogicalName(final CompilationUnit cu, ClassType classType){
		ClassCategoryFindVisitor visitor = new ClassCategoryFindVisitor();
		cu.accept( visitor );
		
		String logicalName= visitor.getLogicalName();
		if(StringUtils.isEmpty(logicalName))
		{
			/* 첫번째 TypeDeclaration만 검색한다 */
			List<?> types= cu.types();
			
			ASTNode aNode= null;
			for(Object type : types) {
				if(type instanceof ASTNode) {
					aNode= (ASTNode) type;
					break;
				}
			}
			
			if(aNode != null)
			{
				logicalName= getAliasValue(aNode).trim();
			}
		}
		
		return logicalName;
	}
	
	private String getAliasValue(ASTNode node)
	{
		JavadocVisitor jv= new JavadocVisitor();
		node.accept(jv);
		
		return StringUtils.isEmpty(jv.getAliasValue())?"":jv.getAliasValue();
	}

	private void decorateInternal(final ICompilationUnit cUnit, final IDecoration decoration)
	{
		try {
			if ( cUnit== null || !cUnit.exists() ) return;
			if ( !cUnit.getJavaProject().getProject().hasNature(BxmConstants.BXM_APPLICATION_NATURE_ID) ) return;
		} catch (CoreException e) {
			e.printStackTrace();
			PluginLog.info("Invalid Compilation Unit - " + e.getMessage());
			return;
		}

		DecorationCache cache= cacheSet.get(cUnit);

		if ( cache== null ){
			cache= new DecorationCache();
			cacheSet.put(cUnit, cache);
			// TODO
		}

		long modifiedTimestamp= cUnit.getResource().getLocalTimeStamp();
		if ( logger.isTraceEnabled() ) if ( logger.isTraceEnabled() ) logger.trace(">> ICU : {}, isOpen : {}", new Object[]{cUnit.getElementName(),cUnit.isOpen()});
		if ( modifiedTimestamp > cache.timestamp ){
			// TODO 파싱 필요
			cache.timestamp = modifiedTimestamp;
			cache.label= "뉴";
		}
		else{
			cache.label= "변경 없음";
		}

		try {
			ClassType classType= BXMUtils.getClassType(cUnit);

			CompilationUnit cu= ASTUtils.createCU(cUnit, false);

			final String logicalName = getLogicalName(cu, classType);

			if ( ClassType.BEAN== classType
//					|| ClassType.BATCHBEAN== classType
					|| ClassType.CHUNKED_BATCHBEAN== classType
					|| ClassType.TASKLET_BATCHBEAN== classType
					|| ClassType.BATCH_CLASS_TASKLET== classType
					|| ClassType.BATCH_CLASS_TASKENTITY== classType
					|| ClassType.SUB_SERVICE== classType
					)
			{
				cache.label= String.format(UIText.LABEL_FILE_BEAN_JAVA, logicalName==null?UIText.LABEL_UNREGISTERED_RESOURCE:logicalName);
				beanIcondecoration(decoration);
			}
			else if ( ClassType.SERVICE== classType
						|| ClassType.MAIN_SERVICE== classType)
			{
				cache.label= String.format(UIText.LABEL_FILE_SERVICE_JAVA, logicalName==null?UIText.LABEL_UNREGISTERED_RESOURCE:logicalName);
				serviceIconDecoration(decoration);
			}
			else if ( ClassType.DBIO_INTERFACE== classType )
			{
				cache.label= String.format(UIText.LABEL_FILE_DBIO_INTERFACE, logicalName==null?UIText.LABEL_UNREGISTERED_RESOURCE:logicalName);
				dbioInterfaceIconDecoration(decoration);
			}
//			else if ( ClassType.OMM_GENERATED== classType ||
//						ClassType.BUSINESS_VO== classType ||
//						ClassType.OTHER_VO== classType)
			else if ( ClassType.OMM_GENERATED== classType)
			{
				String description = null;

				OmmGeneratedJavaVisitor visitor = new OmmGeneratedJavaVisitor();
				cu.accept(visitor);
				description = visitor.getDescription();

				cache.label= String.format(UIText.LABEL_FILE_OMM_JAVA, description);

				ommJavaIconDecoration(decoration);
			}
			else if ( ClassType.BUSINESS_VO.equals(classType))
			{
				cache.label= String.format(UIText.LABEL_FILE_SERVICE_JAVA, logicalName==null?UIText.LABEL_UNREGISTERED_RESOURCE:logicalName);
				ommJavaIconDecoration(decoration);
			}
			else if ( ClassType.DTO_GENERATED== classType )
			{
				String description = null;

				DtoGeneratedJavaVisitor visitor = new DtoGeneratedJavaVisitor();
				cu.accept(visitor);
				description = visitor.getDescription();

				cache.label= String.format(UIText.LABEL_FILE_DTO_JAVA, description);

				dtoJavaIconDecoration(decoration);
			}
			else{
				cache.label= UIText.LABEL_FILE_NORMAL_JAVA;
			}
		} catch (Exception e) {
			e.printStackTrace();
		}

		decoration.addSuffix(cache.toString());
	}

	private void decorateInternal(IJavaProject javaProject, IDecoration decoration)
	{
		if ( !DecoratorPreferenceManager.useProjectDecorating() ) return ;

		if ( javaProject == null || !javaProject.exists() ) return;

		projectIconDecoration(decoration);

		IResource resource = javaProject.getProject().findMember(BxmConstants.APPLICATION_XML_FOLDER_NAME);
		if ( resource == null || !(resource instanceof IFolder) )
		{
			decoration.addSuffix(UIText.LABEL_PROJECT_INVALID_NOT_FOUND_META_INF_FOLDER);
			return;
		}

		IFolder metaInfFolder = (IFolder)resource;

		IFile file = metaInfFolder.getFile(BxmConstants.APPLICATION_XML_FILE_NAME);

		if ( file == null )
		{
			decoration.addSuffix(UIText.LABEL_PROJECT_INVALID_NOT_FOUND_META_INF_FOLDER);
			return;
		}

        try {
        	file.refreshLocal(IResource.DEPTH_ONE, new NullProgressMonitor());
        	/**
    		 * BXM Configuration Load
    		 */
        	BxmApplication application= BXMUtils.getApplicationDescriptor(javaProject.getProject());
//        	decoration.addSuffix(
//        			MessageFormat.format(UIText.LABEL_APPLICATION_NAME,
//        					//            					applicationName.getNodeValue()
//        					application.getDescription()
//        					,application.getName()
//        					,application.getType().name()
//        					)
//        			);
        	decoration.addSuffix(
        			MessageFormat.format("[{0}-{1}]",
        					//            					applicationName.getNodeValue()
        					application.getDescription()
        					,application.getType().name()
        					)
        			);
        }
        catch (Exception e) {
        	e.printStackTrace();
        	PluginLog.info("Error occured - decorateInternal(javaProject) : " + e.getMessage());
		}
	}

	private void decorateInternal(IFolder folder, IDecoration decoration)
	{
		if ( EclipseUtils.isInvalidFolder(folder) ) return;

		if ( !DecoratorPreferenceManager.useFolderDecorating() ) return ;

		try {
			if ( !folder.getProject().hasNature(BxmConstants.BXM_APPLICATION_NATURE_ID) ) return;
		} catch (Exception e) {
		}

		String folderName= folder.getName();

		if ( BxmConstants.TESTCASES_FOLDER_NAME.equals(folderName) ){
			decoration.addSuffix(UIText.LABEL_TESTCASES_FOLDER);
		}
		else if ( BxmConstants.APPLICATION_XML_FOLDER_NAME.equals(folderName) ){
			decoration.addSuffix(UIText.LABEL_META_INF_FOLDER);
		}
		else if ( BxmConstants.BATCH_JOBS_FOLDER_NAME.equals(folderName) ){
			decoration.addSuffix(UIText.LABEL_JOBS_FOLDER);
		}
		else if ( BxmConstants.LIB_FOLDER_NAME_3RD_PARTY.equals(folderName) ){
			decoration.addSuffix(" [어플리케이션 라이브러리]");
		}
		else if ( BxmConstants.WEB_CONTENT_FRAMEWORK_LIB_FOLDER.equals(folderName) ){
			decoration.addSuffix(" [라이브러리]");
		}
		else if ( ".settings".equals(folderName) ){
			decoration.addSuffix(UIText.LABEL_SETTINGS);
		}
		else if ( BxmConstants.BATCH_SHELL_FOLDER_NAME.equals(folderName) ){
			decoration.addSuffix(UIText.LABEL_SHELLS_FOLDER);
		}
	}

	private void decorateInternal(IFile file, IDecoration decoration)
	{
		if( file == null || "class".equals(file.getFileExtension()) || !file.exists() || file.isPhantom() || file.isHidden() ) return;

		try {
			if ( !file.getProject().hasNature(BxmConstants.BXM_APPLICATION_NATURE_ID) ) return;
		} catch (Exception e) {
		}

		String ext = file.getFileExtension();

		if ( "omm".equals(ext) )
		{
			decorationInternalOmmFile(file, decoration);
		}
		else if ( "dto".equals(ext) )
		{
			decorationInternalDtoFile(file, decoration);
		}
		else if ( "dbio".equals(ext) )
		{
			decorationInternalDbioFile(file, decoration);
		}
		else if ( BxmConstants.APPLICATION_XML_FILE_NAME.equals(file.getName()) )
		{
			decoration.addSuffix(UIText.LABEL_APPLICATION_CONFIG_FILE);
		}
		else if ( "case".equals(ext) )
		{
			decorationInternalTestCaseFile(file, decoration);
		}
		else if ( "classpath".equals(ext) ){
			decoration.addSuffix(UIText.LABEL_FILE_CLASSPATH_PROPERTY);
		}
		else if ( "project".equals(ext) ){
			decoration.addSuffix(UIText.LABEL_FILE_PROJECT_PROPERTY);
		}
		else if ( "bxm".equals(ext)){
			decoration.addSuffix(UIText.LABEL_FILE_PACKAGE_PROPERTY);
		}
		else{
			if ( logger.isTraceEnabled() ) logger.trace("\tNO DECORATION: ");
		}
	}

	private void decorationInternalOmmFile(IFile file, IDecoration decoration)
	{
		if ( !DecoratorPreferenceManager.useOmmDecorating() ) return ;
		if ( logger.isTraceEnabled() ) logger.trace(">> DECORATION - OMM : " + file.getName());

		String logicalName = null;

		InputStreamReader reader= null;
		try {
			IProject project= file.getProject();
			final String currentCharSet= BXMUtils.getCurrentCharSet(project);
			reader= new InputStreamReader(file.getContents(), currentCharSet);
			String contents= StreamUtils.getString(reader);
			StringBuilder sb= new StringBuilder();
			boolean in= false;
			for( int i = 0; i < contents.length(); ++i){
				char c= contents.charAt(i);
				if ( c== '"'){
					if ( in ){
						break;
					}
					else{
						in= true;
						continue;
					}
				}

				if ( in ){
					sb.append(c);
				}
			}

			logicalName= sb.toString();

		} catch (Exception e) {
			/*ignore*/
		}
		finally{
			StreamUtils.tryClose(reader);
		}

		try {
			String refined = null;

			if ( logicalName == null )
				refined = UIText.LABEL_UNREGISTERED_RESOURCE;// + "-" + ResourceManager.instance().getOmmEntity(file).getDescription();
			else refined = logicalName;

			decoration.addSuffix(
					String.format(UIText.LABEL_FILE_OMM, refined)
					);
		} catch (Exception e) {
			e.printStackTrace();
			PluginLog.info("Error occured - decorationInternalOmmFile(file) : " + e.getMessage());
		}
	}
	
	private void decorationInternalDtoFile(IFile file, IDecoration decoration)
	{
		if ( !DecoratorPreferenceManager.useOmmDecorating() ) return ;
		if ( logger.isTraceEnabled() ) logger.trace(">> DECORATION - DTO : " + file.getName());

		String logicalName = null;

		InputStreamReader reader= null;
		try {
			reader= new InputStreamReader(file.getContents());
			String contents= StreamUtils.getString(reader);
			StringBuilder sb= new StringBuilder();
			boolean in= false;
			for( int i = 0; i < contents.length(); ++i){
				char c= contents.charAt(i);
				if ( c== '"'){
					if ( in ){
						break;
					}
					else{
						in= true;
						continue;
					}
				}

				if ( in ){
					sb.append(c);
				}
			}

			logicalName= sb.toString();

		} catch (Exception e) {
			/*ignore*/
		}
		finally{
			StreamUtils.tryClose(reader);
		}

		try {
			String refined = null;

			if ( logicalName == null )
				refined = UIText.LABEL_UNREGISTERED_RESOURCE;// + "-" + ResourceManager.instance().getOmmEntity(file).getDescription();
			else refined = logicalName;

			decoration.addSuffix(
					String.format(UIText.LABEL_FILE_OMM, refined)
					);
		} catch (Exception e) {
			e.printStackTrace();
			PluginLog.info("Error occured - decorationInternalDtoFile(file) : " + e.getMessage());
		}
	}

	private void decorationInternalTestCaseFile(IFile file, IDecoration decoration)
	{
		if ( !DecoratorPreferenceManager.useTestCaseDecorating()) return ;
		if ( logger.isTraceEnabled() ) logger.trace(">> DECORATION - TEST CASE : " + file.getName());

		InputStreamReader isr= null;
		BufferedReader br= null;
		try {
			isr= new InputStreamReader(file.getContents());
			br= new BufferedReader(isr);

			String temp= null;

			while( (temp=br.readLine()) != null ){
				if ( temp.startsWith("#TestCaseName")){ // TODO
					String[] values= temp.split("=");
					if ( values != null && values.length==2 ){
						decoration.addSuffix("["+values[1]+"]");
					}
					break;
				}
			}

		} catch (Exception e) {
			e.printStackTrace();
			decoration.addSuffix(UIText.LABEL_FILE_TEST_CASE);
		}
		finally{
			StreamUtils.tryClose(br);
			StreamUtils.tryClose(isr);
		}
	}

	private void decorationInternalDbioFile(IFile file, IDecoration decoration)
	{
		if ( !DecoratorPreferenceManager.useDbioDecorating()) return ;
		if ( logger.isTraceEnabled() ) logger.trace(">> DECORATION - DBIO : " + file.getName());

		try {
			String logicalName = null;

			IFile javaFile = MapperFileUtils.getPairIFile(file);
			ClassCategoryFindVisitor visitor = new ClassCategoryFindVisitor();

			if ( javaFile == null || !javaFile.exists()) return;

			ICompilationUnit cUnit = JavaCore.createCompilationUnitFrom(javaFile);
			final CompilationUnit cu = ASTUtils.createCU(cUnit);
			cu.accept(visitor);
			logicalName = visitor.getLogicalName();

			String refined = null;

			if ( logicalName == null )
				refined =  UIText.LABEL_UNREGISTERED_RESOURCE;
			else refined = logicalName;

			decoration.addSuffix(
					String.format(UIText.LABEL_FILE_DBIO, refined)
					);
		} catch (Exception e) {
			e.printStackTrace();
			PluginLog.info("Error occured - decorationInternalDbioFile(file) : " + e.getMessage());
		}
	}

	@SuppressWarnings("unused")
	private void decorateInternal(final SourceType sourceType, final IDecoration decoration)
	{
		if ( sourceType == null ) return;
		if ( logger.isTraceEnabled() ) logger.trace(">> DECORATION - Source: " + sourceType.getElementName());

		try {
			if ( sourceType.getParent().getElementType() == IJavaElement.COMPILATION_UNIT ){

				ClassType classType= BXMUtils.getClassType((ICompilationUnit)sourceType.getParent());

				if ( classType == ClassType.DBIO_INTERFACE )
				{
					if ( !DecoratorPreferenceManager.useDbioDecorating()) return ;
					decoration.addSuffix(DBIO_INTERFACE);
				}
				else if ( classType == ClassType.OMM_GENERATED)
				{
					if ( !DecoratorPreferenceManager.useOmmDecorating()) return ;
					decoration.addSuffix(OMM_JAVA);
				}
				else if ( classType == ClassType.BEAN){
					if ( !DecoratorPreferenceManager.useBeanDecorating()) return ;

					String logicalName= TypeUtils.getLogicalName(sourceType);
					decoration.addSuffix(String.format(UIText.LABEL_METHOD_BEAN, StringUtils.isEmpty(logicalName)?"":logicalName));
				}
				else if ( classType == ClassType.SERVICE){
					if ( !DecoratorPreferenceManager.useServiceDecorating()) return ;

					String logicalName= TypeUtils.getLogicalName(sourceType);
					decoration.addSuffix(String.format(UIText.LABEL_METHOD_SERVICE, StringUtils.isEmpty(logicalName)?"":logicalName));
				}
			}
			else if ( sourceType.getParent().getElementType() == IJavaElement.TYPE ){
				decorateInternal((SourceType)sourceType.getParent(), decoration);
			}
			else if ( sourceType.getParent().getElementType() == IJavaElement.METHOD ){
				decorateInternal((SourceMethod)sourceType.getParent(), decoration);
			}
			else{
				/*ignore*/
			}
		} catch (Exception e) {
			/*ignore*/
			e.printStackTrace();
			PluginLog.info("Error occured - decorateInternal(sourceType) : " + e.getMessage());
		}
	}

	private void decorateInternal(final SourceMethod sourceMethod, final IDecoration decoration)
	{
		ICompilationUnit cUnit = null;
		if ( logger.isTraceEnabled() ) logger.trace(">> DECORATION - Source Method: " + sourceMethod.getElementName());
		try {
			cUnit = (ICompilationUnit)sourceMethod.getParent().getParent();

			ClassType classType= BXMUtils.getClassType(cUnit);

			String logicalName= TypeUtils.getLogicalName(sourceMethod);

			String label = null;

			if ( classType == ClassType.DBIO_INTERFACE )
			{
				if ( !DecoratorPreferenceManager.useDbioDecorating()) return ;

				dbioInterfaceIconDecoration(decoration);
				label= UIText.LABEL_METHOD_DBIO;
			}
			else if ( classType == ClassType.BEAN ){
				if ( !DecoratorPreferenceManager.useBeanDecorating()) return ;

				beanOperationIconDecoration(decoration);
				label= UIText.LABEL_METHOD_BEAN;
			}
			else if ( classType == ClassType.SERVICE ){
				if ( !DecoratorPreferenceManager.useServiceDecorating()) return ;

				if ( TypeUtils.isServiceOperation(sourceMethod) ){
					serviceOperationIconDecoration(decoration);
				}
				else{
				}
				label= UIText.LABEL_METHOD_SERVICE;
			}

			if ( label != null ){
				decoration.addSuffix(String.format(label, StringUtils.isEmpty(logicalName)?"":logicalName));
			}

		} catch (Exception e) {
			PluginLog.info("Error occured - decorateInternal(sourceMethod) : " + e.getMessage());
		}
	}

	private void decorateInternal(IPackageFragmentRoot pfr, IDecoration decoration)
	{
		if ( !DecoratorPreferenceManager.usePackageFragmentRootDecorating() ) return ;
		if ( pfr== null || !pfr.exists() || pfr.isArchive() ) return;

		if ( logger.isTraceEnabled() ) logger.trace(">> DECORATION - PFR: " + pfr.getElementName());

		if ( BxmConstants.SRC_GEN_FOLDER_NAME.equals( pfr.getElementName() ) )
		{
			decoration.addSuffix(UIText.LABEL_AUTO_GENERATED_SOURCE);
		}
		else if ( BxmConstants.SRC_FOLDER_NAME.equals( pfr.getElementName() ) )
		{
			decoration.addSuffix(UIText.LABEL_SOURCE_FOLDER);
		}
	}

	private void decorateInternal(IPackageFragment pf, IDecoration decoration)
	{
		if ( !DecoratorPreferenceManager.usePackageFragmentDecorating() ) return ;

		if ( pf.isReadOnly() ) return;

		InputStream is= null;
		InputStreamReader isr= null;
		try {
			IFolder folder= (IFolder)pf.getResource();
			IFile file= folder.getFile(".bxm");

			if ( file != null && file.exists() ){
				is= file.getContents();
				isr= new InputStreamReader(is, "UTF8");
				Properties p= new Properties();
				p.load(isr);
				String label= p.getProperty("label");
				if ( !StringUtils.isEmpty(label) ){
					decoration.addSuffix(" ["+label+"]");
				}
			}
		} catch (Exception e) {
			e.printStackTrace();
		}
		finally{
			StreamUtils.tryClose(is);
			StreamUtils.tryClose(isr);
		}
	}

