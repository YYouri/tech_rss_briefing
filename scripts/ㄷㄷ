		return applyLogicalNameToOperation;
	}

	public boolean isApplyLogicalNameToIO() {
		return applyLogicalNameToOperation;
	}

	private ContentProposalAdapter typeNameContentProposalAdapter;

	@Override
	protected void addTypeNameContentProposalAdapter(Text text) {

		if ( getPackageFragmentRoot() != null ){
			try {
				char[] autoActivationCharacters= {};

				IProject project= getPackageFragmentRoot().getJavaProject().getProject();

				IContentProposalProvider contentProposalProvider=
						new SimpleContentProposalProvider(ResourceNamingProviderManager.instance().getServiceNameProposals(project, ""));

				KeyStroke keyStroke= KeyStroke.getInstance("Ctrl+Space");
				typeNameContentProposalAdapter= new ContentProposalAdapter(
						text
						, new TextContentAdapter()
						, contentProposalProvider
						, keyStroke
						, autoActivationCharacters
						);

			} catch (Exception e) {
				e.printStackTrace();
			}
		}
	}

	@Override
	protected IStatus containerChanged() {

		if ( typeNameContentProposalAdapter != null ){
			IProject project= getPackageFragmentRoot().getJavaProject().getProject();

			IContentProposalProvider contentProposalProvider=
					new SimpleContentProposalProvider(ResourceNamingProviderManager.instance().getServiceNameProposals(project, ""));

			typeNameContentProposalAdapter.setContentProposalProvider(contentProposalProvider);
		}

		return super.containerChanged();
	}

	@Override
	protected ClassType getClassTypeToCreate() {
		return ClassType.MAIN_SERVICE;
	}

	@Override
	protected String getCuContents(IPackageFragment pack, ICompilationUnit icu) 
	{
		final String lineDelimiter= StubUtility.getLineDelimiterUsed(pack.getJavaProject());
		final String comment= getMainServiceComment(lineDelimiter, pack, icu);
		return getMainService(lineDelimiter, pack, icu, comment);
	}
	
	private String getMainServiceComment(String lineDelimiter, IPackageFragment pack, ICompilationUnit icu)
	{
		final String tmplId= CodeTemplateContextManager.SERVICE_COMMENT_ID;
		Template tmpl= bxm.builder.ui.templates.StubUtility.getCodeTemplate(tmplId, pack.getJavaProject());
		
		if(tmpl == null)
		{
			PluginLog.logInfo("Cannot find template information : " + tmplId);
			return "";
		}
		
		CodeTemplateContext context= new CodeTemplateContext(tmpl.getContextTypeId(), pack.getJavaProject(), lineDelimiter);
		context.setCompilationUnitVariables(icu);
		
		long time= System.currentTimeMillis();
		SimpleDateFormat timeFormatter= new SimpleDateFormat("yyyy-MM-dd");
		
		context.setVariable("date", timeFormatter.format(new Date(time)));
		
		try {
			return bxm.builder.ui.templates.StubUtility.evaluateTemplate(context, tmpl);
		} catch (CoreException e) {
			PluginLog.logError("fail to create service comment contents", e);
			return "";
		}
	}
	
	private String getMainService(String lineDelimiter, IPackageFragment pack, ICompilationUnit icu, String comment)
	{
		final String tmplId= CodeTemplateContextManager.MAIN_SERVICE_ID;
		Template tmpl= bxm.builder.ui.templates.StubUtility.getCodeTemplate(tmplId, pack.getJavaProject());
		
		if(tmpl == null)
		{
			PluginLog.logInfo("Cannot find template information : " + tmplId);
			return "";
		}
		
		CodeTemplateContext context= new CodeTemplateContext(tmpl.getContextTypeId(), pack.getJavaProject(), lineDelimiter);
		context.setCompilationUnitVariables(icu);
		context.setVariable("package_declaration", "package " + pack.getElementName() + ";");
		context.setVariable("import_declaration", "");
		context.setVariable("service_comment", comment);
		context.setVariable("main_service_name", getTypeName());
		context.setVariable("logical_name", getLogicalName());
		context.setVariable("description", getDescription());
		context.setVariable("method_declaration", "");
		context.setVariable("field_declaration", "");
		context.setVariable("main_service_annotation_qname", BXMConstants.Annotations.MAIN_SERVICE_QNAME);
		context.setVariable("main_service_annotation_sname", BXMConstants.Annotations.MAIN_SERVICE_SNAME);
		
		try {
			return bxm.builder.ui.templates.StubUtility.evaluateTemplate(context, tmpl);
		} catch (CoreException e) {
			PluginLog.logError("fail to create main service contents", e);
			return "";
		}
	}

