        public void bar() {
                InputStream is = null;
                try {
                        is = new InputStream();
                        // do something...
                } finally {
                        // empty!
                }
        }
}
 
/* 올바른 예 */
public class Foo {
        public void bar() {
                InputStream is = null;
                try {
                        is = new InputStream();
                        // do something...
                } finally {
                        if( is != null ) try { is.close(); is = null; } catch(Exception ignr) { is = null; }
                }
        }
}
                        ]]> 
                </example> 
        </rule> 
        
        <rule name="EmptyIfStmt"
        		language="java"
                since="0.1"
                message="if block이 비어있음"
