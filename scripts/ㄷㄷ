	public void doSave( final IProgressMonitor monitor )
	{
		ValidateResult result = isEditorValid();
		if ( !result.isValid() )
		{
			StringBuilder sb = new StringBuilder();
			sb.append(TEXT_SAVE_NOT_ALLOWED);
			sb.append(result.getMessage().toString());

			MessageDialog.openError(getSite().getShell(), TEXT_ERROR,  sb.toString());
			monitor.done();
			return;
		}
		
		/**
		 * HDS 요청 : offset
		 */
		propertySectionPart.configOffsets();
		
		final IFileEditorInput input = (IFileEditorInput) getEditorInput();
		IFile file = input.getFile();
		
		/**
		 * HDS : OMM의 패키지, 이름이 명명규칙을 따르지 않는 경우
		 */
		OmmStructure os= getOmmStructure();
		IProject project= null;
		if(input.getFile() != null)
		{
			project= input.getFile().getProject();
		}
		
		super.doSave( monitor );


		//12.12.01 [[
		final String key = String.format("%s_%s", file.getProject().getName(), ommStructure.getOmmName());
		PropertyWrapperValidateUtil.removeSuperTypeCache(key);
		//12.12.01 ]]

		synchronized (file) {
			InputStream ommFileStream = null;

			try {
				String currentEncoding= BXMUtils.getCurrentCharSet(project);
				ommFileStream = new ByteArrayInputStream(ommStructure.getContent().getBytes(currentEncoding));

				if (file.exists()) {
					file.setContents(ommFileStream, true, true, monitor);
				} else {
					file.create(ommFileStream, true, monitor);
				}
			}
			catch ( final CoreException e )
			{
				throw new IllegalStateException( e );
			} catch (UnsupportedEncodingException e) {
				logger.error(e.getMessage());
			}
			finally
			{
				monitor.done();
				StreamUtils.tryClose( ommFileStream );
				backup();
			}

			monitor.worked(1);
			monitor.setTaskName( "Save..." );
		}
	}