  <!-- 5. 키 바인딩 -->
  <extension point="org.eclipse.ui.bindings">
    <key commandId="hi.bxm.assist.openChat"
         schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
         sequence="ALT+SHIFT+A"/>
    <key commandId="hi.bxm.assist.explainCode"
         schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
         sequence="ALT+SHIFT+E"
         contextId="org.eclipse.ui.textEditorScope"/>
    <key commandId="hi.bxm.assist.fixError"
         schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
         sequence="ALT+SHIFT+F"
         contextId="org.eclipse.ui.textEditorScope"/>
    <key commandId="hi.bxm.assist.refactor"
         schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
         sequence="ALT+SHIFT+R"
         contextId="org.eclipse.ui.textEditorScope"/>
    <key commandId="hi.bxm.assist.triggerInline"
         schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
         sequence="CTRL+ALT+SPACE"
         contextId="org.eclipse.ui.textEditorScope"/>
    <!-- [신규] TODO 코드 생성 -->
    <key commandId="hi.bxm.assist.generateTodo"
         schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
         sequence="ALT+SHIFT+T"
         contextId="org.eclipse.ui.textEditorScope"/>
  </extension>

  <!-- 6. JDT 자동완성 (Ctrl+Space 팝업) -->
  <!--
    Eclipse 4.5.2 에서 동작하는 정확한 구조:
    - proposalCategory 와 javaCompletionProposalComputer 를 같은 extension 에 선언
    - partition 미지정: 모든 Java 파티션(__java_code, __java_string, default)에서 동작
    - needsSortingAfterFiltering="false": 정렬 불필요 (AI 제안은 항상 맨 위로)
    - requiresUIThread="false": 백그라운드 스레드에서 computeCompletionProposals() 호출 허용
    - activate="true": 카테고리를 기본 활성 상태로 등록
      (false 이면 Advanced 탭에서 수동 활성화 필요)
  -->
  <extension
      id="hi.bxm.assist.aiCompletion"
      point="org.eclipse.jdt.ui.javaCompletionProposalComputer">
    <proposalCategory
        id="hi.bxm.assist.proposalCategory"
        label="BXM Assist"
        icon="icons/assist_ai_16.png"/>
    <javaCompletionProposalComputer
        class="hi.bxm.assist.editor.completion.AICompletionProcessor"
        categoryId="hi.bxm.assist.proposalCategory"
        needsSortingAfterFiltering="true"
        requiresUIThread="false">
    </javaCompletionProposalComputer>
  </extension>


  <!-- 7. 시작 시 자동완성 주입 + Ghost Text 컨트롤러 install -->
  <extension
      id="hi.bxm.assist.startups"
      point="org.eclipse.ui.startup">
    <startup class="hi.bxm.assist.editor.ghost.InlineCompletionStartup"/>
  </extension>

  <!-- 8. Java 호버 -->
  <extension
      id="hi.bxm.assist.aiHovers"
      point="org.eclipse.jdt.ui.javaEditorTextHovers">
    <hover id="hi.bxm.assist.aiHover"
           class="hi.bxm.assist.editor.hover.AIHoverProvider"
           label="AI Code Explanation"/>
  </extension>

  <!-- 9. Quick Fix -->
  <extension
      id="hi.bxm.assist.aiMarkerResolution"
      point="org.eclipse.ui.ide.markerResolution">
    <markerResolutionGenerator
        markerType="org.eclipse.jdt.core.problem"
        class="hi.bxm.assist.editor.quickfix.AIMarkerResolutionGenerator"/>
    <markerResolutionGenerator
        markerType="org.eclipse.jdt.core.task"
        class="hi.bxm.assist.editor.quickfix.AIMarkerResolutionGenerator"/>
    <markerResolutionGenerator
        markerType="org.eclipse.core.resources.problemmarker"
        class="hi.bxm.assist.editor.quickfix.AIMarkerResolutionGenerator"/>
  </extension>

  <!-- 10. Preferences -->
  <extension point="org.eclipse.ui.preferencePages">
    <page id="hi.bxm.assist.preferences"
          name="BXM AI Assist"
          class="hi.bxm.assist.ui.prefs.AssistPreferencePage"/>
  </extension>
  <extension point="org.eclipse.core.runtime.preferences">
    <initializer class="hi.bxm.assist.ui.prefs.PreferenceInitializer"/>
  </extension>

</plugin>
	