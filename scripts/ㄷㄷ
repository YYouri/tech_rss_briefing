import java.util.List;
import java.util.Map;

import jakarta.xml.bind.annotation.XmlRootElement;
import jakarta.xml.bind.annotation.XmlType;

import com.fasterxml.jackson.annotation.JsonIgnore;

import bxm.omm.annotation.BxmOmm_Field;
import bxm.omm.predict.FieldInfo;
import bxm.omm.predict.Predictable;
import jef.application.entity.BusinessVO;

/**
 * int 데이터를 화면에 보낼 응답 문자열로 변환하고자 할 때 데이터를 저장하는 클래스이다.
 *
 * @author Framework Team
 *
 */
@XmlType(propOrder={"data"}, name="HiIntegerVO")
@XmlRootElement(name="IntegerVO")
@SuppressWarnings("all")
public class IntegerVO extends BusinessVO implements Predictable {

	private static final long serialVersionUID = 1L;

	@BxmOmm_Field(referenceType="reference", description="data", formatType="", format="", align="left", length=8, decimal=0, arrayReference="", fill="", comment="0 ~ 7", encrypt="", validationRule="")
	private int data;

	/**
	 * 생성자
	 *
	 */
	public IntegerVO() {
	}

	/**
	 * 생성자
	 *
	 * @param data
	 */
	public IntegerVO(int data) {
		this.data = data;
	}

	/**
	 * int 데이터를 반환한다.
	 *
	 * @return int
	 */
	public int getData() {
		return data;
	}

	/**
	 * int 데이터를 설정한다.
	 *
	 * @param data 데이터
	 */
	public void setData(int data) {
		this.data = data;
	}

	@Override
	@JsonIgnore
	public long predictMessageLength() {
		return 0;
	}

	@Override
	public IntegerVO clone(){
		try{
			IntegerVO object= (IntegerVO)super.clone();
			object.data = this.data;
			return object;
		} 
		catch(CloneNotSupportedException e){
			throw new bxm.omm.exception.CloneFailedException();
		}
	}
}