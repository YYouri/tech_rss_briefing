public class CommitActionFactory
extends BxmCommitParticipant
{
	final Logger logger = LoggerFactory.getLogger(this.getClass());
	protected final static String bxmNatureId = BxmProjectNature.NATURE_ID;
	public final static String bxmWebProjectNatureId= "bxm.nature.webProjectNature";

	protected final static String libraryDir = "lib";
	protected final static String sourceDir = "src";
	protected final static String metainfDir = "META-INF";
	protected final static String dbioFileExtension = "dbio";
	protected final static String ommFileExtension = "omm";
	protected final static String jarFileExtension  = "jar";
	protected final static String javaFileExtension = "java";
	protected final static String wsdlFileExtension = "wsdl";
	protected final static String parFileExtension = "par";
	protected IProject project = null;
	protected IPath homeLocation = null;
	protected List<IPath> srcPathList = null;
	protected IPath classPath = null;
	protected IPath classLocation = null;

	class DeployRunnable implements IRunnableWithProgress{
		private List<BxmPropertiesModel> propertiesList;
		private IResource[] resourcesToAdd;
		private IResource[] resourcesToModify;
		private IResource[] resourcesToDelete;

		private String errorMessage= null;


		public DeployRunnable(
				List<BxmPropertiesModel> propertiesList
				, IResource[] resourcesToAdd
				, IResource[] resourcesToModify
				, IResource[] resourcesToDelete
				){
			this.propertiesList= propertiesList;
			this.resourcesToAdd= resourcesToAdd;
			this.resourcesToModify= resourcesToModify;
			this.resourcesToDelete= resourcesToDelete;
		}

		@Override
		public void run(IProgressMonitor monitor)
				throws InvocationTargetException, InterruptedException {
			try {
				System.out.println(">> resourcesToAdd : " + resourcesToAdd.length);
				System.out.println(">> resourcesToModify : " + resourcesToModify.length);
				System.out.println(">> resourcesToDelete : " + resourcesToDelete.length);

				DeployExecutorManager.instance().execute(project, propertiesList, resourcesToAdd, resourcesToModify, resourcesToDelete,
						monitor
						);
				
				/**
				 * HDS : TODO : 빌드 요청
				 */
				if(ConfigurationUtils.getConfiguration().isUseServerBuild())
				{
					BuildRequest br= new BuildRequest();
					br.request(project, resourcesToAdd, resourcesToModify, resourcesToDelete);
				}
				
			} catch (Exception e) {
				e.printStackTrace();
				errorMessage= e.getMessage();
			}
		}

		public String getErrorMessage() {
			return errorMessage;
		}
	}

	@Override
	public void performAfterCommitTasks(
			Object preProcessResult,
			CompositeOperation compositeOperation,
			IRevisionProvider revisionProvider,
			IActionOperation[] actionOperation,
			IWorkbenchPart part)
	{
		logger.trace("CommitActionFactory#performAfterCommitTasks");
		ICommentDialogPanel panel= BxmCommitFactory.panel;
		logger.debug("message!!!!!!!!!!!!!!!!= {}", panel.getMessage());

		CommitHelper svnCommitHelper = new CommitHelper();
		IResource[] resourcesToCommit =
				svnCommitHelper.getResourcesToCommit(compositeOperation, revisionProvider);
		if (resourcesToCommit.length == 0) {
			logger.debug("커밋대상 리소스가 존재하지 않습니다.");
			return;
		}

		if (logger.isDebugEnabled()) {
			for (IResource res: resourcesToCommit) {
				logger.debug("CommitDialog 에서 전달된 커밋대상= {}", res);
			}
		}

		project = resourcesToCommit[0].getProject();
//		try {
//			project = resourcesToCommit[0].getProject();
//			homePath = project.getFullPath();
//			homeLocation = project.getLocation();
//			workspaceLocation = project.getWorkspace().getRoot().getLocation();
//			srcPathList = ResourceUtil.getClasspathCpeSource(project);
//			classPath = ResourceUtil.getClassOutputLocation(project);
//			classPath = classPath.removeFirstSegments(1);
//			classLocation = homeLocation.append(classPath);
//		} catch (JavaModelException e) {
//			BuilderLog.logError(e);
//		}

		boolean cont= false;

		// Bxm Project 가 아니면 종료.
		try {
			if ( project.hasNature(bxmNatureId)
					|| project.hasNature(bxmWebProjectNatureId)
					){
				cont= true;
			}
			else{
				List<String> natureIds= BuilderActivator.getDefault().getConfiguration().getProjectNatureForCommitAllow();

				for (String natureId : natureIds) {
					if ( project.hasNature(natureId) ){
						cont= true;
						break;
					}
				}
			}
		} catch (CoreException e) {
			BuilderLog.logError(e);
			cont=false;
		}
		logger.debug("커밋 진행 여부= {}", cont);
		if ( !cont ){
			return;
		}

//		FLD 사용 하므로 사용 안함
//		List<BxmPropertiesModel> propertiesList = PlatformUtil.getPropertiesConfigAll(project);
		List<BxmPropertiesModel> propertiesList = new ArrayList<BxmPropertiesModel>();
		CommonDeployModel commonConfig= null;
		
		try {
			commonConfig= PlatformUtil.getCommonDeployConfig(project);
		} catch (Throwable e) {
			/**
			 * 웹자원
			 */
			commonConfig= new CommonDeployModel();
		}

		IResource[] resourcesToAdd = FileUtility.getResourcesRecursive(resourcesToCommit, IStateFilter.SF_ADDED, 0);
		IResource[] resourcesToModify = FileUtility.getResourcesRecursive(resourcesToCommit, IStateFilter.SF_MODIFIED, 0);
		IResource[] resourcesToDelete = FileUtility.getResourcesRecursive(resourcesToCommit, IStateFilter.SF_DELETED, 0);
		if (logger.isDebugEnabled()) {
			for (IResource res: resourcesToAdd) {
				logger.debug("신규 리소스 커밋 대상= {}", res);
			}
			for (IResource res: resourcesToModify) {
				logger.debug("수정 리소스 커밋 대상= {}", res);
			}
			for (IResource res: resourcesToDelete) {
				logger.debug("삭제 리소스 커밋 대상= {}", res);
			}
		}

		/**
		 * omm 파일이 커밋 대상이면 omm source gen 파일도 같이 커밋
		 */
		CommitOperation commitOperation = getCommitOperation(compositeOperation);
		replaceResources(commitOperation, resourcesToCommit);
		AddToSVNWithPropertiesOperation addToSVNWithPropertiesOperation = getAddToSVNWithPropertiesOperation(compositeOperation);
		ClearLocalStatusesOperation clearLocalStatusesOperation = getClearLocalStatusesOperation(compositeOperation);
		if (addToSVNWithPropertiesOperation == null) {
			addToSVNWithPropertiesOperation = new AddToSVNWithPropertiesOperation(resourcesToAdd);
			compositeOperation.add(addToSVNWithPropertiesOperation);

			clearLocalStatusesOperation = new ClearLocalStatusesOperation(resourcesToAdd);
			compositeOperation.add(clearLocalStatusesOperation);
		}
		else {
			replaceResources(addToSVNWithPropertiesOperation, resourcesToAdd);
			replaceResources(clearLocalStatusesOperation, resourcesToAdd);
		}
		// OutDatedFiles 이 있으면 종료.
		Set<IResource> svnCommitFiles = svnCommitHelper.getIResources(resourcesToCommit);

		Set<IResource> svnOutDatedFiles = svnCommitHelper.getOutdatedFiles(svnCommitFiles);

		if (svnOutDatedFiles.size() > 0) {
			String msg= "";
			Iterator<IResource> iter= svnOutDatedFiles.iterator();
			while (iter.hasNext()) {
				String name= iter.next().getName();
				msg+=  "File '" +name+ "' is out of date.\n";
			}
			MessageDialog.openError(msg);
			removeAllOperations(compositeOperation);
			return;
		}
		// Locked Files 이 있으면 종료.
		Map<String, SVNLock> svnLockMap= svnCommitHelper.getSvnLockInfo();
		if (svnLockMap.size() > 0) {
			String msg= "";
			Iterator<String> iter= svnLockMap.keySet().iterator();
			while (iter.hasNext()) {
				String key= iter.next();
				SVNLock value= svnLockMap.get(key);
				msg+= "File '" +key+ "' is locked. Owner[" + value.owner + "]\n";
			}
			MessageDialog.openError(msg);
			removeAllOperations(compositeOperation);
			return;
		}

		// 리소스 상태가 Replace 상태일 경우에 필요
		sortCompositeOperation(compositeOperation);
		// 커밋 테스트 할때 주석해제

		/**
		 * 2013.05.30 changyoung.shin update
		 * SVN 커밋없이 디플로이가 실행되도록 변경
		 * SVN 커밋은 디플로이가 끝나면 SVN이 자동으로 실행함.
		 */

		/**
		 * 2013.07.21 PARK.Jeongyeob
		 * 사이트 요청으로 코드를 수정하는데 기존에 잘 돌던 deploy 메소드를 수정하면 발생할
		 * 잠재적 위험에 대비하기 위해
		 * 아래 옵션이 true 인 경우에 새로 작성한 코드가 수행되고, false 인 경우에 기존 코드가 그대로 동작합니다.
		 *
		 */

		/* 15.03.17
		 * SVN 계정 정보가 없는 경우(또는 틀린경우) SVN Plug-in 에서 계정정보를 입력하라고 뜸.
		 * 이때 Cancel 을 진행하거나, 계정 정보를 잘못 입력하고 OK 를 누를 경우 디플로이가 실행됨.
		 *
		 * 기본적인 커밋&배포 순서는
		 *
		 * 1. 배포
		 *
		 * 2. SVN 커밋
		 *
		 * 인데, 배포를 먼저 하고 SVN 커밋을 하기 때문에 SVN 커밋 과정에서 계정정보가 잘못된 경우에는 배포만 되고
		 * 커밋이 안되게 되어 있음.
		 */

		if(commonConfig.isDeployable())
		{
			DeployRunnable runnable= new DeployRunnable(propertiesList, resourcesToAdd, resourcesToModify, resourcesToDelete);

			ProgressMonitorDialog dialog= new ProgressMonitorDialog(part.getSite().getShell());
			try {
				dialog.run(false, true, runnable);

				if ( runnable.getErrorMessage() != null ){
//					MessageDialog.openError(runnable.getErrorMessage());
//					removeAllOperations(compositeOperation);
					MessageDialog.openError("deploy error : [" + runnable.getErrorMessage() + "]");
				}
			} catch (Exception e) {
				e.printStackTrace();
			}
		}
	}


	/**
	 * targetFullPath= apphome/targetBasePath/targetFilePackage/targetFileName
	 * @param deployer
	 * @param mode
	 * @param targetBasePath
	 * @param targetFilePackage
	 * @param sourceAbsolutePath
	 * @param targetFileName
	 * @throws Exception
	 */
	@SuppressWarnings("unchecked")
	public<K, V> void ftpDeployExecute(
			ICommonDeployer deployer,
			int mode,
			K sourceAbsolutePath,
			String targetBasePath,
			String targetFilePackage,
			V targetFileName) throws Throwable
	{
		try {
			boolean result = false;
			if (!deployer.cdAppHomeDir()) {
				BuilderLog.logError("Application home directory failed to move...", null);
				return;
			}

			if (!deployer.cd(targetBasePath)) {
				BuilderLog.logError("Target base directory failed to move...", null);
				return;
			}

			if (!deployer.cd(targetFilePackage.toString())) {
				BuilderLog.logError("Target package directory failed to move...", null);
				return;
			}

			/**
			 * 2013.02.18 changyoung.shin update
			 * innerClass 존재 가능성으로 인한 삭제로직 추가
			 */
			String fileName= null;
			if (targetFileName instanceof String) {
				fileName= (String)targetFileName;
			} else {
				fileName= ((List<String>)targetFileName).get(0);
			}

			int index= fileName.indexOf(".class");
			if( index > 0) {
				fileName= fileName.substring(0, index);
				List<String> fileList= deployer.list(fileName + "$*.class");
				if (fileList.size() > 0) {
					result = deployer.removeAll((List<String>)fileList);
					if (!result) {
						BuilderLog.logError("Exception occurred during FTP Upload task.", null);
						return;
					}
				}
			}
			/**
			 * 2013.02.18 changyoung.shin update
			 * end
			 */

			if (sourceAbsolutePath instanceof String) {
				switch (mode) {
				case BuilderConstants.COMMIT_STATS_ADDED:
				case BuilderConstants.COMMIT_STATS_MODIFIED:
					result = deployer.put((String)sourceAbsolutePath, (String)targetFileName);
					break;
				case BuilderConstants.COMMIT_STATS_DELETED:
					result = deployer.remove((String)targetFileName);
					break;
				default: break;
				}
			} else {
				switch (mode) {
				case BuilderConstants.COMMIT_STATS_ADDED:
				case BuilderConstants.COMMIT_STATS_MODIFIED:
					result = deployer.putAll((List<String>)sourceAbsolutePath, (List<String>)targetFileName);
					break;
				case BuilderConstants.COMMIT_STATS_DELETED:
					result = deployer.removeAll((List<String>)targetFileName);
					break;
				default: break;
				}
			}

			if (!result) {
				BuilderLog.logError("Exception occurred during FTP Upload task.", null);
			}
		} catch( Throwable th) {
			throw th;
		}
	}


	@SuppressWarnings("unchecked")
	private static CommitOperation getCommitOperation(CompositeOperation compositeOperation) {
		CommitOperation commitOperation = null;

		try {
			// get operations from CompositeOperation class through reflection
			Field declaredFieldOperationList = CompositeOperation.class.getDeclaredField("operations");
			declaredFieldOperationList.setAccessible(true);

			List<Object> operationPairList =
					(List<Object>) declaredFieldOperationList.get(compositeOperation);

			for (Object operationPair : operationPairList) {
				Field operationField = operationPair.getClass().getField("operation");
				IActionOperation operation = (IActionOperation) operationField.get(operationPair);
				if (operation instanceof CommitOperation) {
					commitOperation = (CommitOperation) operation;
				}
			}
		}
		catch (Exception e) {
			BuilderLog.logError(e);
		}
		return commitOperation;
	}

	@SuppressWarnings("unchecked")
	private static ClearLocalStatusesOperation getClearLocalStatusesOperation(CompositeOperation compositeOperation) {
		ClearLocalStatusesOperation clearLocalStatusesOperation = null;

		try {
			// get operations from CompositeOperation class through reflection
			Field declaredFieldOperationList = CompositeOperation.class.getDeclaredField("operations");
			declaredFieldOperationList.setAccessible(true);

			List<Object> operationPairList =
					(List<Object>) declaredFieldOperationList.get(compositeOperation);

			for (Object operationPair : operationPairList) {
				Field operationField = operationPair.getClass().getField("operation");
				IActionOperation operation = (IActionOperation) operationField.get(operationPair);
				if (operation instanceof ClearLocalStatusesOperation) {
					clearLocalStatusesOperation = (ClearLocalStatusesOperation) operation;
				}
			}
		}
		catch (Exception e) {
			BuilderLog.logError(e);
		}
		return clearLocalStatusesOperation;
	}

	@SuppressWarnings("unchecked")
	private static AddToSVNWithPropertiesOperation getAddToSVNWithPropertiesOperation(CompositeOperation compositeOperation) {
		AddToSVNWithPropertiesOperation addToSVNWithPropertiesOperation = null;

		try {
			// get operations from CompositeOperation class through reflection
			Field declaredFieldOperationList = CompositeOperation.class.getDeclaredField("operations");
			declaredFieldOperationList.setAccessible(true);

			List<Object> operationPairList =
					(List<Object>) declaredFieldOperationList.get(compositeOperation);

			for (Object operationPair : operationPairList) {
				Field operationField = operationPair.getClass().getField("operation");
				IActionOperation operation = (IActionOperation) operationField.get(operationPair);
				if (operation instanceof AddToSVNWithPropertiesOperation) {
					addToSVNWithPropertiesOperation = (AddToSVNWithPropertiesOperation) operation;
				}
			}
		}
		catch (Exception e) {
			BuilderLog.logError(e);
		}
		return addToSVNWithPropertiesOperation;
	}

	private void replaceResources(Object commitOperation, IResource[] allFiles) {
		try {
			// get operations from CompositeOperation class through reflection
			Field declaredFieldResources = AbstractWorkingCopyOperation.class.getDeclaredField("resources");
			declaredFieldResources.setAccessible(true);
//			declaredFieldResources.set(commitOperation, allFiles.toArray(new IResource[0]));
			declaredFieldResources.set(commitOperation, allFiles);
		}
		catch (Exception e) {
			BuilderLog.logError(e);
		}
	}

	@SuppressWarnings("unchecked")
	private static void removeAllOperations(CompositeOperation compositeOperation) {
		try {
			// get operations from CompositeOperation class through reflection
			Field declaredFieldOperationList = CompositeOperation.class.getDeclaredField("operations");
			declaredFieldOperationList.setAccessible(true);

			List<Object> operationPairList = (List<Object>) declaredFieldOperationList.get(compositeOperation);
			List<IActionOperation> operationsToRemove = new ArrayList<IActionOperation>();
			for (Object operationPair : operationPairList) {
				Field operationField = operationPair.getClass().getField("operation");
				IActionOperation operation = (IActionOperation) operationField.get(operationPair);
				operationsToRemove.add(operation);
			}

			// remove now these operations from the CompositeOperation
			Iterator<IActionOperation> operationsToRemoveIterator = operationsToRemove.iterator();
			while (operationsToRemoveIterator.hasNext()) {
				compositeOperation.remove(operationsToRemoveIterator.next());
			}
		}
		catch (Exception e) {
			BuilderLog.logError(e);
		}
	}

	@SuppressWarnings("unused")
	protected IPath getLocalPath(IResource resource) {
		String sourceAbsolutePath = resource.getLocation().toString();
		IPath fullPath = resource.getFullPath();
		for (IPath srcPath : srcPathList) {
			boolean isPrefix = srcPath.isPrefixOf(fullPath);
			if (isPrefix) {
				int count = srcPath.matchingFirstSegments(fullPath);
				IPath filePath = fullPath.removeFirstSegments(count);
			}
		}
		return null;
	}

	public void sortCompositeOperation(CompositeOperation compositeOperation) {
		Map<Integer, IActionOperation> sortMap= new HashMap<Integer, IActionOperation>();

		int fAddToSVNWithProperties= 0;
		int fClearLocalStatuses= 1;
		int fCommit= 2;
		int fClearUpdateStatuses= 3;
		int fRefreshResources= 4;
		int fNotifyUnresolvedConflict= 5;
		sortMap.put(fAddToSVNWithProperties, null);
		sortMap.put(fClearLocalStatuses, null);
		sortMap.put(fCommit, null);
		sortMap.put(fClearUpdateStatuses, null);
		sortMap.put(fRefreshResources, null);
		sortMap.put(fNotifyUnresolvedConflict, null);

		try {
			// get operations from CompositeOperation class through reflection
			Field declaredFieldOperationList = CompositeOperation.class.getDeclaredField("operations");
			declaredFieldOperationList.setAccessible(true);

			@SuppressWarnings("unchecked")
			List<Object> operationPairList = (List<Object>) declaredFieldOperationList.get(compositeOperation);

			for (Object operationPair : operationPairList) {
				Field operationField = operationPair.getClass().getField("operation");
				IActionOperation operation = (IActionOperation) operationField.get(operationPair);

				if (operation instanceof AddToSVNWithPropertiesOperation) {
					sortMap.put(fAddToSVNWithProperties, operation);
				} else if (operation instanceof ClearLocalStatusesOperation) {
					sortMap.put(fClearLocalStatuses, operation);
				} else if (operation instanceof CommitOperation) {
					sortMap.put(fCommit, operation);
				} else if (operation instanceof ClearUpdateStatusesOperation) {
					sortMap.put(fClearUpdateStatuses, operation);
				} else if (operation instanceof RefreshResourcesOperation) {
					sortMap.put(fRefreshResources, operation);
				} else if (operation instanceof NotifyUnresolvedConflictOperation) {
					sortMap.put(fNotifyUnresolvedConflict, operation);
				}
			}

			// remove now these operations from the CompositeOperation
			for ( int i = 0 ; i < sortMap.size() ; i++ ) {
				compositeOperation.remove(sortMap.get(i));
			}

			// add now these operations to the CompositeOperation
			for ( int i = 0 ; i < sortMap.size() ; i++ ) {
				compositeOperation.add(sortMap.get(i));
			}
		}
		catch (Exception e) {
			BuilderLog.logError(e);
		}
	}
}