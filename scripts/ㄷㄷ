        <rule name="UseStringReplace" since="2.1" 
        		language="java"
                message="String 클래스의 replace 사용"
                class="net.sourceforge.pmd.lang.rule.XPathRule"
                externalInfoUrl="http://developer.cis.co.kr/support/pmd/UseStringReplace.html"> 
 
                <description> 
