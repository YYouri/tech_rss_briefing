public class BxmProjectWizard extends BxmNewElementWizard
implements IExecutableExtension
{
	final Logger logger = LoggerFactory.getLogger(this.getClass());
	protected final String defaultCharEncoding = BuilderConstants.CHARSET_DEFAULT;

	private BxmNewJavaProjectWizardPageOne fFirstPage;
	private NewJavaProjectWizardPageTwo fSecondPage;

	private IConfigurationElement fConfigElement;

	public BxmProjectWizard()
	{
		super("New BXM Project Wizard");
		setDialogSettings(JavaPlugin.getDefault().getDialogSettings());
	}

	@Override
	public void addPages() {

		if (fFirstPage == null)
			fFirstPage = new BxmNewJavaProjectWizardPageOne();
		fFirstPage.setTitle(BuilderMessages.NEW_BXM_WIZARD_PAGE_1_TITLE);
		fFirstPage.setDescription(BuilderMessages.NEW_BXM_WIZARD_PAGE_1_DESC);
		addPage(fFirstPage);

		if (fSecondPage == null)
			fSecondPage = new NewJavaProjectWizardPageTwo(fFirstPage);

		fFirstPage.init(getSelection(), getActivePart());
	}

	@Override
	protected void finishPage(IProgressMonitor monitor)
			throws InterruptedException, CoreException {
		logger.trace("BxmProjectWizard#finishPage");
		EclipseUtils.syncExec(new Runnable() {
			@Override
			public void run() {
				try {
					// 두번째 페이지 추가를 빼면서 SWT Thread Error 발생 때문에 Runnable()로 구현함.
					fSecondPage.performFinish(new NullProgressMonitor());// use the full progress monitor
				} catch (CoreException e) {
					e.printStackTrace();
				} catch (InterruptedException e) {
					e.printStackTrace();
				}
			}
		});
		addNature(fSecondPage.getJavaProject().getProject(), monitor);
		createDefaultResource(fSecondPage.getJavaProject().getProject(), monitor);
		configureClasspath(fSecondPage.getJavaProject().getProject(), monitor);
		setDefaultCharSet(fSecondPage.getJavaProject(), monitor);
		
		/**
		 * 온라인 로컬 테스트 관련 리소스
		 */
		if(fFirstPage.isOnline()) 
		{
			createLocalTestResource(fSecondPage.getJavaProject().getProject(), monitor);
			createLocalDevHelpScriptFile(fSecondPage.getJavaProject().getProject(), monitor);
		}
		createUpdateLibraryGradleScriptFile(fSecondPage.getJavaProject().getProject(), fFirstPage.isOnline(), monitor);
		
		configureDefaultPackages(fSecondPage.getJavaProject(), monitor);
		configureDefaultFolders(fSecondPage.getJavaProject(), monitor);
	}
	
	private void createUpdateLibraryGradleScriptFile(IProject project, boolean isOnline, IProgressMonitor monitor)
	{
		String contents= "";
		
		try {
			contents= getGradleScriptContents(project, isOnline);
		} catch (Exception e) {
			MessageDialog.openWarn(e.getMessage());
			return;
		}
		
		String charSet= BXMUtils.getCurrentCharSet(project);
		IFile script= project.getFile("build.gradle");
		InputStream inStrm= null;
		
		try {
			inStrm= new ByteArrayInputStream(contents.getBytes(charSet));
			script.create(inStrm, IFile.FORCE, monitor);
		} catch (UnsupportedEncodingException | CoreException e) {
			MessageDialog.openWarn(e.getMessage());
			return;
		}
	}
	
	private String getGradleScriptContents(IProject project, boolean isOnline) throws Exception
	{
		final String tmplName= "update_library_gradle_script_template";
		
		String tmplContents= 
				TemplateManager.instance().getTemplateContents(tmplName);
		
		TemplateParserDelegator p= new TemplateParserDelegator();
		
		p.addCtxt("FRAMEWORK_LIBRARY_DIRECTORY", getFrameworkLibDir(isOnline));
		p.addCtxt("APPLICATION_LIBRARY_DIRECTORY", getApplicationLibDir(isOnline));
		
		p.parse(tmplContents);
		
		return p.getResult();
	}
	
	private String getApplicationLibDir(boolean isOnline)
	{
		String appLibDir= "";
		
		if(isOnline) {
			appLibDir= BxmConstants.WEB_CONTENT_FOLDER + "/" + BxmConstants.WEB_CONTENT_WEB_INF_FOLDER + "/";
		}
		
		appLibDir= appLibDir + BxmConstants.LIB_FOLDER_NAME_3RD_PARTY;
		
		return appLibDir;
	}
	
	private String getFrameworkLibDir(boolean isOnline)
	{
		String fwLibDir= "";
		
		if(isOnline) {
			fwLibDir= BxmConstants.WEB_CONTENT_FOLDER + "/" + BxmConstants.WEB_CONTENT_WEB_INF_FOLDER + "/";
		}
		
		fwLibDir= fwLibDir + BxmConstants.WEB_CONTENT_FRAMEWORK_LIB_FOLDER;
		
		return fwLibDir;
	}
	
	private void createLocalDevHelpScriptFile(IProject project, IProgressMonitor monitor)
	{
		String contents= "";
		
		try {
			contents= getScriptContents(project);
		} catch (Exception e) {
			MessageDialog.openWarn(e.getMessage());
			return;
		}
		
		String charSet= BXMUtils.getCurrentCharSet(project);
		IFile script= project.getFile("build.xml");
		InputStream inStrm= null;
		
		try {
			inStrm= new ByteArrayInputStream(contents.getBytes(charSet));
			script.create(inStrm, IFile.FORCE, monitor);
		} catch (UnsupportedEncodingException | CoreException e) {
			MessageDialog.openWarn(e.getMessage());
			return;
		}
	}
	
	private String getScriptContents(IProject project) throws Exception
	{
		final String tmplName= "local_helper_script_template";
		
		String tmplContents= 
				TemplateManager.instance().getTemplateContents(tmplName);
		
		TemplateParserDelegator p= new TemplateParserDelegator();
		p.addCtxt("PROJECT_UPCASE_NAME", project.getName());
		p.addCtxt("PROJECT_LOWCASE_NAME", project.getName().toLowerCase());
		p.addCtxt("REFERENCE_PROJECT_NAME", BuilderProperties.instance().getReferenceProjectName());
		p.addCtxt("WEB_PROJECT_NAME", BuilderProperties.instance().getWebReferenceProjectName());
		p.parse(tmplContents);
		
		return p.getResult();
	}

	@Override
	public boolean performFinish() {
		logger.trace("BxmProjectWizard#performFinish");
		boolean res = super.performFinish();
		if (res) {

			final IJavaElement newElement = getCreatedElement();

			IWorkingSet[] workingSets = fFirstPage.getWorkingSets();
			if (workingSets.length > 0) {
				PlatformUI.getWorkbench().getWorkingSetManager().
				addToWorkingSets(newElement, workingSets);
			}

			BasicNewProjectResourceWizard.updatePerspective(fConfigElement);
			selectAndReveal(fSecondPage.getJavaProject().getProject());

			String propertyName= fFirstPage.getNewProjectPropertyName();
			Properties properties= fFirstPage.getNewProjectProperties();

			if( propertyName!= null && properties != null ){
				try {
					BXMUtils.setProjectProperties(fSecondPage.getJavaProject().getProject(), propertyName, properties, false, new NullProgressMonitor());
				} catch (Exception e) {
					e.printStackTrace();
				}
			}

			Display.getDefault().asyncExec(new Runnable() {
				public void run() {
					IWorkbenchPart activePart = getActivePart();
					if (activePart instanceof IPackagesViewPart) {
						PackageExplorerPart view = PackageExplorerPart.
								openInActivePerspective();
						view.tryToReveal(newElement);
					}
				}
			});
		}
		return res;
	}

	private IWorkbenchPart getActivePart() {
		IWorkbenchWindow activeWindow = getWorkbench().getActiveWorkbenchWindow();
		if (activeWindow != null) {
			IWorkbenchPage activePage = activeWindow.getActivePage();
			if (activePage != null) {
				return activePage.getActivePart();
			}
		}
		return null;
	}

	@Override
	protected void handleFinishException(Shell shell, InvocationTargetException e)
	{
		String title = NewWizardMessages.JavaProjectWizard_op_error_title;
		String message = NewWizardMessages.JavaProjectWizard_op_error_create_message;
		ExceptionHandler.handle(e, getShell(), title, message);
	}

	@Override
	public void setInitializationData(IConfigurationElement cfig, String propertyName,
			Object data) throws CoreException {
		fConfigElement = cfig;

	}

	@Override
	public boolean performCancel()
	{
		this.fSecondPage.performCancel();
		return super.performCancel();
	}

	@Override
	public IJavaElement getCreatedElement() {
		return fSecondPage.getJavaProject();
	}

	/**
	 * Project에 Nature 추가
	 * @param project
	 */
	private void addNature(IProject project, IProgressMonitor monitor) {
		BxmProjectNature.addNatureToProject(project, monitor);
	}

	/**
	 * 기본 리소스 생성
	 */
	private void createDefaultResource(IProject project, IProgressMonitor monitor) {
		String description= fFirstPage.getCategoryLogicalName();

		InputStream inputStream = new ByteArrayInputStream(
				ResourceUtil.getBaseBxmApplication(
						project
						, fFirstPage.isOnline()
						, StringUtils.isEmpty(description)?project.getName():description
						)
				);
		try {
			// 기본 디렉토리 만들기
			for (int i=0 ; i<BuilderConstants.SYSTEM_FOLDERS.length ; i++) 
			{
				if(BuilderConstants.SYSTEM_FOLDERS[i].equals(BuilderConstants.SOURCE_GEN_FOLDER)) {
					if( !ConfigurationUtils.getConfiguration().getGenOmmJavaInSrcGen() ) {
						continue;
					}
				}
				
				IFolder folder = project.getFolder(BuilderConstants.SYSTEM_FOLDERS[i]);
				ResourceUtil.ensureFolderExists(folder, Policy.subMonitorFor(monitor, 1));
			}
			
			String ommPfr= ConfigurationUtils.getConfiguration().getOmmPfr();
			if( !BxmConstants.SRC_FOLDER_NAME.equals(ommPfr) )
			{
				IFolder folder= project.getFolder(ommPfr);
				ResourceUtil.ensureFolderExists(folder, Policy.subMonitorFor(monitor, 1));
			}
		
			/* 온라인, 배치 모두 config 폴더 필요 */
//			if( !fFirstPage.isOnline() )
			{
				IFolder folder= project.getFolder(BxmConstants.CONFIG_FOLDER);
				ResourceUtil.ensureFolderExists(folder, Policy.subMonitorFor(monitor, 1));
			}
			
			if( !fFirstPage.isOnline() )
			{
				IFolder cLib= project.getFolder(BxmConstants.WEB_CONTENT_FRAMEWORK_LIB_FOLDER);
				ResourceUtil.ensureFolderExists(cLib, Policy.subMonitorFor(monitor, 1));
				
				IFolder lib= project.getFolder(BxmConstants.LIB_FOLDER_NAME_3RD_PARTY);
				ResourceUtil.ensureFolderExists(lib, Policy.subMonitorFor(monitor, 1));
			}
			
			// 기본 파일 만들기
			IPath path = BuilderConstants.METAINF_FOLDER.append(BuilderConstants.APPLICATION_METAFILE_NAME);
			IFile file = project.getFile(path);
			file.create(inputStream, true, monitor);
			
			/**
			 * @author taehoon.kim
			 * @date 2016.06.02
			 * 로컬 개발 환경이 구성될 경우 gradle script 파일을 자동 생성합니다.
			 * -> HDS는 gradle 사용 안함
			 */
//			if(BuilderProperties.instance().isUseLocalDevEnv())
//			{
//				IBuildScriptCreator creator = new LocalDevBuildScriptCreator();
//				creator.create(project);
//			}

			BuilderConfiguration configuration= BuilderActivator.getDefault().getConfiguration();

			BxmPropertiesModel bxmPropertiesModel= new BxmPropertiesModel();

			String protocol= StringUtils.nvl(configuration.getFtpDeployProtocol());
			String deployIp= StringUtils.nvl(configuration.getFtpDeployIp());
			String deployPort= StringUtils.nvl(configuration.getFtpDeployPort());
			String id= StringUtils.nvl(configuration.getFtpDeployId());
			String encPassword= StringUtils.nvl(configuration.getFtpDeployEncPassword());
			String endpointURL= StringUtils.nvl(configuration.getDefaultEndpointURL());

			bxmPropertiesModel.setName("Default");
			bxmPropertiesModel.setProtocol(protocol);
			bxmPropertiesModel.setIp(deployIp);
			bxmPropertiesModel.setPort(deployPort);
			bxmPropertiesModel.setId(id);
			bxmPropertiesModel.setPassword(Base64Util.decode(encPassword));
			bxmPropertiesModel.setEndPointUrl(endpointURL);

			String appHomeLocation= configuration.getFtpDeployAppHomeLocation();
			if ( !StringUtils.isEmpty(appHomeLocation) ){
				if ( appHomeLocation.endsWith("/")){
					appHomeLocation= appHomeLocation+ BXMUtils.getApplicationName(project);
				}
				else{
					appHomeLocation= appHomeLocation+"/" +BXMUtils.getApplicationName(project);
				}
				bxmPropertiesModel.setAppHomeDir(appHomeLocation);
			}

			PropertiesConfiguration pc= new PropertiesConfiguration(project);
			pc.save(bxmPropertiesModel.getContent());

		} catch (Exception e) {
			BuilderLog.logError(e);
		} finally {
			if (inputStream != null) {
				try {
					inputStream.close();
				}
				catch (IOException e) {
					BuilderLog.logError(e);
				}
			}
			monitor.done();
		}
	}
	
	private void createLocalTestResource(IProject project, IProgressMonitor monitor)
	{
		try
		{
			/* hdmfTomcat의 클래스 패스에 잡히는 폴더 */
			IFolder webContent= project.getFolder(BxmConstants.WEB_CONTENT_FOLDER);
			ResourceUtil.ensureFolderExists(webContent, Policy.subMonitorFor(monitor, 1));
			webContent.setDerived(true, monitor);
			
			IFolder webInf= webContent.getFolder(BxmConstants.WEB_CONTENT_WEB_INF_FOLDER);
			ResourceUtil.ensureFolderExists(webInf, Policy.subMonitorFor(monitor, 1));
			webInf.setDerived(true, monitor);
			
			IFolder webLib= webInf.getFolder(BxmConstants.WEB_CONTENT_LIB_FOLDER);
			ResourceUtil.ensureFolderExists(webLib, Policy.subMonitorFor(monitor, 1));
			webLib.setDerived(true, monitor);
			
			/* BXM 프레임워크가 로딩하는 내부 어플리케이션 디렉토리 */
//			IFolder localDeployApp= project.getFolder(project.getName());
//			ResourceUtil.ensureFolderExists(localDeployApp, Policy.subMonitorFor(monitor, 1));
//			localDeployApp.setDerived(true, monitor);
//			localDeployApp.setTeamPrivateMember(true);
//			
//			IFolder localAppClasses= localDeployApp.getFolder(BxmConstants.APP_CLASSES_FOLDER);
//			ResourceUtil.ensureFolderExists(localAppClasses, Policy.subMonitorFor(monitor, 1));
//			localAppClasses.setDerived(true, monitor);
//			localAppClasses.setTeamPrivateMember(true);
//			
//			IFolder localAppLibs= localDeployApp.getFolder(BxmConstants.LIB_FOLDER_NAME_3RD_PARTY);
//			ResourceUtil.ensureFolderExists(localAppLibs, Policy.subMonitorFor(monitor, 1));
//			localAppLibs.setDerived(true, monitor);
//			localAppLibs.setTeamPrivateMember(true);
//			
//			IFolder localAppMeta= localDeployApp.getFolder(BxmConstants.APPLICATION_XML_FOLDER_NAME);
//			ResourceUtil.ensureFolderExists(localAppMeta, Policy.subMonitorFor(monitor, 1));
//			localAppMeta.setDerived(true, monitor);
//			localAppMeta.setTeamPrivateMember(true);
		} catch (Exception e) {
			BuilderLog.logError(e);
		} finally {
			monitor.done();
		}
	}

	/**
	 * Classpath 생성
	 * @param project
	 * @param monitor
	 */
	private void configureClasspath(IProject project, IProgressMonitor monitor) {
		monitor = Policy.monitorFor(monitor);
		monitor.beginTask(null, 2);
		Policy.checkCanceled(monitor);

		IPath projectPath = project.getFullPath();
		
		/**
		 * 온라인의 경우 Output Classpath가 변경되어야 한다...
		 */
//		IPath outputLocation = projectPath.append(BuilderConstants.OUTPUT_FOLDER);
		IPath outputLocation= null;
		if(fFirstPage.isOnline()) {
			outputLocation = projectPath.append(BxmConstants.WEB_CONTENT_FOLDER)
					.append(BxmConstants.WEB_CONTENT_WEB_INF_FOLDER)
					.append(BxmConstants.WEB_CONTENT_CLASSES_FOLDER);
		} else {
			outputLocation = projectPath.append(BuilderConstants.OUTPUT_FOLDER);
		}
		
		List<IClasspathEntry> entries = new ArrayList<IClasspathEntry>();
		entries.addAll(Arrays.asList(PreferenceConstants.getDefaultJRELibrary()));
		
		/**
		 * HDS : 클래스 패스 컨테이너 사용 안함
		 */
//		entries.add(JavaCore.newContainerEntry(Constants.CLASSPATH_CONTAINER));
//		try 
//		{
//			addFrameworkLibrary(entries, project.getName());
//		} 
//		catch (Exception ignoreEx) 
//		{
//			ignoreEx.printStackTrace();
//			Display.getDefault().asyncExec(new Runnable() {
//				@Override
//				public void run() {
//					MessageDialog.openWarn("프로젝트 클래스패스에 framework 라이브러리를 추가하는 도중 에러가 발생하여 클래스패스 추가에 실패하였습니다");
//				}
//			});
//			PluginLog.error("프로젝트 클래스패스에 framework 라이브러리를 추가하는 도중 에러가 발생하였습니다", ignoreEx);
//		}
		
		entries.add(JavaCore.newSourceEntry(
				projectPath.append(BuilderConstants.SOURCE_FOLDER)));
		
		/**
		 * HDS 관련 처리
		 */
		if( ConfigurationUtils.getConfiguration().getGenOmmJavaInSrcGen() ) {
			entries.add(JavaCore.newSourceEntry(
					projectPath.append(BuilderConstants.SOURCE_GEN_FOLDER)));
		}
		
		String ommPfr= ConfigurationUtils.getConfiguration().getOmmPfr();
		
		if( !BxmConstants.SRC_FOLDER_NAME.equals(ommPfr) ) {
			entries.add(JavaCore.newSourceEntry(
					projectPath.append(ommPfr)));
		}
		
		if( fFirstPage.isOnline() ) {
			entries.add(JavaCore.newSourceEntry(
					projectPath.append(BxmConstants.TESTCASES_FOLDER_NAME)));
		} 
		
		entries.add(JavaCore.newSourceEntry(
				projectPath.append(BxmConstants.CONFIG_FOLDER)));
		
		IClasspathEntry[] classpathEntrys =
				(IClasspathEntry[]) entries.toArray(new IClasspathEntry[entries.size()]);

		IJavaProject javaProject = JavaCore.create(project);
		try {
			javaProject.setOutputLocation(outputLocation, Policy.subMonitorFor(monitor, 1));
			javaProject.setRawClasspath(classpathEntrys, Policy.subMonitorFor(monitor, 2));
			
			INewProjectProvider[] providers= BuilderCustomizationManager.instance().getNewProjectProviders();
			for (INewProjectProvider provider : providers) {
				try {
					provider.processProjectProperties(javaProject);
				} catch (Exception e) {
					BuilderLog.logError(e);
				}
			}
		} catch (CoreException e) {
			BuilderLog.logError(e);
		}
		
		
		/**
		 * workaround
		 */
		try {
			IFolder bin= project.getFolder("bin");
			if(bin.exists()) {
				bin.delete(true, monitor);
			}
		} catch (Exception e) {
			// TODO: handle exception
		}
	}
	
	@SuppressWarnings("unused")
	private void addFrameworkLibrary(List<IClasspathEntry> entries, String projectName) throws Exception
	{
		IWorkspaceRoot root= ResourcesPlugin.getWorkspace().getRoot();
		IProject[] projects= root.getProjects();
		
		IProject referenceProj= getReferenceProject(projects);
		List<IResource> frameworkLibs= getFrameworkLibraries(referenceProj, projectName);
		
		for(IResource lib : frameworkLibs)
		{
			entries.add(JavaCore.newLibraryEntry(lib.getRawLocation(), null, null));
		}
	}
	
	private IProject getReferenceProject(IProject[] projects) throws Exception
	{
		final String referenceProjectName= BuilderProperties.instance().getReferenceProjectName();
		
		if(StringUtils.isEmpty(referenceProjectName)) {
			throw new Exception("Reference Project 이름이 설정되어 있지 않습니다");
		}
		
		for(IProject proj : projects)
		{
			if(referenceProjectName.equals(proj.getName()))
			{
				return proj;
			}
		}

		throw new Exception("Reference Project(" + referenceProjectName +")이 존재하지 않습니다");
	}
	
	private List<IResource> getFrameworkLibraries(IProject libProject, String projectName) throws Exception
	{
		IFolder lib= libProject.getFolder(BuilderConstants.LIB_FOLDER);
		
		List<IResource> entries= new ArrayList<IResource>();
		
		if(lib.exists())
		{
			IFolder framework= lib.getFolder(BuilderConstants.CORE_LIB_FOLDER);
			if(framework.exists()) {
				entries.addAll(getJarFiles(framework, null));
			}
			
			IFolder business= lib.getFolder(BuilderConstants.BUSINESS_LIB_FOLDER);
			if(business.exists()) {
				List<IResource> bizzLibs= getJarFiles(business, BuilderConstants.BUSINESS_LIB_POSTFIX); 
				
				/**
				 * 자기 자신 제외 {bizz.code}-online.jar
				 */
				final String excludeName= projectName.toLowerCase() + BuilderConstants.BUSINESS_LIB_POSTFIX;
				IResource exclude= null;
				for(IResource bizzLib : bizzLibs)
				{
					if(bizzLib.getName().equals(excludeName)) {
						exclude= bizzLib;
						break;
					}
				}
				
				if(exclude != null) {
					bizzLibs.remove(exclude);
				}
					
				entries.addAll(bizzLibs);
			}
			
			IFolder dbio= lib.getFolder(BuilderConstants.DBIO_LIB_FOLDER);
			if(dbio.exists()) {
				entries.addAll(getJarFiles(dbio, null));
			}
		}
		
		return entries;
	}
	
	private List<IResource> getJarFiles(IFolder directory, final String postfix) throws Exception
	{
		List<IResource> jars= new ArrayList<IResource>();
		
		try 
		{
			IResource[] children= directory.members();
			
			for(IResource child : children)
			{
				jars.addAll(getJarFilesInternal(child, postfix));
			}
		} 
		catch (CoreException e) 
		{
			throw new Exception("Jar 파일 목록을 로드 하는 도중 에러가 발생하였습니다", e);
		}
		
		return jars;
	}
	
	private List<IResource> getJarFilesInternal(IResource res, final String postfix)
	{
		List<IResource> jars= new ArrayList<IResource>();
		
		if(res.getType() == IResource.FOLDER) {
			IFolder f= (IFolder) res;
			
			try {
				for(IResource child : f.members())
				{
					jars.addAll(getJarFilesInternal(child, postfix));
				}
			} catch (CoreException e) {
				e.printStackTrace();
				PluginLog.error("폴더[" + f.getName() + "] 하위 jar 파일 검색 중 에러가 발생하였습니다", e);
			}
			
		} else if(res.getType() == IResource.FILE) {
			if(BuilderConstants.LIBRARY_EXTENSION.equals(res.getFileExtension()))
			{
				if(StringUtils.isEmpty(postfix)) {
					jars.add(res);
				}else if(res.getName().endsWith(postfix)) {
					jars.add(res);
				}
			}
		}
		return jars;
	}

	/**
	 * create build file
	 */
	@SuppressWarnings("unused")
	private void generateBuildfiles(IJavaProject currentProject, IProgressMonitor monitor) {
		BuildPropertiesCreator creator= new BuildPropertiesCreator();
		creator.createBuildProperties(currentProject.getProject(), monitor);
	}

	protected void setDefaultCharSet(IJavaProject currentProject, IProgressMonitor monitor) {
		try {
			/**
			 * HDS 에서는 UTF-8로 Studio 인코딩을 기본적으로 강제화 하지 않는다.
			 */
			String currentCharEncoding= System.getProperty("file.encoding");
			if(ConfigurationUtils.getConfiguration().getForceCharSetUtf8()) {
				currentProject.getProject().setDefaultCharset(defaultCharEncoding, monitor);
			} else {
				currentProject.getProject().setDefaultCharset(currentCharEncoding, monitor);
			}
		} catch (CoreException e) {
			e.printStackTrace();
		}
	}

	/**
	 * src(기본)에 생기는 기본 패키지 목록 생성
	 * @param javaProject
	 */
	private void configureDefaultPackages(IJavaProject javaProject, IProgressMonitor monitor){

		try {
			javaProject.getResource().refreshLocal(IResource.DEPTH_INFINITE, monitor);
		} catch (CoreException e1) {
			e1.printStackTrace();
		}

		IPackageFragmentRoot[] pfrs= null;
		IPackageFragmentRoot pfr= null;

		try {
			pfrs= javaProject.getPackageFragmentRoots();
		} catch (Exception e) {
			BuilderLog.logError(e);
			return;
		}

		for (IPackageFragmentRoot p : pfrs) {
			// jar 파일 제외
			if ( p.isArchive() ) continue;

			if ( BxmConstants.SRC_FOLDER_NAME.equals( p.getElementName() )){
				pfr= p;
				break;
			}
		}

		if ( pfr== null ){
			BuilderLog.logInfo("["+BxmConstants.SRC_FOLDER_NAME+"] folder does not exist at current project");
			return;
		}

//		for (INewProjectProvider provider : providers) {
////			String[] defaultPackageSet= provider.getDefaultPackageSet(getPackagePrefix());
//			String[] defaultPackageSet= fFirstPage.getDefaultPackageSet();
//
//			for (String defaultPackage : defaultPackageSet) {
//				try {
//					pfr.createPackageFragment(defaultPackage, true, Policy.subMonitorFor(monitor, 1));
//				} catch (JavaModelException e) {
//					e.printStackTrace();
//					BuilderLog.logError(e);
//				}
//			}
//		}

		PackageSet[] defaultPackageSet= fFirstPage.getDefaultPackageSet();

		for (PackageSet defaultPackage : defaultPackageSet) {
			IPackageFragment pf= null;
			try {
				pf= pfr.createPackageFragment(defaultPackage.getPackageName(), true, Policy.subMonitorFor(monitor, 1));
			} catch (JavaModelException e) {
				e.printStackTrace();
				BuilderLog.logError(e);
			}

			try {
				if ( pf!= null && pf.exists() ){
					IFolder folder= (IFolder)pf.getResource();
					IFile file= folder.getFile(".bxm");
					if ( !file.exists() ){
						StringBuilder sb= new StringBuilder();
						sb.append("#Do not modify this file").append("\n");
						sb.append("label=").append(defaultPackage.getDescription()).append("\n");
						ByteArrayInputStream bais= new ByteArrayInputStream(sb.toString().getBytes("UTF8"));
						file.create(bais, true, Policy.subMonitorFor(monitor, 2));
						bais.close();
					}

//					IFolder configFolder= folder.getFolder(".bxm");
//					configFolder.create(true, true, Policy.subMonitorFor(monitor, 2));
//					configFolder.getRawLocation().toFile().
//
//					IFile file= configFolder.getFile("bxm.properties");
//					if ( !file.exists() ){
//						String contents= "label=" + defaultPackage.getDescription() + "\n";
//						ByteArrayInputStream bais= new ByteArrayInputStream(contents.getBytes());
//						file.create(bais, true, Policy.subMonitorFor(monitor, 2));
//						file.setHidden(true);
//						bais.close();
//					}
				}
			} catch (Exception e) {
				// TODO: handle exception
			}
		}
	}

	private void configureDefaultFolders(IJavaProject javaProject, IProgressMonitor monitor){

		try {
			javaProject.getResource().refreshLocal(IResource.DEPTH_INFINITE, monitor);
		} catch (CoreException e1) {
			e1.printStackTrace();
		}

		INewProjectProvider[] providers= BuilderCustomizationManager.instance().getNewProjectProviders();

		for (INewProjectProvider provider : providers) {
			String[] defaultFolderSet= provider.getDefaultFolderSet();

			for (String defaultFolder : defaultFolderSet) {
				try {
					if("testcases".equals(defaultFolder))
					{
						if( !fFirstPage.isOnline() )
						{
							continue;
						}
					}
					IFolder folder = javaProject.getProject().getFolder(defaultFolder);
					ResourceUtil.ensureFolderExists(folder, Policy.subMonitorFor(monitor, 1));
				} catch (CoreException e) {
					e.printStackTrace();
					BuilderLog.logError(e);
				}
			}
		}
	}

	@SuppressWarnings("unused")
	private String getPackagePrefix(){
		return fFirstPage.getProjectCode();
	}
