/**
 *
 */
package bxm.ui.decorators.utils;

import java.net.URL;
import java.util.HashMap;

import org.eclipse.core.runtime.FileLocator;
import org.eclipse.core.runtime.IPath;
import org.eclipse.core.runtime.Path;
import org.eclipse.jface.resource.ImageDescriptor;
import org.eclipse.jface.resource.ImageRegistry;
import org.eclipse.swt.graphics.Image;
import org.osgi.framework.Bundle;

import bxm.ui.decorators.Activator;

/**
 * @author 손현준
 *
 */
public abstract class UIImage {

	private static final IPath ICONS_PATH = new Path("$nl$/icons"); //$NON-NLS-1$

	private static final String NAME_PREFIX = Activator.PLUGIN_ID + "."; //$NON-NLS-1$
	private static final int NAME_PREFIX_LENGTH = NAME_PREFIX.length();

	private static ImageRegistry fgImageRegistry = null;
	private static HashMap<String, ImageDescriptor> fgAvoidSWTErrorMap = null;

	private static final String DECORATOR = "decorator";

	public static final String IMG_OMM_JAVA= NAME_PREFIX + "ommJava.png"; //$NON-NLS-1$
	public static final String IMG_DBIO_INTERFACE= NAME_PREFIX + "dbioInterface.png"; //$NON-NLS-1$
	public static final String IMG_PROJECT= NAME_PREFIX + "project.png"; //$NON-NLS-1$
	public static final String IMG_BEAN= NAME_PREFIX + "beanJava.png"; //$NON-NLS-1$
	public static final String IMG_SERVICE= NAME_PREFIX + "serviceJava.png"; //$NON-NLS-1$
	public static final String IMG_SERVICE_OPERATION= NAME_PREFIX + "decorator_serviceoperation.png"; //$NON-NLS-1$
	public static final String IMG_BEAN_OPERATION= NAME_PREFIX + "decorator_beanoperation.png"; //$NON-NLS-1$


	public static final ImageDescriptor DESC_OMM_JAVA= createManagedFromKey(DECORATOR, IMG_OMM_JAVA);
	public static final ImageDescriptor DESC_DBIO_INTERFACE= createManagedFromKey(DECORATOR, IMG_DBIO_INTERFACE);
	public static final ImageDescriptor DESC_PROJECT= createManagedFromKey(DECORATOR, IMG_PROJECT);

	public static final ImageDescriptor DESC_BEAN= createManagedFromKey(DECORATOR, IMG_BEAN);
	public static final ImageDescriptor DESC_SERVICE= createManagedFromKey(DECORATOR, IMG_SERVICE);
	public static final ImageDescriptor DESC_BEAN_OPERATION= createManagedFromKey(DECORATOR, IMG_BEAN_OPERATION);
	public static final ImageDescriptor DESC_SERVICE_OPERATION= createManagedFromKey(DECORATOR, IMG_SERVICE_OPERATION);

	public static Image get(String key) {
		return getImageRegistry().get(key);
	}

	public static ImageDescriptor getDescriptor(String key) {
		if ( null == fgImageRegistry ) {
			return (ImageDescriptor) fgAvoidSWTErrorMap.get(key);
		}
		return getImageRegistry().getDescriptor(key);
	}

	/* package */ static ImageRegistry getImageRegistry() {
		if ( null == fgImageRegistry ) {
			fgImageRegistry = new ImageRegistry();
			for (String key : fgAvoidSWTErrorMap.keySet()) {
				fgImageRegistry.put(key, (ImageDescriptor) fgAvoidSWTErrorMap.get(key));
			}
			fgAvoidSWTErrorMap = null;
		}
		return fgImageRegistry;
	}

	private static ImageDescriptor createManagedFromKey(String prefix, String key) {
		return createManaged(prefix, key.substring(NAME_PREFIX_LENGTH), key);
	}

	private static ImageDescriptor createManaged(String prefix, String name, String key) {

		ImageDescriptor result = create(prefix, name, true);

		if ( null == fgAvoidSWTErrorMap ) {
			fgAvoidSWTErrorMap = new HashMap<String, ImageDescriptor>();
		}

		fgAvoidSWTErrorMap.put(key, result);

		if ( null == fgImageRegistry ) {
//			System.out.println( "Image registry already defined" ); //$NON-NLS-1$
		}

		return result;
	}

	private static ImageDescriptor create(String prefix, String name, boolean useMissingImageDescriptor) {
		IPath path = null;
		if (prefix == null) {
			path = ICONS_PATH.append(name);
		} else {
			path = ICONS_PATH.append(prefix).append(name);
		}
		return createImageDescriptor( Activator.getDefault().getBundle(), path, useMissingImageDescriptor );
	}

	public static ImageDescriptor createImageDescriptor(Bundle bundle, IPath path, boolean useMissingImageDescriptor) {
		URL url = FileLocator.find(bundle, path, null);
		if ( url != null ) {
			return ImageDescriptor.createFromURL(url);
		}
		if (useMissingImageDescriptor) {
			return ImageDescriptor.getMissingImageDescriptor();
		}
		return null;
	}

}
