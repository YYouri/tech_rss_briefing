        <rule name="ThrowSystemMsgToUI"
        		language="java" 
                message="System Message를 UI로 전달함"
                class="net.sourceforge.pmd.lang.rule.XPathRule"
                externalInfoUrl="http://developer.cis.co.kr/support/pmd/ThrowSystemMsgToUI.html"> 
 
                <description> 
System Message 를 UI로 전달하는지 확인합니다.
System Message 를 직접 전달하지 않고, 업무 특성에 맞는 message 를 전달해야 합니다. 
                </description> 
 
                <priority>4</priority> 
 
                <properties> 
                        <property name="xpath"> 
                                <value> 
                                <![CDATA[
                                        //ThrowStatement/Expression/PrimaryExpression/PrimaryPrefix/AllocationExpression/ClassOrInterfaceType
                                        [
                                                @Image='BizException'
                                                and
                                                (
                                                        ../Arguments/ArgumentList/Expression/PrimaryExpression/PrimaryPrefix/Name
                                                        [
                                                                ends-with(@Image, 'getStatusCode')
                                                        ]
                                                )
                                        ]
                                ]]> 
                                </value> 
                        </property> 
                </properties> 
 
                <example> 
                        <![CDATA[
/* 잘못된 예 */
if(!CodeConstant.OK.equals(dbioResponseVO.getStatusCode() ) ){
        // dbioResponseVO.getStatusCode()를 직접 전달합니다.
        throw new BizException(dbioResponseVO.getStatusCode(), "");
}
                
/* 올바른 예 */
if(!CodeConstant.OK.equals(dbioResponseVO.getStatusCode() ) ){
        // 업무 특성에 맞는 메세지를 전달합니다.
        throw new BizException("UEX00001", {"", ""});
}
                        ]]> 
                </example> 
        </rule> 


        <rule name="UseInterfaceInvokerSameTran" 
        		language="java"
                message="트랜에서 같은 팀의 다른 트랜을 InterfaceInvoker를 이용해서 호출하는지 확인합니다."
                class="net.sourceforge.pmd.lang.rule.XPathRule"
                externalInfoUrl="http://developer.cis.co.kr/support/pmd/UseInterfaceInvokerSameTran.html"> 
 
                <description> 
트랜에서 같은 팀의 다른 트랜을 InterfaceInvoker를 이용해서 호출하는지 확인합니다.
같은 팀의 다른 트랜은 InterfaceInvoker를 사용하지 않고, 직접 호출하는것이 성능에 좋습니다.
                </description> 
 
                <priority>4</priority> 
 
                <properties> 
                        <property name="xpath"> 
                                <value> 
                                <![CDATA[
                                        //CastExpression/PrimaryExpression
                                        [
                                                (
                                                        PrimaryPrefix/Name[@Image='InterfaceInvoker.invoke']
                                                )
                                                and
                                                (
                                                        PrimarySuffix/Arguments/ArgumentList/Expression[2]/PrimaryExpression/PrimaryPrefix/
                                                                Literal[
                                                                        starts-with(@Image, concat('"', substring(ancestor::TypeDeclaration/ClassOrInterfaceDeclaration/@Image, 1, 2)))
                                                                ]
                                                )
                                        ]
                                ]]> 
                                </value> 
                        </property> 
                </properties> 
 
                <example> 
                        <![CDATA[
/* 잘못된 예 */
class TTXX00001M01S {
        ....
 
        public void method1() {
                ...
 
                TTEX0991VO interfaceResVO = (TTEX0991VO)InterfaceInvoker.invoke(this, "TTEX0099I01I", interfaceReqVO);
                ...
        }
}
 
/* 올바른 예 */
class TTXX00001M01S {
        ....
 
        public void method1() {
                ...
 
                TTEX0099S service = new TTEX0099S(getServiceContext());
                resVo = service.method2(reqVo);
                ...
        }
}
                        ]]> 
                </example> 
        </rule> 

        <rule name="AbstractClassWithoutAbstractMethod"
        		language="java"
                since="3.0"
                message="abstract class에 abstract method가 없음"
                class="net.sourceforge.pmd.lang.rule.XPathRule"
                externalInfoUrl="http://developer.cis.co.kr/support/pmd/AbstractClassWithoutAbstractMethod.html"> 
 
                <description> 
